# Copie para .env (local). Em produção, defina as mesmas chaves no painel do host (ex.: DigitalOcean App Platform).

# Obrigatório em produção — senão o Rails aborta ao subir.
# Gere um valor: bin/rails secret   ou   openssl rand -hex 64
SECRET_KEY_BASE=

RAILS_ENV=development

# Banco: em produção na DigitalOcean, prefira colar a connection string inteira:
# DATABASE_URL=postgresql://doadmin:...@host:25060/defaultdb?sslmode=require
DATABASE_URL=

# Ou variáveis separadas (sem DATABASE_URL):
DATABASE_HOST=
DATABASE_PORT=5432
DATABASE_USERNAME=
DATABASE_PASSWORD=
# Legado (só se ainda usar esse nome no deploy):
# SACRISTIA_DIGITAL_DATABASE_PASSWORD=
DATABASE_NAME=sacristia_digital_development

# Produção: require (padrão no database.yml). Se der "dh key too small", veja README (SSL / cluster).
# DATABASE_SSLMODE=require

# URL pública do app (mailer + hosts permitidos; ver config/initializers/allowed_hosts.rb)
APP_HOST=localhost:3000

# Opcional: hosts extras separados por vírgula
# ALLOWED_HOSTS=
