<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= content_for(:title) || "Sacristia Digital - Admin" %></title>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body class="bg-stone-50 text-stone-800 antialiased min-h-screen">
    <% if notice %>
      <div class="fixed top-4 left-4 right-4 sm:left-auto sm:right-4 sm:max-w-sm z-50 px-4 py-2 bg-emerald-100 text-emerald-800 rounded-lg shadow-lg">
        <%= notice %>
      </div>
    <% end %>
    <% if alert %>
      <div class="fixed top-4 left-4 right-4 sm:left-auto sm:right-4 sm:max-w-sm z-50 px-4 py-2 bg-amber-100 text-amber-800 rounded-lg shadow-lg">
        <%= alert %>
      </div>
    <% end %>

    <div class="flex min-h-screen" data-controller="sidebar">
      <div data-sidebar-target="overlay" class="fixed inset-0 z-30 bg-stone-900/50 transition-opacity lg:hidden invisible opacity-0 pointer-events-none" data-action="click->sidebar#close" aria-hidden="true"></div>
      <aside data-sidebar-target="sidebar" class="fixed lg:static inset-y-0 left-0 z-40 w-64 bg-slate-900 flex flex-col transform -translate-x-full lg:translate-x-0 transition-transform duration-300 ease-out">
        <div class="p-6 border-b border-slate-700">
          <h1 class="text-lg font-semibold text-white">Sacristia Digital</h1>
          <p class="text-xs text-slate-400 mt-1">Painel Administrativo</p>
        </div>
        <nav class="flex-1 p-4 space-y-1 overflow-y-auto">
          <% nav_active = ->(path) { path == '/admin' ? request.path.match?(%r{^/admin/?$}) : request.path.start_with?(path) } %>
          <%= link_to admin_root_path, class: "flex items-center gap-3 px-4 py-2.5 rounded-xl text-slate-300 hover:bg-slate-800 hover:text-white #{nav_active['/admin'] ? 'bg-sky-600 text-white hover:bg-sky-600' : ''}" do %>
            <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
            Dashboard
          <% end %>
          <% if current_user.admin? || current_user.coordenador? %>
            <%= link_to ministro_root_path, class: "flex items-center gap-3 px-4 py-2.5 rounded-xl text-slate-300 hover:bg-slate-800 hover:text-white #{request.path.start_with?('/ministro') ? 'bg-violet-600 text-white hover:bg-violet-600' : ''}" do %>
              <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
              Minha escala
            <% end %>
          <% end %>
          <p class="px-4 pt-4 pb-1 text-xs font-medium text-slate-500 uppercase tracking-wider">Cadastros</p>
          <%= link_to admin_users_path, class: "flex items-center gap-3 px-4 py-2.5 rounded-xl text-slate-300 hover:bg-slate-800 hover:text-white #{nav_active['/admin/users'] ? 'bg-sky-600 text-white hover:bg-sky-600' : ''}" do %>
            <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
            Usuários
          <% end %>
          <%= link_to admin_ministros_path, class: "flex items-center gap-3 px-4 py-2.5 rounded-xl text-slate-300 hover:bg-slate-800 hover:text-white #{nav_active['/admin/ministros'] ? 'bg-sky-600 text-white hover:bg-sky-600' : ''}" do %>
            <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
            Ministros
          <% end %>
          <%= link_to admin_sacerdotes_path, class: "flex items-center gap-3 px-4 py-2.5 rounded-xl text-slate-300 hover:bg-slate-800 hover:text-white #{nav_active['/admin/sacerdotes'] ? 'bg-sky-600 text-white hover:bg-sky-600' : ''}" do %>
            <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
            Sacerdotes
          <% end %>
          <%= link_to admin_tipo_servicos_path, class: "flex items-center gap-3 px-4 py-2.5 rounded-xl text-slate-300 hover:bg-slate-800 hover:text-white #{nav_active['/admin/tipos-servico'] ? 'bg-sky-600 text-white hover:bg-sky-600' : ''}" do %>
            <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/></svg>
            Tipos de Serviço
          <% end %>
          <p class="px-4 pt-4 pb-1 text-xs font-medium text-slate-500 uppercase tracking-wider">Escalas</p>
          <%= link_to admin_calendario_base_index_path, class: "flex items-center gap-3 px-4 py-2.5 rounded-xl text-slate-300 hover:bg-slate-800 hover:text-white #{nav_active['/admin/calendario-base'] ? 'bg-sky-600 text-white hover:bg-sky-600' : ''}" do %>
            <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
            Calendário Base
          <% end %>
          <%= link_to admin_equipes_path, class: "flex items-center gap-3 px-4 py-2.5 rounded-xl text-slate-300 hover:bg-slate-800 hover:text-white #{nav_active['/admin/equipes'] ? 'bg-sky-600 text-white hover:bg-sky-600' : ''}" do %>
            <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
            Equipes
          <% end %>
          <%= link_to admin_competencia_mensal_index_path, class: "flex items-center gap-3 px-4 py-2.5 rounded-xl text-slate-300 hover:bg-slate-800 hover:text-white #{nav_active['/admin/competencia-mensal'] ? 'bg-sky-600 text-white hover:bg-sky-600' : ''}" do %>
            <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"/></svg>
            Competências
          <% end %>
          <%= link_to admin_eventos_extra_index_path, class: "flex items-center gap-3 px-4 py-2.5 rounded-xl text-slate-300 hover:bg-slate-800 hover:text-white #{nav_active['/admin/eventos-extra'] ? 'bg-sky-600 text-white hover:bg-sky-600' : ''}" do %>
            <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            Eventos Extra
          <% end %>
          <p class="px-4 pt-4 pb-1 text-xs font-medium text-slate-500 uppercase tracking-wider">Financeiro</p>
          <%= link_to admin_registros_esportula_index_path, class: "flex items-center gap-3 px-4 py-2.5 rounded-xl text-slate-300 hover:bg-slate-800 hover:text-white #{nav_active['/admin/esportulas'] ? 'bg-sky-600 text-white hover:bg-sky-600' : ''}" do %>
            <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            Espórtulas
          <% end %>
          <p class="px-4 pt-4 pb-1 text-xs font-medium text-slate-500 uppercase tracking-wider">Relatórios</p>
          <%= link_to admin_relatorios_path, class: "flex items-center gap-3 px-4 py-2.5 rounded-xl text-slate-300 hover:bg-slate-800 hover:text-white #{nav_active['/admin/relatorios'] ? 'bg-sky-600 text-white hover:bg-sky-600' : ''}" do %>
            <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
            Relatórios
          <% end %>
        </nav>
        <div class="p-4 border-t border-slate-700">
          <%= button_to destroy_user_session_path, method: :delete, form: { data: { turbo: false } }, class: "flex items-center gap-3 w-full px-4 py-2.5 text-sm text-slate-400 hover:text-white hover:bg-slate-800 rounded-xl text-left transition-colors" do %>
            <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
            Sair
          <% end %>
        </div>
      </aside>
      <div class="flex-1 flex flex-col min-w-0">
        <header class="lg:hidden sticky top-0 z-20 flex items-center gap-2 px-4 py-3 bg-white border-b border-stone-200">
          <button type="button" data-action="click->sidebar#toggle" class="p-2 -ml-2 rounded-lg text-stone-600 hover:bg-stone-100 shrink-0" aria-label="Abrir menu">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
          </button>
          <span class="font-semibold text-stone-800 truncate min-w-0 flex-1">Sacristia Digital</span>
          <% if current_user.admin? || current_user.coordenador? %>
            <%= link_to ministro_root_path, class: "shrink-0 inline-flex items-center gap-1 px-2.5 py-1.5 rounded-lg text-xs font-semibold bg-violet-100 text-violet-900 border border-violet-200/80 hover:bg-violet-200/80" do %>
              Escala
            <% end %>
          <% end %>
        </header>
        <main class="flex-1 p-4 sm:p-6 lg:p-8 overflow-x-hidden">
          <%= yield %>
        </main>
      </div>
    </div>
  </body>
</html>
