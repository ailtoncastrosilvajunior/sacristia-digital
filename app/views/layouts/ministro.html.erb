<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= content_for(:title) || "Sacristia Digital - Minha Escala" %></title>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body class="bg-stone-50 text-stone-800 antialiased min-h-screen">
    <% if notice %>
      <div class="fixed top-4 right-4 z-50 px-4 py-2 bg-emerald-100 text-emerald-800 rounded-lg shadow-lg">
        <%= notice %>
      </div>
    <% end %>
    <% if alert %>
      <div class="fixed top-4 right-4 z-50 px-4 py-2 bg-amber-100 text-amber-800 rounded-lg shadow-lg">
        <%= alert %>
      </div>
    <% end %>

    <div class="max-w-4xl mx-auto px-4 py-8">
      <header class="flex justify-between items-center mb-8">
        <div>
          <h1 class="text-xl font-semibold text-stone-800">Sacristia Digital</h1>
          <p class="text-sm text-stone-500">Minha escala de serviços</p>
        </div>
        <%= button_to "Sair", destroy_user_session_path, method: :delete, class: "px-4 py-2 text-sm text-stone-600 hover:text-stone-800 hover:bg-stone-100 rounded-lg" %>
      </header>
      <%= yield %>
    </div>
  </body>
</html>
