<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= content_for(:title) || "Sacristia Digital - Minha Escala" %></title>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body class="bg-stone-50 text-stone-800 antialiased min-h-screen">
    <% if notice %>
      <div class="fixed top-4 left-4 right-4 sm:left-auto sm:right-4 sm:max-w-sm z-50 px-4 py-2 bg-emerald-100 text-emerald-800 rounded-lg shadow-lg">
        <%= notice %>
      </div>
    <% end %>
    <% if alert %>
      <div class="fixed top-4 left-4 right-4 sm:left-auto sm:right-4 sm:max-w-sm z-50 px-4 py-2 bg-amber-100 text-amber-800 rounded-lg shadow-lg">
        <%= alert %>
      </div>
    <% end %>

    <div class="max-w-6xl mx-auto px-4 py-6 sm:px-6 lg:px-8 lg:py-8">
      <header class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between mb-8 pb-6 border-b border-stone-200/80">
        <div>
          <h1 class="text-lg font-semibold text-stone-900">Sacristia Digital</h1>
          <p class="text-sm text-violet-700/90 font-medium">Área do ministro</p>
        </div>
        <nav class="flex flex-wrap items-center gap-2">
          <%= link_to ministro_root_path, class: "inline-flex items-center gap-1.5 px-3 py-2 rounded-xl text-sm font-medium #{request.path == ministro_root_path ? "bg-violet-100 text-violet-900" : "text-stone-600 hover:bg-stone-100"}" do %>
            <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
            Minha escala
          <% end %>
          <%= link_to ministro_meus_servicos_path, class: "inline-flex items-center gap-1.5 px-3 py-2 rounded-xl text-sm font-medium #{request.path.start_with?("/ministro/meus-servicos") || request.path.match?(%r{^/ministro/servicos/}) ? "bg-violet-100 text-violet-900" : "text-stone-600 hover:bg-stone-100"}" do %>
            <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>
            Meus serviços
          <% end %>
          <% if current_user.admin? %>
            <%= link_to admin_root_path, class: "inline-flex items-center gap-1.5 px-3 py-2 rounded-xl text-sm font-medium text-sky-800 bg-sky-50 border border-sky-200/80 hover:bg-sky-100" do %>
              <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              Painel admin
            <% end %>
          <% end %>
          <% if current_user.coordenador? %>
            <%= link_to coordenador_root_path, class: "inline-flex items-center gap-1.5 px-3 py-2 rounded-xl text-sm font-medium text-indigo-800 bg-indigo-50 border border-indigo-200/80 hover:bg-indigo-100" do %>
              <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              Painel coordenador
            <% end %>
          <% end %>
          <%= button_to destroy_user_session_path, method: :delete, form: { data: { turbo: false } }, class: "inline-flex items-center gap-1.5 px-3 py-2 rounded-xl text-sm font-medium text-stone-600 hover:bg-stone-100 border border-transparent hover:border-stone-200" do %>
            <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
            Sair
          <% end %>
        </nav>
      </header>
      <%= yield %>
    </div>
  </body>
</html>
