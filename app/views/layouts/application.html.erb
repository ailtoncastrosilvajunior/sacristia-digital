<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= content_for(:title) || "Sacristia Digital" %></title>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body class="bg-stone-50 text-stone-800 antialiased">
    <% if notice %>
      <div class="fixed top-4 right-4 z-50 px-4 py-2 bg-emerald-100 text-emerald-800 rounded-lg shadow-lg" data-controller="flash" data-flash-target="message">
        <%= notice %>
      </div>
    <% end %>
    <% if alert %>
      <div class="fixed top-4 right-4 z-50 px-4 py-2 bg-amber-100 text-amber-800 rounded-lg shadow-lg" data-controller="flash" data-flash-target="message">
        <%= alert %>
      </div>
    <% end %>
    <%= yield %>
  </body>
</html>
