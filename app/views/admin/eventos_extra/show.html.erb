<div class="space-y-6">
  <div class="flex items-center justify-between">
    <div>
      <%= link_to "← Eventos Extra", admin_eventos_extra_index_path, class: "text-sm text-stone-500 hover:text-stone-700 mb-2 block" %>
      <h1 class="text-2xl font-semibold text-stone-800"><%= @evento.tipo_servico.nome %> - <%= l(@evento.data) %></h1>
      <p class="text-stone-500 mt-1">Detalhes do evento extra</p>
    </div>
    <div class="flex gap-2">
      <%= link_to "Editar", edit_admin_eventos_extra_path(@evento),
          class: "px-4 py-2 bg-slate-600 hover:bg-slate-700 text-white font-medium rounded-lg transition-colors" %>
      <%= button_to "Excluir", admin_eventos_extra_path(@evento), method: :delete, data: { turbo_confirm: "Tem certeza que deseja excluir este evento?" },
          class: "px-4 py-2 border border-red-300 text-red-600 hover:bg-red-50 font-medium rounded-lg transition-colors" %>
    </div>
  </div>

  <div class="bg-white rounded-xl border border-stone-200 shadow-sm p-6">
    <dl class="grid grid-cols-1 gap-4 sm:grid-cols-2">
      <div>
        <dt class="text-sm font-medium text-stone-500">Data</dt>
        <dd class="mt-1 text-stone-800"><%= l(@evento.data) %></dd>
      </div>
      <div>
        <dt class="text-sm font-medium text-stone-500">Horário</dt>
        <dd class="mt-1 text-stone-800"><%= l(@evento.horario, format: :time) %></dd>
      </div>
      <div>
        <dt class="text-sm font-medium text-stone-500">Tipo de serviço</dt>
        <dd class="mt-1 text-stone-800"><%= @evento.tipo_servico.nome %></dd>
      </div>
      <div>
        <dt class="text-sm font-medium text-stone-500">Competência</dt>
        <dd class="mt-1 text-stone-800"><%= @evento.competencia_mensal.label %></dd>
      </div>
      <div>
        <dt class="text-sm font-medium text-stone-500">Local</dt>
        <dd class="mt-1 text-stone-800"><%= @evento.local || "—" %></dd>
      </div>
      <div>
        <dt class="text-sm font-medium text-stone-500">Sacerdote</dt>
        <dd class="mt-1 text-stone-800"><%= @evento.sacerdote&.nome || "—" %></dd>
      </div>
      <div>
        <dt class="text-sm font-medium text-stone-500">Quantidade de ministros</dt>
        <dd class="mt-1 text-stone-800"><%= @evento.quantidade_ministros %></dd>
      </div>
      <div>
        <dt class="text-sm font-medium text-stone-500">Status</dt>
        <dd class="mt-1">
          <span class="inline-flex px-2 py-1 text-xs font-medium rounded-full
            <%= case @evento.status
                when 'concluido' then 'bg-emerald-100 text-emerald-800'
                when 'confirmado' then 'bg-blue-100 text-blue-800'
                when 'cancelado' then 'bg-stone-100 text-stone-600'
                else 'bg-amber-100 text-amber-800'
                end %>">
            <%= @evento.status.capitalize %>
          </span>
        </dd>
      </div>
      <% if @evento.descricao.present? %>
        <div class="sm:col-span-2">
          <dt class="text-sm font-medium text-stone-500">Descrição</dt>
          <dd class="mt-1 text-stone-800"><%= simple_format(@evento.descricao) %></dd>
        </div>
      <% end %>
      <% if @evento.observacoes.present? %>
        <div class="sm:col-span-2">
          <dt class="text-sm font-medium text-stone-500">Observações</dt>
          <dd class="mt-1 text-stone-800"><%= simple_format(@evento.observacoes) %></dd>
        </div>
      <% end %>
    </dl>
  </div>
</div>
