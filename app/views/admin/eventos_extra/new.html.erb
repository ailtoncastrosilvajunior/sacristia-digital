<div class="space-y-6">
  <div>
    <%= link_to "← Eventos Extra", admin_eventos_extra_index_path, class: "text-sm text-stone-500 hover:text-stone-700 mb-2 block" %>
    <h1 class="text-2xl font-semibold text-stone-800">Novo evento extra</h1>
    <p class="text-stone-500 mt-1">Cadastre uma missa ou celebração extra</p>
  </div>

  <div class="bg-white rounded-xl border border-stone-200 shadow-sm p-6 max-w-2xl">
    <%= form_with model: @evento, url: admin_eventos_extra_index_path, local: true, html: { class: "space-y-5" } do |f| %>
      <% if @evento.errors.any? %>
        <div class="rounded-lg bg-red-50 p-4 text-red-800 text-sm">
          <p class="font-medium mb-2"><%= pluralize(@evento.errors.count, "erro") %> impediram o cadastro:</p>
          <ul class="list-disc list-inside">
            <% @evento.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div>
        <%= f.label :competencia_mensal_id, "Competência", class: "block text-sm font-medium text-stone-700 mb-1" %>
        <%= f.collection_select :competencia_mensal_id, CompetenciaMensal.ordenados, :id, :label, { include_blank: "Selecione" },
            class: "w-full px-4 py-2.5 rounded-lg border border-stone-300 focus:ring-2 focus:ring-slate-500/20 focus:border-slate-500" %>
      </div>

      <div>
        <%= f.label :tipo_servico_id, "Tipo de serviço", class: "block text-sm font-medium text-stone-700 mb-1" %>
        <%= f.collection_select :tipo_servico_id, TipoServico.extras.ativos, :id, :nome, { include_blank: "Selecione" },
            class: "w-full px-4 py-2.5 rounded-lg border border-stone-300 focus:ring-2 focus:ring-slate-500/20 focus:border-slate-500" %>
      </div>

      <div class="grid grid-cols-2 gap-4">
        <div>
          <%= f.label :data, class: "block text-sm font-medium text-stone-700 mb-1" %>
          <%= f.date_field :data, class: "w-full px-4 py-2.5 rounded-lg border border-stone-300 focus:ring-2 focus:ring-slate-500/20 focus:border-slate-500" %>
        </div>
        <div>
          <%= f.label :horario, class: "block text-sm font-medium text-stone-700 mb-1" %>
          <%= f.time_field :horario, class: "w-full px-4 py-2.5 rounded-lg border border-stone-300 focus:ring-2 focus:ring-slate-500/20 focus:border-slate-500", value: "08:00" %>
        </div>
      </div>

      <div>
        <%= f.label :local, class: "block text-sm font-medium text-stone-700 mb-1" %>
        <%= f.text_field :local, class: "w-full px-4 py-2.5 rounded-lg border border-stone-300 focus:ring-2 focus:ring-slate-500/20 focus:border-slate-500" %>
      </div>

      <div>
        <%= f.label :quantidade_ministros, "Quantidade de ministros", class: "block text-sm font-medium text-stone-700 mb-1" %>
        <%= f.number_field :quantidade_ministros, min: 1, class: "w-full px-4 py-2.5 rounded-lg border border-stone-300 focus:ring-2 focus:ring-slate-500/20 focus:border-slate-500" %>
      </div>

      <div>
        <%= f.label :sacerdote_id, "Sacerdote", class: "block text-sm font-medium text-stone-700 mb-1" %>
        <%= f.collection_select :sacerdote_id, Sacerdote.ativos.ordenados_por_nome, :id, :nome, { include_blank: "Nenhum" },
            class: "w-full px-4 py-2.5 rounded-lg border border-stone-300 focus:ring-2 focus:ring-slate-500/20 focus:border-slate-500" %>
      </div>

      <div>
        <%= f.label :descricao, class: "block text-sm font-medium text-stone-700 mb-1" %>
        <%= f.text_area :descricao, rows: 2, class: "w-full px-4 py-2.5 rounded-lg border border-stone-300 focus:ring-2 focus:ring-slate-500/20 focus:border-slate-500" %>
      </div>

      <div>
        <%= f.label :observacoes, class: "block text-sm font-medium text-stone-700 mb-1" %>
        <%= f.text_area :observacoes, rows: 2, class: "w-full px-4 py-2.5 rounded-lg border border-stone-300 focus:ring-2 focus:ring-slate-500/20 focus:border-slate-500" %>
      </div>

      <div class="flex gap-3 pt-4">
        <%= f.submit "Cadastrar", class: "px-4 py-2.5 bg-slate-600 hover:bg-slate-700 text-white font-medium rounded-lg transition-colors cursor-pointer" %>
        <%= link_to "Cancelar", admin_eventos_extra_index_path, class: "px-4 py-2.5 border border-stone-300 text-stone-700 hover:bg-stone-50 font-medium rounded-lg transition-colors" %>
      </div>
    <% end %>
  </div>
</div>
