<div class="space-y-6">
  <div>
    <%= link_to "← Espórtulas", admin_registros_esportula_index_path, class: "text-sm text-stone-500 hover:text-stone-700 mb-2 block" %>
    <h1 class="text-2xl font-semibold text-stone-800">Editar registro de espórtula</h1>
    <p class="text-stone-500 mt-1"><%= l(@registro.data) %> - <%= @registro.sacerdote.nome %></p>
  </div>

  <div class="bg-white rounded-xl border border-stone-200 shadow-sm p-6 max-w-2xl">
    <%= form_with model: @registro, url: admin_registros_esportula_path(@registro), local: true, html: { class: "space-y-5" } do |f| %>
      <% if @registro.errors.any? %>
        <div class="rounded-lg bg-red-50 p-4 text-red-800 text-sm">
          <p class="font-medium mb-2"><%= pluralize(@registro.errors.count, "erro") %> impediram a atualização:</p>
          <ul class="list-disc list-inside">
            <% @registro.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div>
        <%= f.label :sacerdote_id, "Sacerdote", class: "block text-sm font-medium text-stone-700 mb-1" %>
        <%= f.collection_select :sacerdote_id, Sacerdote.ativos.ordenados_por_nome, :id, :nome, {},
            class: "w-full px-4 py-2.5 rounded-lg border border-stone-300 focus:ring-2 focus:ring-slate-500/20 focus:border-slate-500" %>
      </div>

      <div>
        <%= f.label :data, class: "block text-sm font-medium text-stone-700 mb-1" %>
        <%= f.date_field :data, class: "w-full px-4 py-2.5 rounded-lg border border-stone-300 focus:ring-2 focus:ring-slate-500/20 focus:border-slate-500" %>
      </div>

      <div>
        <%= f.label :valor, class: "block text-sm font-medium text-stone-700 mb-1" %>
        <%= f.number_field :valor, step: 0.01, min: 0, class: "w-full px-4 py-2.5 rounded-lg border border-stone-300 focus:ring-2 focus:ring-slate-500/20 focus:border-slate-500" %>
      </div>

      <div>
        <%= f.label :forma_pagamento, "Forma de pagamento", class: "block text-sm font-medium text-stone-700 mb-1" %>
        <%= f.text_field :forma_pagamento, class: "w-full px-4 py-2.5 rounded-lg border border-stone-300 focus:ring-2 focus:ring-slate-500/20 focus:border-slate-500" %>
      </div>

      <div>
        <%= f.label :status, class: "block text-sm font-medium text-stone-700 mb-1" %>
        <%= f.select :status, RegistroEsportula::STATUS.map { |s| [s.capitalize, s] }, {},
            class: "w-full px-4 py-2.5 rounded-lg border border-stone-300 focus:ring-2 focus:ring-slate-500/20 focus:border-slate-500" %>
      </div>

      <div class="grid grid-cols-2 gap-4">
        <div>
          <%= f.label :competencia_mes, "Mês (competência)", class: "block text-sm font-medium text-stone-700 mb-1" %>
          <%= f.number_field :competencia_mes, min: 1, max: 12, class: "w-full px-4 py-2.5 rounded-lg border border-stone-300 focus:ring-2 focus:ring-slate-500/20 focus:border-slate-500" %>
        </div>
        <div>
          <%= f.label :competencia_ano, "Ano (competência)", class: "block text-sm font-medium text-stone-700 mb-1" %>
          <%= f.number_field :competencia_ano, min: 2020, max: 2100, class: "w-full px-4 py-2.5 rounded-lg border border-stone-300 focus:ring-2 focus:ring-slate-500/20 focus:border-slate-500" %>
        </div>
      </div>

      <div>
        <%= f.label :evento_escala_id, "Evento (opcional)", class: "block text-sm font-medium text-stone-700 mb-1" %>
        <%= f.collection_select :evento_escala_id, EventoEscala.extras.por_data.limit(100), :id, :to_s, { include_blank: "Nenhum" },
            class: "w-full px-4 py-2.5 rounded-lg border border-stone-300 focus:ring-2 focus:ring-slate-500/20 focus:border-slate-500" %>
      </div>

      <div class="flex gap-3 pt-4">
        <%= f.submit "Salvar", class: "px-4 py-2.5 bg-slate-600 hover:bg-slate-700 text-white font-medium rounded-lg transition-colors cursor-pointer" %>
        <%= link_to "Cancelar", admin_registros_esportula_path(@registro), class: "px-4 py-2.5 border border-stone-300 text-stone-700 hover:bg-stone-50 font-medium rounded-lg transition-colors" %>
      </div>
    <% end %>
  </div>
</div>
