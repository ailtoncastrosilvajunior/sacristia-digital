<% content_for :title, "#{@ministro.nome} — Ministros" %>

<div class="min-h-full">
  <%# Header %>
  <div class="border-b border-stone-200 bg-white">
    <div class="px-6 py-5 sm:px-8">
      <div class="flex items-center justify-between gap-6">
        <div class="min-w-0">
          <p class="text-xs font-medium text-stone-500 uppercase tracking-wide">Ministro</p>
          <h1 class="mt-1 text-3xl font-semibold text-stone-900"><%= @ministro.nome %></h1>
          <div class="mt-2 flex items-center gap-4">
            <span class="inline-flex px-2.5 py-1 text-xs font-medium rounded <%= @ministro.ativo? ? 'bg-emerald-100 text-emerald-700' : 'bg-stone-100 text-stone-600' %>">
              <%= @ministro.ativo? ? "Ativo" : "Inativo" %>
            </span>
            <% if @ministro.sexo.present? %>
              <span class="text-sm text-stone-600"><%= @ministro.sexo %></span>
            <% end %>
          </div>
        </div>
        <div class="flex gap-2 shrink-0">
          <%= link_to edit_admin_ministro_path(@ministro), class: "px-4 py-2 bg-stone-900 text-white text-sm font-medium rounded-lg hover:bg-stone-800 transition-colors" do %>
            Editar
          <% end %>
          <%= button_to admin_ministro_path(@ministro), method: :delete, data: { turbo_confirm: "Tem certeza?" }, class: "px-4 py-2 border border-red-300 text-red-700 text-sm font-medium rounded-lg hover:bg-red-50 transition-colors" do %>
            Excluir
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <div class="space-y-6 p-6 sm:p-8">

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <%# Coluna esquerda: Informações básicas %>
    <div class="lg:col-span-1">
      <div class="relative overflow-hidden rounded-lg bg-stone-50/60 border border-stone-200/40 shadow-sm p-6 space-y-6">
        <div class="absolute inset-x-0 top-0 h-1 bg-gradient-to-r from-slate-400 to-slate-300"></div>
        <div>
          <p class="text-xs font-medium text-stone-500 uppercase tracking-wide">Email</p>
          <p class="mt-2 text-stone-900"><%= @ministro.email %></p>
        </div>
        <% if @ministro.telefone.present? %>
          <div>
            <p class="text-xs font-medium text-stone-500 uppercase tracking-wide">Telefone</p>
            <p class="mt-2 text-stone-900"><%= @ministro.telefone %></p>
          </div>
        <% end %>
        <% if @ministro.observacoes.present? %>
          <div>
            <p class="text-xs font-medium text-stone-500 uppercase tracking-wide">Observações</p>
            <div class="mt-2 text-sm text-stone-700 leading-relaxed space-y-2">
              <%= simple_format(@ministro.observacoes) %>
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <%# Coluna direita: Serviços %>
    <div class="lg:col-span-2 space-y-6">
      <%# KPIs %>
      <div class="grid grid-cols-3 gap-4">
        <div class="relative overflow-hidden rounded-lg bg-stone-50/60 border border-stone-200/40 shadow-sm p-4 text-center">
          <div class="absolute inset-x-0 top-0 h-0.5 bg-sky-400"></div>
          <p class="text-xs font-medium text-stone-500 uppercase tracking-wide">Serviços</p>
          <p class="mt-3 text-2xl font-bold text-stone-900"><%= @ministro.evento_escalas.count %></p>
        </div>
        <div class="relative overflow-hidden rounded-lg bg-stone-50/60 border border-stone-200/40 shadow-sm p-4 text-center">
          <div class="absolute inset-x-0 top-0 h-0.5 bg-emerald-400"></div>
          <p class="text-xs font-medium text-stone-500 uppercase tracking-wide">Confirmados</p>
          <p class="mt-3 text-2xl font-bold text-stone-900"><%= @ministro.escala_ministros.where(confirmado: true).count %></p>
        </div>
        <div class="relative overflow-hidden rounded-lg bg-stone-50/60 border border-stone-200/40 shadow-sm p-4 text-center">
          <div class="absolute inset-x-0 top-0 h-0.5 bg-amber-400"></div>
          <p class="text-xs font-medium text-stone-500 uppercase tracking-wide">Equipes</p>
          <p class="mt-3 text-2xl font-bold text-stone-900"><%= @ministro.equipes.count %></p>
        </div>
      </div>

      <%# Tabela de serviços %>
      <div class="relative overflow-hidden rounded-lg bg-stone-50/60 border border-stone-200/40 shadow-sm">
        <div class="absolute inset-x-0 top-0 h-1 bg-gradient-to-r from-slate-300 to-stone-300"></div>
        <div class="border-b border-stone-200/40 bg-stone-50/80 px-6 py-4">
          <h3 class="font-semibold text-stone-900 text-sm">Últimos serviços</h3>
        </div>
        <% if @ministro.evento_escalas.any? %>
          <table class="w-full text-sm">
            <tbody class="divide-y divide-stone-200">
              <% @ministro.evento_escalas.order(data: :desc).limit(10).each do |evento| %>
                <tr class="hover:bg-stone-50">
                  <td class="px-6 py-3 text-stone-900 font-medium"><%= evento.tipo_servico.nome %></td>
                  <td class="px-6 py-3 text-stone-600 tabular-nums text-right"><%= l(evento.data, format: :short) %></td>
                  <td class="px-6 py-3 text-right">
                    <% em = evento.escala_ministros.find { |x| x.ministro_id == @ministro.id } %>
                    <% if em&.confirmado? %>
                      <span class="inline-flex px-2 py-0.5 text-xs font-medium bg-emerald-100 text-emerald-700 rounded">Confirmado</span>
                    <% elsif em %>
                      <span class="inline-flex px-2 py-0.5 text-xs font-medium bg-amber-100 text-amber-700 rounded">Pendente</span>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        <% else %>
          <div class="px-6 py-8 text-center text-stone-500 text-sm">Nenhum serviço registrado</div>
        <% end %>
      </div>
    </div>
  </div>
</div>
