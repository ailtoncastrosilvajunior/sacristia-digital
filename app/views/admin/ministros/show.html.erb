<div class="space-y-6">
  <div class="flex items-center justify-between">
    <div>
      <%= link_to "← Ministros", admin_ministros_path, class: "text-sm text-stone-500 hover:text-stone-700 mb-2 block" %>
      <h1 class="text-2xl font-semibold text-stone-800"><%= @ministro.nome %></h1>
      <p class="text-stone-500 mt-1">Detalhes do ministro</p>
    </div>
    <div class="flex gap-2">
      <%= link_to "Novo", new_admin_ministro_path, 
        data: { turbo_frame: "evento_modal" }, 
        class: "inline-flex items-center justify-center px-3 py-1.5 bg-emerald-600 hover:bg-emerald-700 text-white text-sm font-medium rounded-lg transition-colors" 
      %>
      <%= link_to "Editar", edit_admin_ministro_path(@ministro),
          class: "px-4 py-2 bg-slate-600 hover:bg-slate-700 text-white font-medium rounded-lg transition-colors" %>
      <%= button_to "Excluir", admin_ministro_path(@ministro), method: :delete, data: { turbo_confirm: "Tem certeza que deseja excluir este ministro?" },
          class: "px-4 py-2 border border-red-300 text-red-600 hover:bg-red-50 font-medium rounded-lg transition-colors" %>
    </div>
  </div>

  <div class="bg-white rounded-xl border border-stone-200 shadow-sm p-6">
    <dl class="grid grid-cols-1 gap-4 sm:grid-cols-2">
      <div>
        <dt class="text-sm font-medium text-stone-500">Nome</dt>
        <dd class="mt-1 text-stone-800"><%= @ministro.nome %></dd>
      </div>
      <div>
        <dt class="text-sm font-medium text-stone-500">Email</dt>
        <dd class="mt-1 text-stone-800"><%= @ministro.email %></dd>
      </div>
      <div>
        <dt class="text-sm font-medium text-stone-500">Telefone</dt>
        <dd class="mt-1 text-stone-800"><%= @ministro.telefone || "—" %></dd>
      </div>
      <div>
        <dt class="text-sm font-medium text-stone-500">Sexo</dt>
        <dd class="mt-1 text-stone-800"><%= @ministro.sexo || "—" %></dd>
      </div>
      <div>
        <dt class="text-sm font-medium text-stone-500">Status</dt>
        <dd class="mt-1">
          <span class="inline-flex px-2 py-1 text-xs font-medium rounded-full <%= @ministro.ativo? ? 'bg-emerald-100 text-emerald-800' : 'bg-stone-100 text-stone-600' %>">
            <%= @ministro.ativo? ? "Ativo" : "Inativo" %>
          </span>
        </dd>
      </div>
      <% if @ministro.observacoes.present? %>
        <div class="sm:col-span-2">
          <dt class="text-sm font-medium text-stone-500">Observações</dt>
          <dd class="mt-1 text-stone-800"><%= simple_format(@ministro.observacoes) %></dd>
        </div>
      <% end %>
    </dl>
  </div>
</div>
