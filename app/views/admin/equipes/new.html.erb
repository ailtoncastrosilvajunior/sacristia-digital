<div class="space-y-6">
  <div>
    <%= link_to "← Equipes", admin_equipes_path, class: "text-sm text-stone-500 hover:text-stone-700 mb-2 block" %>
    <h1 class="text-2xl font-semibold text-stone-800">Nova equipe</h1>
    <p class="text-stone-500 mt-1">Cadastre uma nova equipe de ministros</p>
  </div>

  <div class="bg-white rounded-xl border border-stone-200 shadow-sm p-6 max-w-2xl">
    <%= form_with model: [:admin, @equipe], local: true, html: { class: "space-y-5" } do |f| %>
      <% if @equipe.errors.any? %>
        <div class="rounded-lg bg-red-50 p-4 text-red-800 text-sm">
          <p class="font-medium mb-2"><%= pluralize(@equipe.errors.count, "erro") %> impediram o cadastro:</p>
          <ul class="list-disc list-inside">
            <% @equipe.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div>
        <%= f.label :nome, class: "block text-sm font-medium text-stone-700 mb-1" %>
        <%= f.text_field :nome, class: "w-full px-4 py-2.5 rounded-lg border border-stone-300 focus:ring-2 focus:ring-slate-500/20 focus:border-slate-500", placeholder: "Ex: Equipe A", autofocus: true %>
      </div>

      <div>
        <%= f.label :observacoes, class: "block text-sm font-medium text-stone-700 mb-1" %>
        <%= f.text_area :observacoes, rows: 3, class: "w-full px-4 py-2.5 rounded-lg border border-stone-300 focus:ring-2 focus:ring-slate-500/20 focus:border-slate-500" %>
      </div>

      <div>
        <%= f.label :ministro_ids, "Ministros da equipe", class: "block text-sm font-medium text-stone-700 mb-1" %>
        <div class="rounded-lg border border-stone-300 p-3 max-h-48 overflow-y-auto bg-stone-50/50">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
            <% Ministro.ativos.ordenados_por_nome.each do |ministro| %>
              <label class="flex items-center gap-2 p-2 rounded-lg hover:bg-white cursor-pointer transition-colors">
                <%= f.check_box :ministro_ids, { multiple: true }, ministro.id, nil %>
                <span class="text-sm text-stone-800"><%= ministro.nome %></span>
              </label>
            <% end %>
          </div>
        </div>
        <p class="mt-1 text-sm text-stone-500">Marque os ministros que fazem parte desta equipe</p>
      </div>

      <div class="border-t border-stone-200 pt-4">
        <h3 class="text-sm font-medium text-stone-700 mb-3">Dias de plantão no mês</h3>
        <p class="text-sm text-stone-500 mb-3">Indique em quais dias (1 a 31) esta equipe fica de plantão. Os eventos extra da competência serão associados automaticamente à equipe do dia.</p>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <%= f.label :dia_inicio, "Do dia", class: "block text-sm font-medium text-stone-700 mb-1" %>
            <%= f.number_field :dia_inicio, min: 1, max: 31, placeholder: "1", class: "w-full px-4 py-2.5 rounded-lg border border-stone-300 focus:ring-2 focus:ring-slate-500/20 focus:border-slate-500" %>
          </div>
          <div>
            <%= f.label :dia_fim, "Até o dia", class: "block text-sm font-medium text-stone-700 mb-1" %>
            <%= f.number_field :dia_fim, min: 1, max: 31, placeholder: "31", class: "w-full px-4 py-2.5 rounded-lg border border-stone-300 focus:ring-2 focus:ring-slate-500/20 focus:border-slate-500" %>
          </div>
        </div>
        <p class="mt-1 text-xs text-stone-500">Ex: dias 1 a 10, ou 21 a 31. Deixe em branco se a equipe não tiver dias fixos.</p>
      </div>

      <div class="flex gap-3 pt-4">
        <%= f.submit "Cadastrar", class: "px-4 py-2.5 bg-slate-600 hover:bg-slate-700 text-white font-medium rounded-lg transition-colors cursor-pointer" %>
        <%= link_to "Cancelar", admin_equipes_path, class: "px-4 py-2.5 border border-stone-300 text-stone-700 hover:bg-stone-50 font-medium rounded-lg transition-colors" %>
      </div>
    <% end %>
  </div>
</div>
