<div class="space-y-6">
  <div class="flex items-center justify-between">
    <div>
      <%= link_to "← Equipes", admin_equipes_path, class: "text-sm text-stone-500 hover:text-stone-700 mb-2 block" %>
      <h1 class="text-2xl font-semibold text-stone-800"><%= @equipe.nome %></h1>
      <p class="text-stone-500 mt-1">Detalhes da equipe</p>
    </div>
    <div class="flex gap-2">
      <%= link_to "Editar", edit_admin_equipe_path(@equipe),
          class: "px-4 py-2 bg-slate-600 hover:bg-slate-700 text-white font-medium rounded-lg transition-colors" %>
      <%= button_to "Excluir", admin_equipe_path(@equipe), method: :delete, data: { turbo_confirm: "Tem certeza que deseja excluir esta equipe?" },
          class: "px-4 py-2 border border-red-300 text-red-600 hover:bg-red-50 font-medium rounded-lg transition-colors" %>
    </div>
  </div>

  <div class="bg-white rounded-xl border border-stone-200 shadow-sm p-6">
    <dl class="grid grid-cols-1 gap-4 sm:grid-cols-2">
      <div>
        <dt class="text-sm font-medium text-stone-500">Nome</dt>
        <dd class="mt-1 text-stone-800"><%= @equipe.nome %></dd>
      </div>
      <div>
        <dt class="text-sm font-medium text-stone-500">Ministros</dt>
        <dd class="mt-1 text-stone-800"><%= @equipe.ministros.count %></dd>
      </div>
      <% if @equipe.observacoes.present? %>
        <div class="sm:col-span-2">
          <dt class="text-sm font-medium text-stone-500">Observações</dt>
          <dd class="mt-1 text-stone-800"><%= simple_format(@equipe.observacoes) %></dd>
        </div>
      <% end %>
    </dl>

    <% if @equipe.ministros.any? %>
      <div class="mt-6 pt-6 border-t border-stone-200">
        <h3 class="text-sm font-medium text-stone-700 mb-3">Ministros da equipe</h3>
        <ul class="space-y-2">
          <% @equipe.ministros.each do |ministro| %>
            <li class="text-stone-600"><%= ministro.nome %></li>
          <% end %>
        </ul>
      </div>
    <% end %>
  </div>
</div>
