<% content_for :title, "#{@calendario_base.dia_nome} — Calendário base" %>

<div class="space-y-6">
  <div>
    <%= link_to "← Calendário Base", admin_calendario_base_index_path, class: "text-sm text-stone-500 hover:text-stone-700 mb-3 inline-block" %>

    <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
      <div class="min-w-0">
        <p class="text-xs font-medium uppercase tracking-wide text-stone-400">Calendário base</p>
        <h1 class="mt-1 text-2xl font-semibold text-stone-900 tracking-tight"><%= @calendario_base.dia_nome %></h1>
        <p class="mt-1 text-stone-600"><%= I18n.t("activerecord.attributes.calendario_base.tipo.#{@calendario_base.tipo}") %></p>
      </div>
      <div class="flex flex-wrap items-center gap-2 shrink-0">
        <%= link_to new_admin_calendario_base_path,
            class: "inline-flex items-center justify-center gap-1.5 px-3 py-2 bg-emerald-600 hover:bg-emerald-700 text-white text-sm font-medium rounded-lg transition-colors shadow-sm shadow-emerald-900/10" do %>
          <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
          Nova entrada
        <% end %>
        <%= link_to "Editar", edit_admin_calendario_base_path(@calendario_base),
            class: "inline-flex items-center justify-center px-3 py-2 bg-slate-600 hover:bg-slate-700 text-white text-sm font-medium rounded-lg transition-colors" %>
        <%= button_to "Excluir", admin_calendario_base_path(@calendario_base), method: :delete, data: { turbo_confirm: "Tem certeza que deseja excluir esta entrada?" },
            class: "inline-flex items-center justify-center px-3 py-2 border border-red-200 text-red-700 hover:bg-red-50 text-sm font-medium rounded-lg transition-colors bg-white cursor-pointer" %>
      </div>
    </div>
  </div>

  <div class="rounded-2xl border border-stone-200/80 bg-gradient-to-br from-slate-50 via-white to-stone-50/80 p-6 sm:p-8 shadow-sm ring-1 ring-stone-100/80">
    <div class="flex flex-col gap-6 sm:flex-row sm:items-end sm:justify-between">
      <div class="flex flex-wrap items-baseline gap-x-4 gap-y-1">
        <p class="text-3xl sm:text-4xl font-semibold tabular-nums text-stone-900"><%= l(@calendario_base.horario, format: :time) %></p>
        <p class="text-lg text-stone-500 font-medium">Horário fixo</p>
      </div>
      <div class="flex flex-wrap items-center gap-2">
        <span class="inline-flex px-3 py-1.5 text-xs font-semibold rounded-full border bg-sky-100 text-sky-800 border-sky-300">
          <%= I18n.t("activerecord.attributes.calendario_base.tipo.#{@calendario_base.tipo}") %>
        </span>
        <span class="inline-flex px-3 py-1.5 text-xs font-semibold rounded-full border <%= @calendario_base.ativo? ? "bg-emerald-100 text-emerald-800 border-emerald-300" : "bg-stone-100 text-stone-600 border-stone-200" %>">
          <%= @calendario_base.ativo? ? "Ativo" : "Inativo" %>
        </span>
      </div>
    </div>
  </div>

  <div class="bg-white rounded-xl border border-stone-200 shadow-sm overflow-hidden divide-y divide-stone-100">
    <section class="p-6 sm:p-8">
      <h2 class="text-sm font-semibold text-stone-900 mb-4">Detalhes</h2>
      <dl class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3">
        <div class="rounded-xl border border-stone-100 bg-stone-50/50 px-4 py-3">
          <dt class="text-xs font-medium uppercase tracking-wide text-stone-500">Dia da semana</dt>
          <dd class="mt-1 text-stone-900 font-medium"><%= @calendario_base.dia_nome %></dd>
        </div>
        <div class="rounded-xl border border-stone-100 bg-stone-50/50 px-4 py-3">
          <dt class="text-xs font-medium uppercase tracking-wide text-stone-500">Horário</dt>
          <dd class="mt-1 text-stone-900 font-medium tabular-nums"><%= l(@calendario_base.horario, format: :time) %></dd>
        </div>
        <div class="rounded-xl border border-stone-100 bg-stone-50/50 px-4 py-3">
          <dt class="text-xs font-medium uppercase tracking-wide text-stone-500">Tipo</dt>
          <dd class="mt-1 text-stone-900 font-medium"><%= I18n.t("activerecord.attributes.calendario_base.tipo.#{@calendario_base.tipo}") %></dd>
        </div>
        <div class="rounded-xl border border-stone-100 bg-stone-50/50 px-4 py-3">
          <dt class="text-xs font-medium uppercase tracking-wide text-stone-500">Sacerdote</dt>
          <dd class="mt-1 text-stone-900 font-medium"><%= @calendario_base.sacerdote&.nome || "—" %></dd>
        </div>
        <div class="rounded-xl border border-stone-100 bg-stone-50/50 px-4 py-3">
          <dt class="text-xs font-medium uppercase tracking-wide text-stone-500">Quantidade de ministros</dt>
          <dd class="mt-1 text-stone-900 font-medium tabular-nums"><%= @calendario_base.quantidade_ministros %></dd>
        </div>
        <div class="rounded-xl border border-stone-100 bg-stone-50/50 px-4 py-3">
          <dt class="text-xs font-medium uppercase tracking-wide text-stone-500">Valor espórtula (override)</dt>
          <dd class="mt-1 text-stone-900 font-medium tabular-nums"><%= @calendario_base.valor_esportula_override ? number_to_currency(@calendario_base.valor_esportula_override) : "—" %></dd>
        </div>
        <div class="rounded-xl border border-stone-100 bg-stone-50/50 px-4 py-3">
          <dt class="text-xs font-medium uppercase tracking-wide text-stone-500">Status</dt>
          <dd class="mt-1">
            <span class="inline-flex px-3 py-1 text-xs font-semibold rounded-full border <%= @calendario_base.ativo? ? "bg-emerald-100 text-emerald-800 border-emerald-300" : "bg-stone-100 text-stone-600 border-stone-200" %>">
              <%= @calendario_base.ativo? ? "Ativo" : "Inativo" %>
            </span>
          </dd>
        </div>
      </dl>
    </section>

    <% if @calendario_base.observacoes.present? %>
      <section class="p-6 sm:p-8">
        <h2 class="text-sm font-semibold text-stone-900 mb-4">Observações</h2>
        <div class="text-stone-800 text-sm leading-relaxed"><%= simple_format(@calendario_base.observacoes) %></div>
      </section>
    <% end %>
  </div>
</div>
