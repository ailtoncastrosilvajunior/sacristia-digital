<div class="space-y-6">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-semibold text-stone-800">Calendário Base</h1>
      <p class="text-stone-500 mt-1">Horários fixos das missas e celebrações</p>
    </div>
    <%= link_to "Nova entrada", new_admin_calendario_base_path,
        class: "px-4 py-2 bg-slate-600 hover:bg-slate-700 text-white font-medium rounded-lg transition-colors" %>
  </div>

  <div class="bg-white rounded-xl border border-stone-200 shadow-sm overflow-hidden">
    <table class="min-w-full divide-y divide-stone-200">
      <thead class="bg-stone-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-stone-500 uppercase tracking-wider">Dia</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-stone-500 uppercase tracking-wider">Tipo</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-stone-500 uppercase tracking-wider">Horário</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-stone-500 uppercase tracking-wider">Sacerdote</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-stone-500 uppercase tracking-wider">Espórtula padrão</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-stone-500 uppercase tracking-wider">Ministros</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-stone-500 uppercase tracking-wider">Status</th>
          <th class="px-6 py-3 text-right text-xs font-medium text-stone-500 uppercase tracking-wider">Ações</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-stone-200">
        <% @calendario_base.each do |cb| %>
          <tr class="hover:bg-stone-50">
            <td class="px-6 py-4 whitespace-nowrap text-sm text-stone-800"><%= cb.dia_nome %></td>
            <td class="px-6 py-4 whitespace-nowrap">
              <span class="inline-flex px-2 py-1 text-xs font-medium rounded-full <%= cb.tipo_missa? ? 'bg-amber-100 text-amber-800 border border-amber-200' : 'bg-sky-50 text-sky-600 border border-sky-200' %>">
                <%= I18n.t("activerecord.attributes.calendario_base.tipo.#{cb.tipo}") %>
              </span>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-stone-600"><%= l(cb.horario, format: :time) %></td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-stone-600"><%= cb.sacerdote&.nome || "—" %></td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-stone-600"><%= number_to_currency(cb.valor_esportula_override, unit: "R$ ", separator: ",", delimiter: ".") || "—" %></td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-stone-600"><%= cb.quantidade_ministros %></td>
            <td class="px-6 py-4 whitespace-nowrap">
              <span class="inline-flex px-2 py-1 text-xs font-medium rounded-full <%= cb.ativo? ? 'bg-emerald-100 text-emerald-800 border border-emerald-200' : 'bg-stone-100 text-stone-600 border border-stone-200' %>">
                <%= cb.ativo? ? "Ativo" : "Inativo" %>
              </span>
            </td>
            <td class="px-6 py-4 whitespace-nowrap">
              <div class="flex items-center justify-end gap-1">
                <%= link_to admin_calendario_base_path(cb), title: "Ver detalhes", class: "p-2 rounded-lg text-stone-400 hover:text-slate-600 hover:bg-stone-100 transition-colors" do %>
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                <% end %>
                <%= link_to edit_admin_calendario_base_path(cb), title: "Editar", class: "p-2 rounded-lg text-stone-400 hover:text-sky-600 hover:bg-sky-50 transition-colors" do %>
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                <% end %>
                <%= button_to admin_calendario_base_path(cb), method: :delete, data: { turbo_confirm: "Tem certeza que deseja excluir esta entrada?" }, form: { class: "inline" }, title: "Excluir", class: "p-2 rounded-lg text-stone-400 hover:text-red-600 hover:bg-red-50 transition-colors border-0 bg-transparent cursor-pointer" do %>
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                <% end %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>

    <% if @calendario_base.empty? %>
      <div class="px-6 py-12 text-center text-stone-500">
        Nenhuma entrada no calendário base. <%= link_to "Cadastrar a primeira", new_admin_calendario_base_path, class: "text-slate-600 hover:text-slate-800" %>
      </div>
    <% end %>
  </div>
</div>
