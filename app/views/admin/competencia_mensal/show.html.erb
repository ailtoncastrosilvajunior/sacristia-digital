<div class="space-y-4 sm:space-y-6" data-controller="modal drawer">
  <% filtros = params.permit(:tipo_servico_id, :sacerdote_id, :ministro_id, :dia_semana, :vista, :aba, :vista_calendario, :data_ref).to_unsafe_h.compact_blank %>
  <div id="evento-modal-backdrop" data-modal-target="backdrop" class="fixed inset-0 z-50 hidden items-center justify-center bg-stone-900/50 p-4" data-action="click->modal#closeBackground">
    <div data-action="click->modal#stopPropagation" class="w-full max-w-4xl">
      <turbo-frame id="evento_modal" data-modal-target="frame" data-action="turbo:frame-load->modal#show turbo:frame-render->modal#show"></turbo-frame>
    </div>
  </div>

  <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
    <div>
      <%= link_to "← Competências", admin_competencia_mensal_index_path, class: "text-sm text-stone-500 hover:text-stone-700 mb-1 sm:mb-2 block" %>
      <div class="flex flex-wrap items-center gap-2 sm:gap-3">
        <h1 class="text-xl sm:text-2xl font-semibold text-stone-800"><%= @competencia.label %></h1>
        <span class="inline-flex px-2 py-1 text-xs font-medium rounded-full border <%= @competencia.escala_gerada? ? 'bg-emerald-100 text-emerald-800 border-emerald-300' : 'bg-amber-100 text-amber-800 border-amber-300' %>">
          Escala <%= @competencia.escala_gerada? ? "gerada" : "pendente" %>
        </span>
        <span class="inline-flex px-2 py-1 text-xs font-medium rounded-full border <%= @competencia.escala_liberada? ? 'bg-sky-100 text-sky-800 border-sky-300' : 'bg-stone-100 text-stone-600 border-stone-300' %>" title="<%= @competencia.escala_liberada? ? 'Ministros podem visualizar a escala' : 'Apenas admin e coordenadores podem visualizar' %>">
          <%= @competencia.escala_liberada? ? "Liberada" : "Restrita" %>
        </span>
      </div>
    </div>
    <div class="flex flex-wrap gap-2">
      <%= button_to "Gerar escala", gerar_escala_admin_competencia_mensal_path(@competencia), method: :post,
            data: @competencia.escala_gerada? ? { turbo_confirm: "Isso substituirá a escala atual. Continuar?" } : {},
            class: "px-3 py-2 sm:px-4 text-sm font-medium rounded-lg transition-colors bg-slate-600 hover:bg-slate-700 text-white" %>
      <%= link_to edit_admin_competencia_mensal_path(@competencia), class: "inline-flex items-center gap-1.5 sm:gap-2 px-3 py-2 sm:px-4 text-sm font-medium rounded-lg border border-sky-300 bg-sky-50 text-sky-700 hover:bg-sky-100 hover:border-sky-400 transition-colors" do %>
        <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
        Editar
      <% end %>
      <%= button_to "Excluir", admin_competencia_mensal_path(@competencia), method: :delete, data: { turbo_confirm: "Tem certeza? Isso excluirá todos os eventos." },
          class: "px-3 py-2 sm:px-4 text-sm font-medium rounded-lg border border-red-300 text-red-600 hover:bg-red-50 transition-colors" %>
    </div>
  </div>

  <div class="bg-white rounded-xl border border-stone-200 shadow-sm p-4 sm:p-6">
    <div>
      <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between mb-3">
        <div class="flex flex-wrap items-center gap-2">
          <span class="text-sm font-medium text-stone-700"><%= @eventos.count %> <%= @eventos.count == 1 ? 'evento' : 'eventos' %></span>
          <div class="flex rounded-lg border border-stone-200 overflow-hidden">
            <%= link_to admin_competencia_mensal_path(@competencia, filtros.merge(aba: "calendario")), class: "inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium transition-colors #{@aba == 'calendario' ? 'bg-slate-600 text-white' : 'bg-white text-stone-600 hover:bg-stone-50'}" do %>
              <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
              Calendário
            <% end %>
            <%= link_to admin_competencia_mensal_path(@competencia, filtros.merge(aba: "lista")), class: "inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium transition-colors #{@aba == 'lista' ? 'bg-slate-600 text-white' : 'bg-white text-stone-600 hover:bg-stone-50'}" do %>
              <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16"/></svg>
              Lista
            <% end %>
          </div>
        </div>
        <div class="flex items-center gap-2 shrink-0">
          <button type="button" data-action="click->drawer#toggle" class="inline-flex items-center gap-2 px-2.5 py-1.5 sm:px-3 text-xs sm:text-sm font-medium rounded-lg border border-stone-300 bg-white text-stone-700 hover:bg-stone-50 transition-colors">
            <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"/></svg>
            Filtros
            <% if filtros.except(:aba, :vista).any? %>
              <span class="inline-flex items-center justify-center min-w-[18px] h-[18px] px-1 text-xs font-medium rounded-full bg-slate-600 text-white"><%= filtros.except(:aba, :vista).size %></span>
            <% end %>
          </button>
          <%= link_to "Novo evento", new_admin_evento_escala_path(competencia_mensal_id: @competencia.id, **filtros), data: { turbo_frame: "evento_modal" }, class: "inline-flex items-center justify-center px-3 py-1.5 bg-emerald-600 hover:bg-emerald-700 text-white text-sm font-medium rounded-lg transition-colors" %>
        </div>
      </div>

    <% if @competencia.evento_escalas.any? %>

        <%# Drawer de filtros - lateral direito %>
        <div data-drawer-target="overlay" class="fixed inset-0 z-40 bg-stone-900/30 transition-opacity duration-300 invisible opacity-0 pointer-events-none" data-action="click->drawer#closeOverlay"></div>
        <div data-drawer-target="panel" class="fixed top-0 right-0 z-50 h-full w-full sm:w-96 max-w-sm bg-white shadow-xl transform transition-transform duration-300 ease-out translate-x-full border-l border-stone-200 flex flex-col">
          <div class="flex items-center justify-between px-4 py-4 border-b border-stone-200">
            <h4 class="text-base font-semibold text-stone-800">Filtros</h4>
            <button type="button" data-action="click->drawer#close" class="p-1.5 rounded-lg text-stone-400 hover:text-stone-600 hover:bg-stone-100 transition-colors" aria-label="Fechar">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>
          </div>
          <div class="flex-1 overflow-y-auto p-4">
            <%= form_with url: admin_competencia_mensal_path(@competencia), method: :get, local: true, html: { class: "space-y-4" } do |f| %>
              <%= hidden_field_tag :vista, params[:vista] %>
              <%= hidden_field_tag :aba, params[:aba] %>
              <%= hidden_field_tag :vista_calendario, params[:vista_calendario] %>
              <%= hidden_field_tag :data_ref, params[:data_ref] %>
              <div>
                <label for="filtro_dia_semana" class="block text-sm font-medium text-stone-700 mb-1">Dia da semana</label>
                <%= select_tag :dia_semana, options_for_select(I18n.t("date.abbr_day_names").each_with_index.map { |nome, i| [nome, i] }, params[:dia_semana]), { include_blank: "Todos", id: "filtro_dia_semana", class: "block w-full rounded-lg border-stone-300 text-sm shadow-sm focus:border-slate-500 focus:ring-slate-500" } %>
              </div>
              <div>
                <label for="filtro_tipo_servico" class="block text-sm font-medium text-stone-700 mb-1">Tipo de serviço</label>
                <%= select_tag :tipo_servico_id, options_from_collection_for_select(TipoServico.ativos, :id, :nome, params[:tipo_servico_id]), { include_blank: "Todos", id: "filtro_tipo_servico", class: "block w-full rounded-lg border-stone-300 text-sm shadow-sm focus:border-slate-500 focus:ring-slate-500" } %>
              </div>
              <div>
                <label for="filtro_sacerdote" class="block text-sm font-medium text-stone-700 mb-1">Sacerdote</label>
                <%= select_tag :sacerdote_id, options_from_collection_for_select(Sacerdote.ativos.ordenados_por_nome, :id, :nome, params[:sacerdote_id]), { include_blank: "Todos", id: "filtro_sacerdote", class: "block w-full rounded-lg border-stone-300 text-sm shadow-sm focus:border-slate-500 focus:ring-slate-500" } %>
              </div>
              <div>
                <label for="filtro_ministro" class="block text-sm font-medium text-stone-700 mb-1">Ministro</label>
                <%= select_tag :ministro_id, options_from_collection_for_select(Ministro.ativos.ordenados_por_nome, :id, :nome, params[:ministro_id]), { include_blank: "Todos", id: "filtro_ministro", class: "block w-full rounded-lg border-stone-300 text-sm shadow-sm focus:border-slate-500 focus:ring-slate-500" } %>
              </div>
              <div class="flex gap-2 pt-2">
                <%= submit_tag "Filtrar", class: "flex-1 px-4 py-2 bg-slate-600 hover:bg-slate-700 text-white text-sm font-medium rounded-lg transition-colors cursor-pointer" %>
                <%= link_to "Limpar", admin_competencia_mensal_path(@competencia, aba: params[:aba]), class: "px-4 py-2 bg-stone-200 hover:bg-stone-300 text-stone-700 text-sm font-medium rounded-lg transition-colors rounded-lg" %>
              </div>
            <% end %>
          </div>
        </div>

        <% if @aba == "calendario" %>
        <% eventos_por_dia = @eventos.group_by(&:data) %>
        <div class="flex flex-wrap items-center gap-2 sm:gap-3 mb-3 sm:mb-4">
          <div class="flex rounded-lg border border-stone-200 overflow-hidden">
            <%= link_to admin_competencia_mensal_path(@competencia, filtros.merge(vista_calendario: "mes", aba: "calendario").except(:data_ref)), class: "inline-flex items-center gap-1 px-2.5 py-1.5 sm:px-3 text-xs font-medium transition-colors #{@vista_calendario == 'mes' ? 'bg-slate-600 text-white' : 'bg-white text-stone-600 hover:bg-stone-50'}" do %>
              Mês
            <% end %>
            <%= link_to admin_competencia_mensal_path(@competencia, filtros.merge(vista_calendario: "semana", aba: "calendario", data_ref: @domingo_semana)), class: "inline-flex items-center gap-1 px-2.5 py-1.5 sm:px-3 text-xs font-medium transition-colors #{@vista_calendario == 'semana' ? 'bg-slate-600 text-white' : 'bg-white text-stone-600 hover:bg-stone-50'}" do %>
              Semana
            <% end %>
            <%= link_to admin_competencia_mensal_path(@competencia, filtros.merge(vista_calendario: "dia", aba: "calendario", data_ref: @data_ref)), class: "inline-flex items-center gap-1 px-2.5 py-1.5 sm:px-3 text-xs font-medium transition-colors #{@vista_calendario == 'dia' ? 'bg-slate-600 text-white' : 'bg-white text-stone-600 hover:bg-stone-50'}" do %>
              Dia
            <% end %>
          </div>
          <% if @vista_calendario != "mes" %>
            <div class="flex items-center gap-1">
              <% prev_ref = @vista_calendario == "semana" ? (@domingo_semana - 7) : (@data_ref - 1) %>
              <% next_ref = @vista_calendario == "semana" ? (@domingo_semana + 7) : (@data_ref + 1) %>
              <%= link_to admin_competencia_mensal_path(@competencia, filtros.merge(vista_calendario: @vista_calendario, data_ref: prev_ref, aba: "calendario")), class: "p-2 rounded-lg border border-stone-200 bg-white text-stone-600 hover:bg-stone-50 transition-colors" do %>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
              <% end %>
              <span class="px-2 text-sm font-medium text-stone-700 min-w-[120px] text-center">
                <% if @vista_calendario == "semana" %>
                  <%= l(@domingo_semana, format: :short) %> – <%= l(@domingo_semana + 6, format: :short) %>
                <% else %>
                  <%= l(@data_ref, format: :long) %>
                <% end %>
              </span>
              <%= link_to admin_competencia_mensal_path(@competencia, filtros.merge(vista_calendario: @vista_calendario, data_ref: next_ref, aba: "calendario")), class: "p-2 rounded-lg border border-stone-200 bg-white text-stone-600 hover:bg-stone-50 transition-colors" do %>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
              <% end %>
            </div>
          <% end %>
          <div class="flex flex-wrap gap-2">
            <% @eventos.map(&:tipo_servico).uniq(&:id).sort_by(&:nome).each do |ts| %>
              <span class="inline-flex items-center gap-1.5 text-xs">
                <span class="w-3 h-3 rounded border" style="background-color: <%= ts.cor_etiqueta %>33; border-color: <%= ts.cor_etiqueta %>;"></span>
                <%= ts.nome %>
              </span>
            <% end %>
          </div>
        </div>

        <div class="mb-6 sm:mb-8 overflow-x-auto -mx-4 sm:mx-0 px-4 sm:px-0">
          <% inicio = @competencia.periodo %>
          <% fim = @competencia.periodo_fim %>
          <% if @vista_calendario == "mes" %>
          <% domingo_primeira_semana = inicio - inicio.wday %>
          <div class="min-w-[320px] sm:min-w-[500px] lg:min-w-[700px] rounded-lg border border-stone-200 overflow-hidden">
            <div class="grid grid-cols-7 bg-stone-100 border-b border-stone-200">
              <% %w[Dom Seg Ter Qua Qui Sex Sáb].each do |dia| %>
                <div class="px-1 sm:px-2 py-1.5 sm:py-2 text-center text-[10px] sm:text-xs font-semibold text-stone-600"><%= dia %></div>
              <% end %>
            </div>
            <div class="grid grid-cols-7 bg-white">
              <% 42.times do |i| %>
                <% data = domingo_primeira_semana + i %>
                <% no_mes = (inicio..fim).cover?(data) %>
                <div class="min-h-[70px] sm:min-h-[85px] lg:min-h-[100px] p-1.5 sm:p-2 border-b border-r border-stone-100 <%= data == Date.current ? 'bg-sky-50/50 ring-1 ring-sky-300' : '' %> <%= no_mes ? '' : 'bg-stone-50/50' %>">
                  <div class="text-[10px] sm:text-xs font-medium mb-0.5 sm:mb-1 <%= no_mes ? 'text-stone-700' : 'text-stone-400' %>"><%= data.day %></div>
                  <% if no_mes %>
                    <% (eventos_por_dia[data] || []).sort_by(&:horario).each do |ev| %>
                      <% cor = ev.tipo_servico.cor_etiqueta.presence || "#64748b" %>
                      <%= link_to admin_evento_escala_path(ev, filtros), data: { turbo_frame: "evento_modal" }, title: "Ver detalhes", class: "block text-[10px] sm:text-xs py-0.5 sm:py-1 px-1.5 sm:px-2 rounded mb-0.5 truncate border transition-colors hover:opacity-90 cursor-pointer", style: "background-color: #{cor}26; border-color: #{cor}; color: #1f2937;" do %>
                        <%= l(ev.horario, format: :time) %> <%= ev.tipo_servico.nome %><%= " - #{ev.sacerdote.nome}" if ev.tipo_servico.nome.downcase.include?("missa") && ev.sacerdote.present? %>
                      <% end %>
                    <% end %>
                  <% end %>
                </div>
              <% end %>
            </div>
          </div>
          <% elsif @vista_calendario == "semana" %>
          <div class="min-w-[320px] sm:min-w-[500px] lg:min-w-[700px] rounded-lg border border-stone-200 overflow-hidden">
            <div class="grid grid-cols-7 bg-stone-100 border-b border-stone-200">
              <% 7.times do |i| %>
                <% d = @domingo_semana + i %>
                <div class="px-1 sm:px-2 py-1.5 sm:py-2 text-center">
                  <div class="text-[10px] sm:text-xs font-semibold text-stone-600"><%= I18n.t("date.abbr_day_names")[d.wday] %></div>
                  <div class="text-xs font-medium text-stone-700"><%= d.day %></div>
                </div>
              <% end %>
            </div>
            <div class="grid grid-cols-7 bg-white">
              <% 7.times do |i| %>
                <% data = @domingo_semana + i %>
                <% no_mes = (inicio..fim).cover?(data) %>
                <div class="min-h-[120px] sm:min-h-[160px] p-1.5 sm:p-2 border-b border-r border-stone-100 <%= data == Date.current ? 'bg-sky-50/50 ring-1 ring-sky-300' : '' %> <%= no_mes ? '' : 'bg-stone-50/50' %>">
                  <% if no_mes %>
                    <% (eventos_por_dia[data] || []).sort_by(&:horario).each do |ev| %>
                      <% cor = ev.tipo_servico.cor_etiqueta.presence || "#64748b" %>
                      <%= link_to admin_evento_escala_path(ev, filtros), data: { turbo_frame: "evento_modal" }, title: "Ver detalhes", class: "block text-[10px] sm:text-xs py-0.5 sm:py-1 px-1.5 sm:px-2 rounded mb-0.5 truncate border transition-colors hover:opacity-90 cursor-pointer", style: "background-color: #{cor}26; border-color: #{cor}; color: #1f2937;" do %>
                        <%= l(ev.horario, format: :time) %> <%= ev.tipo_servico.nome %><%= " - #{ev.sacerdote.nome}" if ev.tipo_servico.nome.downcase.include?("missa") && ev.sacerdote.present? %>
                      <% end %>
                    <% end %>
                  <% end %>
                </div>
              <% end %>
            </div>
          </div>
          <% else %>
          <% eventos_do_dia = (eventos_por_dia[@data_ref] || []).sort_by(&:horario) %>
          <div class="max-w-2xl rounded-lg border border-stone-200 overflow-hidden">
            <div class="bg-stone-100 px-4 py-3 border-b border-stone-200">
              <h3 class="text-base font-semibold text-stone-800"><%= l(@data_ref, format: :long) %></h3>
              <p class="text-sm text-stone-500"><%= I18n.t("date.day_names")[@data_ref.wday] %></p>
            </div>
            <div class="bg-white divide-y divide-stone-100">
              <% if eventos_do_dia.any? %>
                <% eventos_do_dia.each do |ev| %>
                  <% cor = ev.tipo_servico.cor_etiqueta.presence || "#64748b" %>
                  <%= link_to admin_evento_escala_path(ev, filtros), data: { turbo_frame: "evento_modal" }, class: "flex items-center gap-4 px-4 py-3 hover:bg-stone-50 transition-colors group" do %>
                    <div class="flex-shrink-0 w-16 text-sm font-medium text-stone-600"><%= l(ev.horario, format: :time) %></div>
                    <div class="flex-1 min-w-0">
                      <div class="font-medium text-stone-800"><%= ev.tipo_servico.nome %></div>
                      <div class="text-sm text-stone-500"><%= ev.sacerdote&.nome || "—" %> · <%= render "admin/evento_escala/ministros_com_coordenador", evento: ev %></div>
                    </div>
                    <div class="h-3 w-1 rounded shrink-0" style="background-color: <%= cor %>"></div>
                  <% end %>
                <% end %>
              <% else %>
                <div class="px-4 py-8 text-center text-stone-500 text-sm">Nenhum evento neste dia</div>
              <% end %>
            </div>
          </div>
          <% end %>
        </div>
        <% end %>

        <% if @aba == "lista" %>
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2 mb-3">
          <h4 class="text-sm font-medium text-stone-700">Lista de eventos</h4>
          <div class="flex rounded-lg border border-stone-200 overflow-hidden shrink-0">
            <%= link_to admin_competencia_mensal_path(@competencia, filtros.merge(vista: "tabela", aba: "lista")), class: "px-3 py-1.5 text-xs font-medium transition-colors #{@vista_lista == 'tabela' ? 'bg-slate-600 text-white' : 'bg-white text-stone-600 hover:bg-stone-50'}" do %>
              <svg class="w-4 h-4 inline-block align-middle" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16"/></svg>
              Tabela
            <% end %>
            <%= link_to admin_competencia_mensal_path(@competencia, filtros.merge(vista: "card", aba: "lista")), class: "px-3 py-1.5 text-xs font-medium transition-colors #{@vista_lista == 'card' ? 'bg-slate-600 text-white' : 'bg-white text-stone-600 hover:bg-stone-50'}" do %>
              <svg class="w-4 h-4 inline-block align-middle" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/></svg>
              Card
            <% end %>
          </div>
        </div>

        <div class="max-h-[60vh] sm:max-h-[450px] lg:max-h-[500px] overflow-y-auto rounded-lg border border-stone-200">
        <% if @vista_lista == "card" %>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3 sm:gap-4 p-3 sm:p-4">
          <% @eventos.por_data.each do |ev| %>
            <% ts = ev.tipo_servico %>
            <% cor = ts.cor_etiqueta.presence || "#64748b" %>
            <div class="rounded-xl border border-stone-200 overflow-hidden bg-white hover:shadow-md transition-shadow">
              <div class="h-1.5" style="background-color: <%= cor %>"></div>
              <div class="p-3 sm:p-4">
                <div class="flex items-start justify-between gap-2 mb-2">
                  <div>
                    <p class="text-xs font-medium text-stone-500"><%= I18n.t("date.abbr_day_names")[ev.data.wday] %> • <%= l(ev.data) %></p>
                    <p class="text-sm font-semibold text-stone-800"><%= l(ev.horario, format: :time) %> - <%= ts.nome %></p>
                  </div>
                  <div class="flex flex-col items-end gap-1.5 shrink-0">
                    <span class="inline-flex px-2 py-0.5 text-xs font-medium rounded-full border
                      <%= case ev.status
                          when 'confirmado' then 'bg-emerald-100 text-emerald-800 border-emerald-300'
                          when 'concluido' then 'bg-sky-100 text-sky-800 border-sky-300'
                          when 'cancelado' then 'bg-red-100 text-red-800 border-red-300'
                          else 'bg-amber-100 text-amber-800 border-amber-300'
                          end %>">
                      <%= I18n.t("activerecord.attributes.evento_escala.status_values.#{ev.status}", default: ev.status.humanize) %>
                    </span>
                    <div class="flex gap-1">
                      <%= link_to admin_evento_escala_path(ev, filtros), data: { turbo_frame: "evento_modal" }, class: "inline-flex items-center gap-1 px-2 py-0.5 text-xs font-medium rounded-lg border border-sky-200 bg-sky-50 text-sky-700 hover:bg-sky-100" do %>
                        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                        Ver
                      <% end %>
                      <%= link_to escalar_ministros_admin_evento_escala_path(ev), data: { turbo_frame: "evento_modal" }, class: "inline-flex items-center gap-1 px-2 py-0.5 text-xs font-medium rounded-lg border border-sky-200 bg-sky-50 text-sky-700 hover:bg-sky-100", title: "Escalar" do %>
                        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                        Escalar
                      <% end %>
                      <%= link_to edit_admin_evento_escala_path(ev, filtros), data: { turbo_frame: "evento_modal" }, class: "inline-flex items-center gap-1 px-2 py-0.5 text-xs font-medium rounded-lg border border-sky-200 bg-sky-50 text-sky-700 hover:bg-sky-100" do %>
                        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                        Editar
                      <% end %>
                      <%= button_to admin_evento_escala_path(ev, filtros), method: :delete, data: { turbo_confirm: "Excluir este evento?" }, class: "inline-flex items-center gap-1 px-2 py-0.5 text-xs font-medium rounded-lg border border-red-200 bg-red-50 text-red-700 hover:bg-red-100", title: "Excluir" do %>
                        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                        Excluir
                      <% end %>
                    </div>
                  </div>
                </div>
                <p class="text-sm text-stone-600 mb-0.5"><%= ev.sacerdote&.nome || "—" %></p>
                <p class="text-xs text-stone-500"><%= render "admin/evento_escala/ministros_com_coordenador", evento: ev %></p>
              </div>
            </div>
          <% end %>
        </div>
        <% else %>
        <div class="overflow-x-auto -mx-3 sm:mx-0">
          <table class="min-w-[580px] sm:min-w-full divide-y divide-stone-200">
            <thead class="bg-stone-50 sticky top-0 z-10">
              <tr>
                <th class="px-2 sm:px-4 py-1.5 sm:py-2 text-left text-[10px] sm:text-xs font-medium text-stone-500 uppercase">Dia</th>
                <th class="px-2 sm:px-4 py-1.5 sm:py-2 text-left text-[10px] sm:text-xs font-medium text-stone-500 uppercase">Data</th>
                <th class="px-2 sm:px-4 py-1.5 sm:py-2 text-left text-[10px] sm:text-xs font-medium text-stone-500 uppercase">Horário</th>
                <th class="px-2 sm:px-4 py-1.5 sm:py-2 text-left text-[10px] sm:text-xs font-medium text-stone-500 uppercase">Serviço</th>
                <th class="px-2 sm:px-4 py-1.5 sm:py-2 text-left text-[10px] sm:text-xs font-medium text-stone-500 uppercase">Sacerdote</th>
                <th class="px-2 sm:px-4 py-1.5 sm:py-2 text-left text-[10px] sm:text-xs font-medium text-stone-500 uppercase">Ministros</th>
                <th class="px-2 sm:px-4 py-1.5 sm:py-2 text-left text-[10px] sm:text-xs font-medium text-stone-500 uppercase">Status</th>
                <th class="px-2 sm:px-4 py-1.5 sm:py-2 text-right text-[10px] sm:text-xs font-medium text-stone-500 uppercase">Ações</th>
              </tr>
            </thead>
            <tbody class="bg-white divide-y divide-stone-200">
              <% @eventos.por_data.each do |ev| %>
                <tr class="hover:bg-stone-50">
                  <td class="px-2 sm:px-4 py-1.5 sm:py-2 text-xs sm:text-sm text-stone-600"><%= I18n.t("date.abbr_day_names")[ev.data.wday] %></td>
                  <td class="px-2 sm:px-4 py-1.5 sm:py-2 text-xs sm:text-sm text-stone-800 whitespace-nowrap"><%= l(ev.data) %></td>
                  <td class="px-2 sm:px-4 py-1.5 sm:py-2 text-xs sm:text-sm text-stone-600"><%= l(ev.horario, format: :time) %></td>
                  <td class="px-2 sm:px-4 py-1.5 sm:py-2 text-xs sm:text-sm">
                    <% ts = ev.tipo_servico %>
                    <span class="inline-flex px-2 py-0.5 text-xs font-medium rounded border" style="background-color: <%= ts.cor_etiqueta %>26; border-color: <%= ts.cor_etiqueta %>; color: #1f2937;"><%= ts.nome %></span>
                  </td>
                  <td class="px-2 sm:px-4 py-1.5 sm:py-2 text-xs sm:text-sm text-stone-600"><%= ev.sacerdote&.nome || "—" %></td>
                  <td class="px-2 sm:px-4 py-1.5 sm:py-2 text-xs sm:text-sm text-stone-600 max-w-[100px] sm:max-w-none" title="<%= ev.ministros_nomes_com_coordenador %>"><%= render "admin/evento_escala/ministros_com_coordenador", evento: ev %></td>
                  <td class="px-2 sm:px-4 py-1.5 sm:py-2">
                    <span class="inline-flex px-2 py-0.5 text-xs font-medium rounded-full border
                      <%= case ev.status
                          when 'confirmado' then 'bg-emerald-100 text-emerald-800 border-emerald-300'
                          when 'concluido' then 'bg-sky-100 text-sky-800 border-sky-300'
                          when 'cancelado' then 'bg-red-100 text-red-800 border-red-300'
                          else 'bg-amber-100 text-amber-800 border-amber-300'
                          end %>">
                      <%= I18n.t("activerecord.attributes.evento_escala.status_values.#{ev.status}", default: ev.status.humanize) %>
                    </span>
                  </td>
                  <td class="px-2 sm:px-4 py-1.5 sm:py-2 text-right">
                    <div class="flex items-center justify-end gap-1">
                      <%= link_to admin_evento_escala_path(ev, filtros), data: { turbo_frame: "evento_modal" }, title: "Ver detalhes", class: "inline-flex items-center gap-1 sm:gap-1.5 px-1.5 sm:px-2.5 py-1 text-[10px] sm:text-xs font-medium rounded-lg border border-sky-200 bg-sky-50 text-sky-700 hover:bg-sky-100 hover:border-sky-300 transition-colors" do %>
                        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                        Ver
                      <% end %>
                      <%= link_to escalar_ministros_admin_evento_escala_path(ev), data: { turbo_frame: "evento_modal" }, title: "Escalar", class: "inline-flex items-center gap-1 sm:gap-1.5 px-1.5 sm:px-2.5 py-1 text-[10px] sm:text-xs font-medium rounded-lg border border-sky-200 bg-sky-50 text-sky-700 hover:bg-sky-100 hover:border-sky-300 transition-colors" do %>
                        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                        Escalar
                      <% end %>
                      <%= link_to edit_admin_evento_escala_path(ev, filtros), data: { turbo_frame: "evento_modal" }, title: "Editar", class: "inline-flex items-center gap-1 sm:gap-1.5 px-1.5 sm:px-2.5 py-1 text-[10px] sm:text-xs font-medium rounded-lg border border-sky-200 bg-sky-50 text-sky-700 hover:bg-sky-100 hover:border-sky-300 transition-colors" do %>
                        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                        Editar
                      <% end %>
                      <%= button_to admin_evento_escala_path(ev, filtros), method: :delete, data: { turbo_confirm: "Excluir este evento?" }, title: "Excluir", class: "inline-flex items-center gap-1 sm:gap-1.5 px-1.5 sm:px-2.5 py-1 text-[10px] sm:text-xs font-medium rounded-lg border border-red-200 bg-red-50 text-red-700 hover:bg-red-100 hover:border-red-300 transition-colors" do %>
                        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                        Excluir
                      <% end %>
                    </div>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
        <% end %>
        </div>
        <% end %>
      </div>
    <% else %>
      <p class="text-stone-500 text-sm py-4">Nenhum evento na escala. Clique em "Novo evento" para adicionar ou "Gerar escala" para criar a partir do calendário base.</p>
    <% end %>
    </div>
  </div>
</div>
