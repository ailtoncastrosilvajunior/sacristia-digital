                  <span class="relative text-2xl font-extrabold tabular-nums leading-none sm:text-center drop-shadow-sm"><%= ev.data.day %></span>
                  <span class="relative text-xs text-white/85 tabular-nums font-medium sm:text-center"><%= l(ev.data, format: :short) %></span>
                  <span class="relative text-sm font-bold tabular-nums w-full text-center sm:w-auto sm:mt-0.5 border-t border-white/25 sm:border-0 pt-2 sm:pt-0 mt-0.5 sm:mt-0 text-white drop-shadow-sm"><%= l(ev.horario, format: :time) %></span>
