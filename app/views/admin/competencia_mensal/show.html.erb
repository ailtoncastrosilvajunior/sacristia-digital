                <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16"/></svg>
                Tabela
              <% end %>
              <%= link_to admin_competencia_mensal_path(@competencia, filtros.merge(vista: "card", aba: "lista")), class: "inline-flex items-center gap-1.5 px-3.5 py-2.5 text-xs font-semibold transition-all #{@vista_lista == 'card' ? 'bg-gradient-to-r from-sky-600 to-indigo-600 text-white shadow-inner' : 'text-stone-600 hover:bg-sky-50/80'}" do %>
                <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/></svg>
                Cartões
              <% end %>
            </div>
          </div>
        </div>

        <div class="max-h-[60vh] sm:max-h-[min(70vh,520px)] lg:max-h-[560px] overflow-y-auto rounded-2xl border border-slate-200/80 bg-gradient-to-b from-slate-50/90 to-white shadow-xl shadow-slate-900/10 ring-1 ring-slate-200/50">
        <% if @vista_lista == "card" %>
        <% lista_acoes_cartao = "inline-flex w-full min-h-[2.75rem] items-center justify-center gap-1.5 px-2 rounded-xl text-xs font-semibold text-center" %>
