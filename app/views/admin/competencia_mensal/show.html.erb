              <div class="group flex flex-col sm:flex-row sm:items-stretch gap-0 rounded-2xl border border-slate-200/90 bg-white overflow-hidden shadow-md shadow-slate-900/6 ring-1 ring-slate-100/80 transition-all duration-300 hover:-translate-y-0.5 hover:border-sky-300/50 hover:shadow-xl hover:shadow-sky-500/15 hover:ring-sky-200/40">
