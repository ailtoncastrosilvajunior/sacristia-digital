              <tr>
                <th scope="col" class="px-3 sm:px-4 py-3.5 text-[10px] sm:text-xs font-bold text-white/95 uppercase tracking-widest">Dia</th>
                <th scope="col" class="px-3 sm:px-4 py-3.5 text-[10px] sm:text-xs font-bold text-white/95 uppercase tracking-widest">Data</th>
                <th scope="col" class="px-3 sm:px-4 py-3.5 text-[10px] sm:text-xs font-bold text-white/95 uppercase tracking-widest">Horário</th>
                <th scope="col" class="px-3 sm:px-4 py-3.5 text-[10px] sm:text-xs font-bold text-white/95 uppercase tracking-widest">Serviço</th>
                <th scope="col" class="px-3 sm:px-4 py-3.5 text-[10px] sm:text-xs font-bold text-white/95 uppercase tracking-widest">Sacerdote</th>
                <th scope="col" class="px-3 sm:px-4 py-3.5 text-[10px] sm:text-xs font-bold text-white/95 uppercase tracking-widest">Ministros</th>
                <th scope="col" class="px-3 sm:px-4 py-3.5 text-[10px] sm:text-xs font-bold text-white/95 uppercase tracking-widest">Status</th>
                <th scope="col" class="px-3 sm:px-4 py-3.5 text-right text-[10px] sm:text-xs font-bold text-white/95 uppercase tracking-widest">Ações</th>
              </tr>
            </thead>
