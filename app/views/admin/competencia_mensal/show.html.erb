                        <%= I18n.t("activerecord.attributes.evento_escala.status_values.confirmado", default: "Confirmado") %>
                      </span>
                    <% when "concluido" %>
                      <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-[10px] font-bold uppercase tracking-wide bg-sky-100 text-sky-800 ring-1 ring-sky-200/80">
                        <span class="h-1.5 w-1.5 rounded-full bg-sky-500 shrink-0"></span>
                        <%= I18n.t("activerecord.attributes.evento_escala.status_values.concluido", default: "Concluído") %>
                      </span>
                    <% when "cancelado" %>
                      <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-[10px] font-bold uppercase tracking-wide bg-red-100 text-red-800 ring-1 ring-red-200/80">
                        <span class="h-1.5 w-1.5 rounded-full bg-red-500 shrink-0"></span>
                        <%= I18n.t("activerecord.attributes.evento_escala.status_values.cancelado", default: "Cancelado") %>
                      </span>
                    <% else %>
                      <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-[10px] font-bold uppercase tracking-wide bg-amber-50 text-amber-800 ring-1 ring-amber-200/70">
                        <span class="h-1.5 w-1.5 rounded-full bg-amber-400 shrink-0"></span>
                        <%= I18n.t("activerecord.attributes.evento_escala.status_values.#{ev.status}", default: ev.status.humanize) %>
                      </span>
                    <% end %>
                  </td>
                  <td class="px-3 sm:px-4 py-3 align-middle">
                    <div class="grid grid-cols-2 grid-rows-2 gap-1.5 w-full max-w-[11.5rem] ml-auto">
                      <%= link_to admin_evento_escala_path(ev, filtros), data: { turbo_frame: "evento_modal" }, title: "Ver detalhes", class: "#{lista_acoes_tabela} border border-sky-200/90 bg-white text-sky-800 hover:bg-sky-50 transition-colors" do %>
                        <svg class="w-3 h-3 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                        Ver
                      <% end %>
                      <%= link_to escalar_ministros_admin_evento_escala_path(ev), data: { turbo_frame: "evento_modal" }, title: "Escalar", class: "#{lista_acoes_tabela} bg-sky-600 text-white hover:bg-sky-700 transition-colors shadow-sm border border-sky-700/20" do %>
                        <svg class="w-3 h-3 shrink-0 opacity-90" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
                        Escalar
                      <% end %>
                      <%= link_to edit_admin_evento_escala_path(ev, filtros), data: { turbo_frame: "evento_modal" }, title: "Editar", class: "#{lista_acoes_tabela} border border-stone-200 bg-white text-stone-700 hover:bg-stone-50 transition-colors" do %>
                        <svg class="w-3 h-3 shrink-0 text-stone-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                        Editar
                      <% end %>
                      <%= button_to admin_evento_escala_path(ev, filtros), method: :delete, data: { turbo_confirm: "Excluir este evento?" }, form: { class: "contents" }, title: "Excluir", class: "#{lista_acoes_tabela} border border-red-200 bg-red-50 text-red-700 hover:bg-red-100 transition-colors" do %>
                        <svg class="w-3 h-3 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                        Excluir
                      <% end %>
                    </div>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
        <% end %>
        </div>
        <% end %>
    <% else %>
      <p class="text-stone-500 text-sm py-4">Nenhum evento na escala. Clique em "Novo evento" para adicionar ou "Gerar escala" para criar a partir do calendário base.</p>
    <% end %>
    </div>
  </div>
</div>
