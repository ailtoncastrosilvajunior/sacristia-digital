<div class="space-y-6">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-semibold text-stone-800">Competências Mensais</h1>
      <p class="text-stone-500 mt-1">Gerencie as competências e gere escalas</p>
    </div>
    <%= link_to "Nova competência", new_admin_competencia_mensal_path,
        class: "px-4 py-2 bg-slate-600 hover:bg-slate-700 text-white font-medium rounded-lg transition-colors" %>
  </div>

  <%= form_with url: admin_competencia_mensal_index_path, method: :get, local: true, class: "flex flex-wrap items-end gap-4 p-4 bg-stone-50 rounded-xl border border-stone-200" do |f| %>
    <div>
      <label for="filtro_ano" class="block text-sm font-medium text-stone-700 mb-1">Ano</label>
      <%= select_tag :ano, options_for_select((2020..Date.current.year).to_a.reverse, params[:ano]), { include_blank: "Todos", id: "filtro_ano", class: "block w-28 rounded-lg border-stone-300 shadow-sm focus:border-slate-500 focus:ring-slate-500" } %>
    </div>
    <div>
      <label for="filtro_mes" class="block text-sm font-medium text-stone-700 mb-1">Mês</label>
      <%= select_tag :mes, options_for_select(I18n.t("date.abbr_month_names").drop(1).each_with_index.map { |n, i| [n, i + 1] }, params[:mes]), { include_blank: "Todos", id: "filtro_mes", class: "block w-32 rounded-lg border-stone-300 shadow-sm focus:border-slate-500 focus:ring-slate-500" } %>
    </div>
    <div>
      <label for="filtro_escala" class="block text-sm font-medium text-stone-700 mb-1">Escala</label>
      <%= select_tag :escala_gerada, options_for_select([["Pendente", "false"], ["Gerada", "true"]], params[:escala_gerada]), { include_blank: "Todas", id: "filtro_escala", class: "block w-36 rounded-lg border-stone-300 shadow-sm focus:border-slate-500 focus:ring-slate-500" } %>
    </div>
    <div class="flex gap-2">
      <%= submit_tag "Filtrar", class: "px-4 py-2 bg-slate-600 hover:bg-slate-700 text-white text-sm font-medium rounded-lg transition-colors cursor-pointer" %>
      <%= link_to "Limpar", admin_competencia_mensal_index_path, class: "px-4 py-2 bg-stone-200 hover:bg-stone-300 text-stone-700 text-sm font-medium rounded-lg transition-colors" %>
    </div>
  <% end %>

  <div class="bg-white rounded-xl border border-stone-200 shadow-sm overflow-hidden">
    <table class="min-w-full divide-y divide-stone-200">
      <thead class="bg-stone-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-stone-500 uppercase tracking-wider">Competência</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-stone-500 uppercase tracking-wider">Escala</th>
          <th class="px-6 py-3 text-right text-xs font-medium text-stone-500 uppercase tracking-wider">Ações</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-stone-200">
        <% @competencias.each do |comp| %>
          <tr class="hover:bg-stone-50">
            <td class="px-6 py-4 whitespace-nowrap">
              <%= link_to comp.label, admin_competencia_mensal_path(comp), class: "text-slate-600 hover:text-slate-800 font-medium" %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap">
              <span class="inline-flex px-2 py-1 text-xs font-medium rounded-full <%= comp.escala_gerada? ? 'bg-emerald-100 text-emerald-800' : 'bg-amber-100 text-amber-800' %>">
                <%= comp.escala_gerada? ? "Gerada" : "Pendente" %>
              </span>
            </td>
            <td class="px-6 py-4 whitespace-nowrap">
              <div class="flex items-center justify-end gap-1">
                <%= link_to admin_competencia_mensal_path(comp), title: "Ver detalhes", class: "p-2 rounded-lg text-stone-400 hover:text-slate-600 hover:bg-stone-100 transition-colors" do %>
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                <% end %>
                <%= link_to edit_admin_competencia_mensal_path(comp), title: "Editar", class: "p-2 rounded-lg text-stone-400 hover:text-sky-600 hover:bg-sky-50 transition-colors" do %>
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                <% end %>
                <%= button_to admin_competencia_mensal_path(comp), method: :delete, data: { turbo_confirm: "Tem certeza? Isso excluirá todos os eventos da competência." }, form: { class: "inline" }, title: "Excluir", class: "p-2 rounded-lg text-stone-400 hover:text-red-600 hover:bg-red-50 transition-colors border-0 bg-transparent cursor-pointer" do %>
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                <% end %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>

    <% if @competencias.empty? %>
      <div class="px-6 py-12 text-center text-stone-500">
        Nenhuma competência cadastrada. <%= link_to "Cadastrar a primeira", new_admin_competencia_mensal_path, class: "text-slate-600 hover:text-slate-800" %>
      </div>
    <% end %>
  </div>

  <div class="flex justify-center">
    <%= paginate @competencias %>
  </div>
</div>
