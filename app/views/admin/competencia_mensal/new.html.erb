<div class="space-y-6">
  <div>
    <%= link_to "← Competências", admin_competencia_mensal_index_path, class: "text-sm text-stone-500 hover:text-stone-700 mb-2 block" %>
    <h1 class="text-2xl font-semibold text-stone-800">Nova competência</h1>
    <p class="text-stone-500 mt-1">Cadastre uma nova competência mensal</p>
  </div>

  <div class="bg-white rounded-xl border border-stone-200 shadow-sm p-6 max-w-2xl">
    <%= form_with model: @competencia, url: admin_competencia_mensal_index_path, scope: :competencia_mensal, local: true, html: { class: "space-y-5" } do |f| %>
      <% if @competencia.errors.any? %>
        <div class="rounded-lg bg-red-50 p-4 text-red-800 text-sm">
          <p class="font-medium mb-2"><%= pluralize(@competencia.errors.count, "erro") %> impediram o cadastro:</p>
          <ul class="list-disc list-inside">
            <% @competencia.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="grid grid-cols-2 gap-4">
        <div>
          <%= f.label :mes, "Mês", class: "block text-sm font-medium text-stone-700 mb-1" %>
          <%= f.select :mes, (1..12).map { |m| [I18n.l(Date.new(2000, m, 1), format: :month), m] }, { include_blank: "Selecione" },
              class: "w-full px-4 py-2.5 rounded-lg border border-stone-300 focus:ring-2 focus:ring-slate-500/20 focus:border-slate-500" %>
        </div>
        <div>
          <%= f.label :ano, "Ano", class: "block text-sm font-medium text-stone-700 mb-1" %>
          <%= f.number_field :ano, min: 2020, max: 2100, class: "w-full px-4 py-2.5 rounded-lg border border-stone-300 focus:ring-2 focus:ring-slate-500/20 focus:border-slate-500" %>
        </div>
      </div>

      <div class="flex gap-3 pt-4">
        <%= f.submit "Cadastrar", class: "px-4 py-2.5 bg-slate-600 hover:bg-slate-700 text-white font-medium rounded-lg transition-colors cursor-pointer" %>
        <%= link_to "Cancelar", admin_competencia_mensal_index_path, class: "px-4 py-2.5 border border-stone-300 text-stone-700 hover:bg-stone-50 font-medium rounded-lg transition-colors" %>
      </div>
    <% end %>
  </div>
</div>
