<%# Nossa Senhora — retrato no hero do admin (arquivo: nossa-senhora-admin.png). %>
<div class="relative shrink-0 overflow-hidden rounded-xl ring-2 ring-amber-200/35 shadow-lg shadow-black/45
            h-[12.5rem] w-[8rem] sm:h-[13.5rem] sm:w-[8.75rem]
            lg:h-[11rem] lg:w-[8.25rem] xl:h-[11.75rem] xl:w-[9rem]
            max-lg:mx-0 lg:mx-0 select-none bg-slate-950/30">
  <div class="pointer-events-none absolute inset-0 bg-gradient-to-b from-amber-200/15 via-transparent to-slate-950/50 z-[1]" aria-hidden="true"></div>
  <%= image_tag "nossa-senhora-admin.png",
        class: "relative z-0 h-full w-full object-cover object-[center_18%]",
        alt: "Nossa Senhora",
        loading: "eager",
        decoding: "async" %>
</div>
