<div class="space-y-6">
  <div>
    <h1 class="text-2xl font-semibold text-stone-800">Dashboard</h1>
    <p class="text-stone-500 mt-1">Bem-vindo ao painel administrativo da Sacristia Digital</p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
    <div class="bg-white rounded-xl border border-stone-200 p-6 shadow-sm">
      <p class="text-sm text-stone-500">Ministros ativos</p>
      <p class="text-2xl font-semibold text-stone-800 mt-1"><%= Ministro.ativos.count %></p>
    </div>
    <div class="bg-white rounded-xl border border-stone-200 p-6 shadow-sm">
      <p class="text-sm text-stone-500">Sacerdotes ativos</p>
      <p class="text-2xl font-semibold text-stone-800 mt-1"><%= Sacerdote.ativos.count %></p>
    </div>
    <div class="bg-white rounded-xl border border-stone-200 p-6 shadow-sm">
      <p class="text-sm text-stone-500">Tipos de serviço</p>
      <p class="text-2xl font-semibold text-stone-800 mt-1"><%= TipoServico.ativos.count %></p>
    </div>
  </div>
</div>
