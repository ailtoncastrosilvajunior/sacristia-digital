<% content_for :title, "Usuários — Admin" %>

<div class="space-y-6">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-semibold text-stone-800">Usuários</h1>
      <p class="text-stone-500 mt-1">Cadastro e perfis de acesso ao sistema</p>
    </div>
    <%= link_to new_admin_user_path,
        class: "px-4 py-2 bg-slate-600 hover:bg-slate-700 text-white font-medium rounded-lg transition-colors" do %>
      Novo usuário
    <% end %>
  </div>

  <div class="bg-white rounded-xl border border-stone-200 shadow-sm overflow-hidden">
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-stone-200">
        <thead class="bg-stone-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-medium text-stone-500 uppercase tracking-wider">E-mail</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-stone-500 uppercase tracking-wider">Nome</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-stone-500 uppercase tracking-wider">Perfis</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-stone-500 uppercase tracking-wider">Ações</th>
          </tr>
        </thead>
        <tbody class="bg-white divide-y divide-stone-200">
          <% @users.each do |user| %>
            <tr class="hover:bg-stone-50">
              <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-stone-900"><%= user.email %></td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-stone-600"><%= user.nome.presence || "—" %></td>
              <td class="px-6 py-4">
                <div class="flex flex-wrap gap-1">
                  <% user.perfis.each do |perfil| %>
                    <% cor = case perfil
                              when "admin" then "bg-violet-100 text-violet-900 ring-violet-200"
                              when "coordenador" then "bg-amber-100 text-amber-900 ring-amber-200"
                              when "ministro" then "bg-sky-100 text-sky-900 ring-sky-200"
                              when "sacerdote" then "bg-emerald-100 text-emerald-900 ring-emerald-200"
                              else "bg-stone-100 text-stone-700 ring-stone-200"
                              end %>
                    <span class="inline-flex px-2 py-0.5 text-[11px] font-bold uppercase tracking-wide rounded-lg ring-1 <%= cor %>">
                      <%= t("user.perfis.#{perfil}", default: perfil.humanize) %>
                    </span>
                  <% end %>
                </div>
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <div class="flex items-center justify-end gap-1">
                  <%= link_to admin_user_path(user), title: "Ver detalhes", class: "p-2 rounded-lg text-stone-400 hover:text-slate-600 hover:bg-stone-100 transition-colors" do %>
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
                  <% end %>
                  <%= link_to edit_admin_user_path(user), title: "Editar", class: "p-2 rounded-lg text-stone-400 hover:text-sky-600 hover:bg-sky-50 transition-colors" do %>
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                  <% end %>
                  <% unless user == current_user %>
                    <%= button_to admin_user_path(user), method: :delete, data: { turbo_confirm: "Tem certeza que deseja excluir este usuário?" }, form: { class: "inline" }, title: "Excluir", class: "p-2 rounded-lg text-stone-400 hover:text-red-600 hover:bg-red-50 transition-colors border-0 bg-transparent cursor-pointer" do %>
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                    <% end %>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <% if @users.empty? %>
      <div class="px-6 py-12 text-center text-stone-500">
        Nenhum usuário cadastrado. <%= link_to "Cadastrar o primeiro", new_admin_user_path, class: "text-slate-600 hover:text-slate-800 font-medium" %>
      </div>
    <% end %>
  </div>

  <div class="flex justify-center pt-4 border-t border-stone-100">
    <%= paginate @users %>
  </div>
</div>
