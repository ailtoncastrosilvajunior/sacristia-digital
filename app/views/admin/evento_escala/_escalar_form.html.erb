<% standalone = local_assigns.fetch(:standalone, false) %>
<% return_params = local_assigns.fetch(:return_params, {}) %>
<% competencia_lista = admin_competencia_mensal_path(evento.competencia_mensal, aba: "lista") %>
<% ministros_json = (ministros_disponiveis + ministros_escalados.map(&:ministro)).uniq.map { |m| { id: m.id, nome: m.nome } }.to_json %>
<% sacerdotes_json = (sacerdotes || []).map { |s| { id: s.id, nome: s.nome } }.to_json %>
<div class="space-y-8" data-controller="escalar-ministros" data-escalar-ministros-ministros-data-value="<%= h ministros_json %>" data-escalar-ministros-sacerdotes-data-value="<%= h sacerdotes_json %>">
  <%= form_with url: update_escalar_ministros_admin_evento_escala_path(evento), method: :patch, data: { escalar_ministros_target: "form" }, class: "space-y-8" do %>
    <% return_params.each do |k, v| %>
      <%= hidden_field_tag k, v %>
    <% end %>
    <%= hidden_field_tag :escalar_context, standalone ? "page" : "modal" %>
    <div data-ministro-ids-container></div>
    <input type="hidden" name="ministro_coordenador_id" data-escalar-ministros-target="ministroCoordenadorId" value="<%= evento.ministro_coordenador&.id %>">
    <input type="hidden" name="ministro_adoracao_id" data-escalar-ministros-target="ministroAdoracaoId" value="<%= evento.ministro_adoracao&.id %>">
    <input type="hidden" name="sacerdote_id" data-escalar-ministros-target="sacerdoteId" value="<%= evento.sacerdote_id %>">

    <%# Sacerdote %>
    <section class="rounded-2xl border border-stone-200/90 bg-white shadow-md shadow-stone-900/5 ring-1 ring-stone-100 overflow-hidden">
      <div class="px-5 py-4 sm:px-6 border-b border-stone-100 bg-gradient-to-r from-violet-50/90 via-white to-indigo-50/50 flex items-start gap-4">
        <span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-white shadow-sm ring-1 ring-violet-200/70 text-violet-700">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
        </span>
        <div class="min-w-0 pt-0.5">
          <h3 class="text-base font-bold text-stone-900 tracking-tight">Sacerdote</h3>
          <p class="text-xs text-stone-500 mt-1 leading-relaxed">Arraste da lista à esquerda para o cartão do evento. Use <span class="font-medium text-stone-700">Nenhum</span> se ainda não houver definição.</p>
        </div>
      </div>
      <div class="p-5 sm:p-6">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 lg:gap-5">
          <div class="rounded-2xl border-2 border-dashed border-stone-200/90 bg-gradient-to-b from-stone-50/80 to-stone-50/30 p-4 min-h-[7rem] ring-1 ring-stone-100/80" data-zone="sacerdotes_disponiveis"
               data-action="dragover->escalar-ministros#dragOver drop->escalar-ministros#drop">
            <p class="text-[11px] font-bold uppercase tracking-wider text-stone-400 mb-3 flex items-center gap-2">
              <svg class="w-3.5 h-3.5 text-stone-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8h16M4 16h16"/></svg>
              Banco de sacerdotes
            </p>
            <div class="flex flex-wrap gap-2">
              <div data-sacerdote-id="none" class="inline-flex items-center gap-2 px-3 py-2 rounded-xl border border-stone-200/90 bg-white shadow-sm cursor-grab active:cursor-grabbing hover:border-violet-300 hover:shadow-md hover:ring-1 hover:ring-violet-200/50 transition-all text-xs font-medium text-stone-600"
                   draggable="true" data-action="dragstart->escalar-ministros#sacerdoteDragStart dragend->escalar-ministros#sacerdoteDragEnd">
                <span class="text-stone-400"><svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8h16M4 16h16"/></svg></span>
                Nenhum
              </div>
              <% (sacerdotes || []).each do |s| %>
                <div data-sacerdote-id="<%= s.id %>" data-sacerdote-json='<%= { id: s.id, nome: s.nome }.to_json %>'
                     class="inline-flex items-center gap-2 px-3 py-2 rounded-xl border border-stone-200/90 bg-white shadow-sm cursor-grab active:cursor-grabbing hover:border-violet-400 hover:shadow-md hover:ring-1 hover:ring-violet-200/60 transition-all text-xs font-semibold text-stone-800"
                     draggable="true" data-action="dragstart->escalar-ministros#sacerdoteDragStart dragend->escalar-ministros#sacerdoteDragEnd">
                  <span class="text-stone-400"><svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8h16M4 16h16"/></svg></span>
                  <%= s.nome %>
                </div>
              <% end %>
              <% if (sacerdotes || []).empty? %>
                <p class="text-stone-500 text-sm py-2 w-full text-center rounded-xl border border-dashed border-stone-200 bg-white/60">Nenhum sacerdote ativo cadastrado.</p>
              <% end %>
            </div>
          </div>
          <div class="rounded-2xl border-2 border-violet-300/70 bg-gradient-to-br from-violet-50/95 to-indigo-50/60 p-4 min-h-[7rem] shadow-inner shadow-violet-900/5 ring-1 ring-violet-200/40" data-zone="sacerdote_evento"
               data-action="dragover->escalar-ministros#dragOver drop->escalar-ministros#drop">
            <p class="text-[11px] font-bold uppercase tracking-wider text-violet-800/90 mb-3 flex items-center gap-2">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              Celebração
            </p>
            <div class="min-h-[2.75rem]" data-escalar-ministros-target="sacerdoteEscalado">
              <% if evento.sacerdote %>
                <div data-sacerdote-id="<%= evento.sacerdote_id %>" data-sacerdote-json='<%= { id: evento.sacerdote.id, nome: evento.sacerdote.nome }.to_json %>'
                     class="inline-flex items-center gap-2 px-4 py-2.5 rounded-xl border border-violet-200 bg-white shadow-md cursor-grab active:cursor-grabbing hover:border-violet-400 transition-all text-sm font-semibold text-stone-900"
                     draggable="true" data-action="dragstart->escalar-ministros#sacerdoteDragStart dragend->escalar-ministros#sacerdoteDragEnd">
                  <span class="text-violet-500"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8h16M4 16h16"/></svg></span>
                  <%= evento.sacerdote.nome %>
                </div>
              <% else %>
                <div class="flex flex-col items-center justify-center py-6 rounded-xl border border-dashed border-violet-300/60 bg-white/50 text-center">
                  <p class="text-sm font-medium text-violet-900/80">Solte o sacerdote aqui</p>
                  <p class="text-xs text-violet-700/70 mt-1">Área do evento</p>
                </div>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    </section>

    <%# Ministros %>
    <section class="rounded-2xl border border-stone-200/90 bg-white shadow-md shadow-stone-900/5 ring-1 ring-stone-100 overflow-hidden">
      <div class="px-5 py-4 sm:px-6 border-b border-stone-100 bg-gradient-to-r from-sky-50/90 via-white to-cyan-50/40 flex items-start gap-4">
        <span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-white shadow-sm ring-1 ring-sky-200/70 text-sky-700">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
        </span>
        <div class="min-w-0 pt-0.5">
          <h3 class="text-base font-bold text-stone-900 tracking-tight">Ministros</h3>
          <p class="text-xs text-stone-500 mt-1 leading-relaxed">Monte a equipe à direita. Um <span class="font-semibold text-amber-700">coordenador</span> e um responsável pela <span class="font-semibold text-fuchsia-700">adoração</span> (opcional).</p>
        </div>
      </div>
      <div class="p-5 sm:p-6">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-5 lg:gap-6">
          <div class="rounded-2xl border-2 border-dashed border-stone-200/90 bg-gradient-to-b from-stone-50/90 to-white p-4 sm:p-5 min-h-[12rem] ring-1 ring-stone-100" data-zone="disponiveis"
               data-action="dragover->escalar-ministros#dragOver drop->escalar-ministros#drop">
            <h4 class="text-xs font-bold uppercase tracking-wider text-stone-500 mb-3">Disponíveis</h4>
            <div class="flex flex-wrap gap-2 max-h-[220px] overflow-y-auto pr-1">
              <% ids_escalados = evento.ministro_ids %>
              <% ministros_disponiveis.each do |m| %>
                <% next if ids_escalados.include?(m.id) %>
                <div data-ministro-id="<%= m.id %>" data-ministro-json='<%= { id: m.id, nome: m.nome }.to_json %>'
                     class="inline-flex items-center gap-2 px-3 py-2 rounded-xl border border-stone-200/90 bg-white shadow-sm cursor-grab active:cursor-grabbing hover:border-sky-400 hover:shadow-md hover:ring-1 hover:ring-sky-200/50 transition-all text-xs font-semibold text-stone-800"
                     draggable="true" data-action="dragstart->escalar-ministros#dragStart dragend->escalar-ministros#dragEnd">
                  <span class="text-stone-400"><svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8h16M4 16h16"/></svg></span>
                  <%= m.nome %>
                </div>
              <% end %>
              <% if (ministros_disponiveis.map(&:id) - ids_escalados).empty? %>
                <p class="text-stone-500 text-sm py-6 w-full text-center rounded-xl border border-dashed border-stone-200 bg-white/70">Todos os ministros já estão neste evento.</p>
              <% end %>
            </div>
          </div>
          <div class="rounded-2xl border-2 border-sky-400/50 bg-gradient-to-br from-sky-50 via-white to-indigo-50/50 p-4 sm:p-5 min-h-[12rem] shadow-inner shadow-sky-900/5 ring-1 ring-sky-200/50" data-zone="escalados"
               data-action="dragover->escalar-ministros#dragOver drop->escalar-ministros#drop">
            <div class="flex items-center justify-between gap-2 mb-3">
              <h4 class="text-xs font-bold uppercase tracking-wider text-sky-900/90">Neste evento</h4>
              <span class="text-[10px] font-semibold text-sky-700/80 bg-sky-100/80 px-2 py-0.5 rounded-full">Coord. · Ador.</span>
            </div>
            <div class="space-y-2.5 min-h-[120px]" data-escalar-ministros-target="escalados" data-zone="escalados"
                 data-action="dragover->escalar-ministros#dragOver drop->escalar-ministros#drop">
              <% ministros_escalados.each do |em| %>
                <div data-ministro-id="<%= em.ministro_id %>" data-ministro-json='<%= { id: em.ministro.id, nome: em.ministro.nome }.to_json %>'
                     class="flex flex-wrap sm:flex-nowrap items-center gap-2 p-3 rounded-xl border border-sky-200/80 bg-white shadow-sm cursor-grab active:cursor-grabbing hover:border-sky-400 hover:shadow-md transition-all group"
                     draggable="true"
                     data-action="dragstart->escalar-ministros#dragStart dragend->escalar-ministros#dragEnd dragover->escalar-ministros#dragOver drop->escalar-ministros#drop">
                  <span class="shrink-0 <%= em.coordenador? ? "text-amber-500" : "text-stone-300" %>">
                    <svg class="w-5 h-5 <%= em.coordenador? ? "fill-amber-500" : "" %>" fill="<%= em.coordenador? ? "currentColor" : "none" %>" stroke="currentColor" viewBox="0 0 20 20" aria-hidden="true"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                  </span>
                  <span class="text-sm font-semibold flex-1 min-w-[8rem] truncate <%= em.coordenador? ? "text-sky-800" : "text-stone-800" %>"><%= em.ministro.nome %></span>
                  <div class="flex flex-wrap items-center gap-1.5 w-full sm:w-auto sm:justify-end">
                    <button type="button" class="shrink-0 px-2.5 py-1 text-[11px] font-bold uppercase tracking-wide rounded-lg <%= em.coordenador? ? "bg-amber-100 text-amber-900 ring-1 ring-amber-200/80" : "bg-stone-100 text-stone-600 hover:bg-amber-50 hover:text-amber-800 ring-1 ring-stone-200/80" %> transition-colors"
                            data-action="click->escalar-ministros#setCoordenadorClick" data-ministro-id="<%= em.ministro_id %>" title="Coordenador">
                      <%= em.coordenador? ? "★ Coord." : "Coord." %>
                    </button>
                    <button type="button" class="shrink-0 px-2.5 py-1 text-[11px] font-bold uppercase tracking-wide rounded-lg <%= em.adoracao? ? "bg-fuchsia-100 text-fuchsia-900 ring-1 ring-fuchsia-200/80" : "bg-stone-100 text-stone-600 hover:bg-fuchsia-50 hover:text-fuchsia-800 ring-1 ring-stone-200/80" %> transition-colors"
                            data-action="click->escalar-ministros#setAdoracaoClick" data-ministro-id="<%= em.ministro_id %>" title="Adoração">
                      <%= em.adoracao? ? "♥ Ador." : "Ador." %>
                    </button>
                    <button type="button" class="shrink-0 p-1.5 rounded-lg text-stone-400 hover:text-red-600 hover:bg-red-50 opacity-100 sm:opacity-0 sm:group-hover:opacity-100 transition-opacity"
                            data-action="click->escalar-ministros#removeClick" title="Remover">
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                    </button>
                  </div>
                </div>
              <% end %>
              <% if ministros_escalados.empty? %>
                <div class="flex flex-col items-center justify-center py-10 rounded-xl border border-dashed border-sky-300/70 bg-white/60 text-center">
                  <div class="h-10 w-10 rounded-full bg-sky-100 text-sky-600 flex items-center justify-center mb-2">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
                  </div>
                  <p class="text-sm font-medium text-sky-900/90">Arraste ministros para cá</p>
                  <p class="text-xs text-sky-700/70 mt-1 max-w-[14rem]">Solte na zona à direita para formar a equipe desta celebração.</p>
                </div>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    </section>

    <div class="flex flex-col-reverse sm:flex-row sm:items-center sm:justify-between gap-4 pt-2 border-t border-stone-200/80">
      <% if standalone %>
        <%= link_to competencia_lista, class: "inline-flex items-center justify-center gap-2 px-5 py-3 rounded-xl border border-stone-300 bg-white text-stone-800 text-sm font-semibold hover:bg-stone-50 hover:border-stone-400 transition-colors shadow-sm" do %>
          <svg class="w-4 h-4 text-stone-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
          Voltar sem salvar
        <% end %>
      <% else %>
        <button type="button" data-action="click->modal#close" class="inline-flex items-center justify-center gap-2 px-5 py-3 rounded-xl border border-stone-300 bg-white text-stone-800 text-sm font-semibold hover:bg-stone-50 transition-colors shadow-sm">
          Cancelar
        </button>
      <% end %>
      <button type="submit" class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-xl bg-gradient-to-r from-sky-600 to-indigo-600 hover:from-sky-500 hover:to-indigo-500 text-white text-sm font-bold shadow-lg shadow-sky-900/25 ring-1 ring-white/10 transition-all sm:min-w-[11rem]">
        <svg class="w-4 h-4 opacity-90" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
        Salvar escala
      </button>
    </div>
  <% end %>
</div>
