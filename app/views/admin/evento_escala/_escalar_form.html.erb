<% ministros_json = (ministros_disponiveis + ministros_escalados.map(&:ministro)).uniq.map { |m| { id: m.id, nome: m.nome } }.to_json %>
<% sacerdotes_json = (sacerdotes || []).map { |s| { id: s.id, nome: s.nome } }.to_json %>
<div class="space-y-6" data-controller="escalar-ministros" data-escalar-ministros-ministros-data-value="<%= h ministros_json %>" data-escalar-ministros-sacerdotes-data-value="<%= h sacerdotes_json %>">
  <%= form_with url: update_escalar_ministros_admin_evento_escala_path(evento), method: :patch, data: { escalar_ministros_target: "form", turbo_frame: "_top" }, class: "space-y-6" do %>
    <div data-ministro-ids-container></div>
    <input type="hidden" name="ministro_coordenador_id" data-escalar-ministros-target="ministroCoordenadorId" value="<%= evento.ministro_coordenador&.id %>">
    <input type="hidden" name="ministro_adoracao_id" data-escalar-ministros-target="ministroAdoracaoId" value="<%= evento.ministro_adoracao&.id %>">
    <input type="hidden" name="sacerdote_id" data-escalar-ministros-target="sacerdoteId" value="<%= evento.sacerdote_id %>">

    <%# Sacerdote %>
    <div>
      <h3 class="text-sm font-semibold text-stone-700 mb-2">Sacerdote</h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="rounded-lg border-2 border-dashed border-stone-200 bg-stone-50/50 p-3" data-zone="sacerdotes_disponiveis"
             data-action="dragover->escalar-ministros#dragOver drop->escalar-ministros#drop">
          <p class="text-xs text-stone-500 mb-2">Arraste para o evento à direita</p>
          <div class="flex flex-wrap gap-1.5">
            <div data-sacerdote-id="none" class="inline-flex items-center gap-1 px-2 py-1 rounded-md border border-stone-200 bg-white cursor-grab active:cursor-grabbing hover:border-stone-400 transition-colors text-xs"
                 draggable="true" data-action="dragstart->escalar-ministros#sacerdoteDragStart dragend->escalar-ministros#sacerdoteDragEnd">
              <span class="text-stone-400"><svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8h16M4 16h16"/></svg></span>
              Nenhum
            </div>
            <% (sacerdotes || []).each do |s| %>
              <div data-sacerdote-id="<%= s.id %>" data-sacerdote-json='<%= { id: s.id, nome: s.nome }.to_json %>'
                   class="inline-flex items-center gap-1 px-2 py-1 rounded-md border border-stone-200 bg-white cursor-grab active:cursor-grabbing hover:border-violet-300 transition-colors text-xs"
                   draggable="true" data-action="dragstart->escalar-ministros#sacerdoteDragStart dragend->escalar-ministros#sacerdoteDragEnd">
                <span class="text-stone-400"><svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8h16M4 16h16"/></svg></span>
                <span class="text-stone-800"><%= s.nome %></span>
              </div>
            <% end %>
            <% if (sacerdotes || []).empty? %>
              <p class="text-stone-500 text-xs">Nenhum sacerdote cadastrado</p>
            <% end %>
          </div>
        </div>
        <div class="rounded-lg border-2 border-violet-200 bg-violet-50/30 p-3 min-h-[60px]" data-zone="sacerdote_evento"
             data-action="dragover->escalar-ministros#dragOver drop->escalar-ministros#drop">
          <p class="text-xs text-violet-600/80 mb-2">Sacerdote deste evento</p>
          <div class="min-h-[36px]" data-escalar-ministros-target="sacerdoteEscalado">
            <% if evento.sacerdote %>
              <div data-sacerdote-id="<%= evento.sacerdote_id %>" data-sacerdote-json='<%= { id: evento.sacerdote.id, nome: evento.sacerdote.nome }.to_json %>'
                   class="inline-flex items-center gap-2 px-2 py-1 rounded-md border border-violet-200 bg-white cursor-grab active:cursor-grabbing hover:border-violet-400 transition-colors text-sm"
                   draggable="true" data-action="dragstart->escalar-ministros#sacerdoteDragStart dragend->escalar-ministros#sacerdoteDragEnd">
                <span class="text-stone-400"><svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8h16M4 16h16"/></svg></span>
                <span class="font-medium text-stone-800"><%= evento.sacerdote.nome %></span>
              </div>
            <% else %>
              <p class="text-stone-500 text-sm py-1">Arraste sacerdote aqui</p>
            <% end %>
          </div>
        </div>
      </div>
    </div>

    <%# Ministros %>
    <div>
      <h3 class="text-sm font-semibold text-stone-700 mb-2">Ministros</h3>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
        <div class="rounded-xl border-2 border-dashed border-stone-200 bg-stone-50/50 p-4" data-zone="disponiveis"
             data-action="dragover->escalar-ministros#dragOver drop->escalar-ministros#drop">
          <h4 class="text-xs font-semibold text-stone-700 mb-2">Disponíveis</h4>
          <div class="flex flex-wrap gap-1.5 max-h-[200px] overflow-y-auto">
            <% ids_escalados = evento.ministro_ids %>
            <% ministros_disponiveis.each do |m| %>
              <% next if ids_escalados.include?(m.id) %>
              <div data-ministro-id="<%= m.id %>" data-ministro-json='<%= { id: m.id, nome: m.nome }.to_json %>'
                   class="inline-flex items-center gap-1 px-2 py-1 rounded-md border border-stone-200 bg-white cursor-grab active:cursor-grabbing hover:border-sky-300 transition-colors text-xs"
                   draggable="true" data-action="dragstart->escalar-ministros#dragStart dragend->escalar-ministros#dragEnd">
                <span class="text-stone-400"><svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8h16M4 16h16"/></svg></span>
                <span class="text-stone-800"><%= m.nome %></span>
              </div>
            <% end %>
            <% if (ministros_disponiveis.map(&:id) - ids_escalados).empty? %>
              <p class="text-stone-500 text-xs py-2">Todos escalados</p>
            <% end %>
          </div>
        </div>
        <div class="rounded-xl border-2 border-sky-200 bg-sky-50/30 p-4" data-zone="escalados"
             data-action="dragover->escalar-ministros#dragOver drop->escalar-ministros#drop">
          <h4 class="text-xs font-semibold text-sky-800 mb-2">Neste evento</h4>
          <p class="text-[10px] text-sky-600/80 mb-2">Botões: Coord. e Ador.</p>
          <div class="space-y-2 min-h-[100px]" data-escalar-ministros-target="escalados" data-zone="escalados"
               data-action="dragover->escalar-ministros#dragOver drop->escalar-ministros#drop">
            <% ministros_escalados.each do |em| %>
              <div data-ministro-id="<%= em.ministro_id %>" data-ministro-json='<%= { id: em.ministro.id, nome: em.ministro.nome }.to_json %>'
                   class="flex items-center gap-2 p-2 rounded-lg border bg-white cursor-grab active:cursor-grabbing hover:border-sky-300 transition-colors group"
                   draggable="true"
                   data-action="dragstart->escalar-ministros#dragStart dragend->escalar-ministros#dragEnd dragover->escalar-ministros#dragOver drop->escalar-ministros#drop">
                <span class="shrink-0 <%= em.coordenador? ? "text-amber-500" : "text-stone-400" %>">
                  <svg class="w-4 h-4 <%= em.coordenador? ? "fill-amber-500" : "" %>" fill="<%= em.coordenador? ? "currentColor" : "none" %>" stroke="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                </span>
                <span class="text-sm font-medium flex-1 min-w-0 truncate <%= em.coordenador? ? "text-sky-600" : "text-stone-800" %>"><%= em.ministro.nome %></span>
                <button type="button" class="shrink-0 px-2 py-0.5 text-xs font-medium rounded <%= em.coordenador? ? "bg-amber-100 text-amber-700" : "bg-stone-100 text-stone-600 hover:bg-sky-100 hover:text-sky-700" %>"
                        data-action="click->escalar-ministros#setCoordenadorClick" data-ministro-id="<%= em.ministro_id %>" title="Coordenador">
                  <%= em.coordenador? ? "★ Coord." : "Coord." %>
                </button>
                <button type="button" class="shrink-0 px-2 py-0.5 text-xs font-medium rounded <%= em.adoracao? ? "bg-rose-100 text-rose-700" : "bg-stone-100 text-stone-600 hover:bg-rose-100 hover:text-rose-700" %>"
                        data-action="click->escalar-ministros#setAdoracaoClick" data-ministro-id="<%= em.ministro_id %>" title="Adoração">
                  <%= em.adoracao? ? "♥ Ador." : "Ador." %>
                </button>
                <button type="button" class="shrink-0 p-1 rounded text-stone-400 hover:text-red-600 hover:bg-red-50 opacity-0 group-hover:opacity-100"
                        data-action="click->escalar-ministros#removeClick" title="Remover">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                </button>
              </div>
            <% end %>
            <% if ministros_escalados.empty? %>
              <p class="text-stone-500 text-sm py-4 text-center">Arraste ministros aqui</p>
            <% end %>
          </div>
        </div>
      </div>
    </div>

    <div class="flex flex-wrap gap-3 pt-2">
      <button type="submit" class="px-4 py-2.5 bg-slate-600 hover:bg-slate-700 text-white font-medium rounded-lg transition-colors cursor-pointer">Salvar</button>
      <button type="button" data-action="click->modal#close" class="px-4 py-2.5 border border-stone-300 text-stone-700 hover:bg-stone-50 font-medium rounded-lg transition-colors">Cancelar</button>
    </div>
  <% end %>
</div>
