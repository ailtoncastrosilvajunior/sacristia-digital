<%# Campos compartilhados entre new, edit e form_modal %>
<div>
  <%= f.label :tipo_servico_id, "Tipo de serviço", class: "block text-sm font-medium text-stone-700 mb-1" %>
  <%= f.collection_select :tipo_servico_id, TipoServico.ativos, :id, :nome, { include_blank: @evento.persisted? ? false : "Selecione..." },
      class: "w-full px-4 py-2.5 rounded-lg border border-stone-300 focus:ring-2 focus:ring-slate-500/20 focus:border-slate-500" %>
</div>

<div class="grid grid-cols-2 gap-4">
  <div>
    <%= f.label :data, class: "block text-sm font-medium text-stone-700 mb-1" %>
    <%= f.date_field :data, class: "w-full px-4 py-2.5 rounded-lg border border-stone-300 focus:ring-2 focus:ring-slate-500/20 focus:border-slate-500" %>
  </div>
  <div>
    <%= f.label :horario, class: "block text-sm font-medium text-stone-700 mb-1" %>
    <%= f.time_field :horario, class: "w-full px-4 py-2.5 rounded-lg border border-stone-300 focus:ring-2 focus:ring-slate-500/20 focus:border-slate-500" %>
  </div>
</div>

<div>
  <%= f.label :local, class: "block text-sm font-medium text-stone-700 mb-1" %>
  <%= f.text_field :local, class: "w-full px-4 py-2.5 rounded-lg border border-stone-300 focus:ring-2 focus:ring-slate-500/20 focus:border-slate-500" %>
</div>

<div>
  <%= f.label :quantidade_ministros, "Quantidade de ministros", class: "block text-sm font-medium text-stone-700 mb-1" %>
  <%= f.number_field :quantidade_ministros, min: 0, class: "w-full px-4 py-2.5 rounded-lg border border-stone-300 focus:ring-2 focus:ring-slate-500/20 focus:border-slate-500" %>
</div>

<div class="rounded-xl border border-sky-200 bg-sky-50/50 p-4 space-y-4">
  <h3 class="text-sm font-semibold text-stone-800 flex items-center gap-2">
    <svg class="w-4 h-4 text-sky-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
    Participantes do evento
  </h3>
  <div>
    <%= f.label :sacerdote_id, "Sacerdote", class: "block text-sm font-medium text-stone-700 mb-1" %>
    <%= f.collection_select :sacerdote_id, Sacerdote.ativos.ordenados_por_nome, :id, :nome, { include_blank: "Nenhum" },
        class: "w-full px-4 py-2.5 rounded-lg border border-stone-300 focus:ring-2 focus:ring-slate-500/20 focus:border-slate-500 bg-white" %>
    <p class="mt-1 text-xs text-stone-500">Para missas e celebrações que exigem sacerdote</p>
  </div>
  <%= render "minister_fields", f: f %>
</div>

<div>
  <%= f.label :valor_esportula, "Valor espórtula (opcional)", class: "block text-sm font-medium text-stone-700 mb-1" %>
  <%= f.number_field :valor_esportula, step: 0.01, min: 0, class: "w-full px-4 py-2.5 rounded-lg border border-stone-300 focus:ring-2 focus:ring-slate-500/20 focus:border-slate-500" %>
</div>

<% if @evento.persisted? %>
  <div>
    <%= f.label :status, class: "block text-sm font-medium text-stone-700 mb-1" %>
    <%= f.select :status, EventoEscala::STATUS.map { |s| [I18n.t("activerecord.attributes.evento_escala.status_values.#{s}", default: s.humanize), s] }, {},
        class: "w-full px-4 py-2.5 rounded-lg border border-stone-300 focus:ring-2 focus:ring-slate-500/20 focus:border-slate-500" %>
  </div>
<% end %>

<div>
  <%= f.label :descricao, class: "block text-sm font-medium text-stone-700 mb-1" %>
  <%= f.text_area :descricao, rows: 2, class: "w-full px-4 py-2.5 rounded-lg border border-stone-300 focus:ring-2 focus:ring-slate-500/20 focus:border-slate-500" %>
</div>

<div>
  <%= f.label :observacoes, class: "block text-sm font-medium text-stone-700 mb-1" %>
  <%= f.text_area :observacoes, rows: 2, class: "w-full px-4 py-2.5 rounded-lg border border-stone-300 focus:ring-2 focus:ring-slate-500/20 focus:border-slate-500" %>
</div>
