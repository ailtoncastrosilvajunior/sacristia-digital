<%# locals: evento, variant: :inline | :chips %>
<% variant = local_assigns.fetch(:variant, :inline).to_sym %>
<% ems = evento.escala_ministros.select { |em| em.ministro.present? }.sort_by { |em| em.ministro.nome.to_s.downcase } %>
<% if ems.empty? %>
  <% if variant == :chips %>
    <span class="text-stone-400 italic text-sm">Ninguém escalado ainda</span>
  <% else %>
    —
  <% end %>
<% elsif variant == :chips %>
  <div class="flex flex-wrap gap-2">
    <% ems.each do |em| %>
      <% nome = em.ministro.nome %>
      <% if em.coordenador? && em.adoracao? %>
        <span class="inline-flex items-center gap-2 max-w-full px-3 py-2 rounded-xl font-semibold text-sm text-stone-900 bg-gradient-to-r from-amber-100 via-white to-fuchsia-100 border border-amber-200/70 shadow-md shadow-amber-900/5 ring-1 ring-fuchsia-200/50" title="Coordenador e adoração">
          <span class="inline-flex items-center gap-0.5 shrink-0" aria-hidden="true">
            <svg class="w-4 h-4 text-amber-600 drop-shadow-sm" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            <svg class="w-4 h-4 text-fuchsia-600 drop-shadow-sm" viewBox="0 0 24 24" fill="currentColor"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
          </span>
          <span class="leading-tight"><%= nome %></span>
        </span>
      <% elsif em.coordenador? %>
        <span class="inline-flex items-center gap-2 max-w-full px-3 py-2 rounded-xl font-semibold text-sm text-amber-950 bg-gradient-to-br from-amber-200/90 to-amber-50 border border-amber-400/50 shadow-md shadow-amber-900/10 ring-1 ring-amber-300/40" title="Coordenador">
          <svg class="w-4 h-4 shrink-0 text-amber-600 drop-shadow-sm" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          <span class="leading-tight"><%= nome %></span>
        </span>
      <% elsif em.adoracao? %>
        <span class="inline-flex items-center gap-2 max-w-full px-3 py-2 rounded-xl font-semibold text-sm text-fuchsia-950 bg-gradient-to-br from-fuchsia-200/90 to-fuchsia-50 border border-fuchsia-400/45 shadow-md shadow-fuchsia-900/10 ring-1 ring-fuchsia-300/40" title="Adoração">
          <svg class="w-4 h-4 shrink-0 text-fuchsia-600 drop-shadow-sm" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
          <span class="leading-tight"><%= nome %></span>
        </span>
      <% else %>
        <span class="inline-flex items-center gap-2 max-w-full px-3 py-2 rounded-xl font-semibold text-sm text-stone-800 bg-gradient-to-br from-stone-100 to-white border border-stone-200/90 shadow-sm ring-1 ring-stone-100/90">
          <svg class="w-4 h-4 shrink-0 text-stone-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          <span class="leading-tight"><%= nome %></span>
        </span>
      <% end %>
    <% end %>
  </div>
<% else %>
  <% ems.each_with_index do |em, i| %>
    <%= ", " if i > 0 %>
    <% nome = em.ministro.nome %>
    <% if em.coordenador? && em.adoracao? %>
      <span class="inline-flex items-center gap-1 align-middle max-w-full px-2 py-0.5 rounded-lg text-xs font-semibold text-stone-900 bg-gradient-to-r from-amber-50 to-fuchsia-50 border border-amber-200/80 shadow-sm ring-1 ring-fuchsia-100/80" title="Coordenador e adoração">
        <span class="inline-flex items-center gap-px shrink-0" aria-hidden="true">
          <svg class="w-3.5 h-3.5 text-amber-600" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
          <svg class="w-3.5 h-3.5 text-fuchsia-600" viewBox="0 0 24 24" fill="currentColor"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
        </span>
        <span class="font-semibold text-stone-800"><%= nome %></span>
      </span>
    <% elsif em.coordenador? %>
      <span class="inline-flex items-center gap-1 align-middle max-w-full px-2 py-0.5 rounded-lg text-xs font-semibold text-amber-950 bg-gradient-to-r from-amber-100 to-amber-50 border border-amber-300/70 shadow-sm ring-1 ring-amber-200/50" title="Coordenador">
        <svg class="w-3.5 h-3.5 shrink-0 text-amber-600" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        <span><%= nome %></span>
      </span>
    <% elsif em.adoracao? %>
      <span class="inline-flex items-center gap-1 align-middle max-w-full px-2 py-0.5 rounded-lg text-xs font-semibold text-fuchsia-950 bg-gradient-to-r from-fuchsia-100 to-fuchsia-50 border border-fuchsia-300/70 shadow-sm ring-1 ring-fuchsia-200/50" title="Adoração">
        <svg class="w-3.5 h-3.5 shrink-0 text-fuchsia-600" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
        <span><%= nome %></span>
      </span>
    <% else %>
      <span class="inline-flex items-center gap-1 align-middle max-w-full px-1.5 py-0.5 rounded-md text-xs font-medium text-stone-700 bg-stone-100/90 border border-stone-200/80">
        <svg class="w-3 h-3 shrink-0 text-stone-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
        <span><%= nome %></span>
      </span>
    <% end %>
  <% end %>
<% end %>
