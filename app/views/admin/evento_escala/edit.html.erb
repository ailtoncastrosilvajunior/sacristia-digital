<div class="space-y-6">
  <div>
    <%= link_to "← #{@evento.competencia_mensal.label}", admin_competencia_mensal_path(@evento.competencia_mensal), class: "text-sm text-stone-500 hover:text-stone-700 mb-2 block" %>
    <h1 class="text-2xl font-semibold text-stone-800">Editar evento</h1>
    <p class="text-stone-500 mt-1"><%= @evento.tipo_servico.nome %> - <%= l(@evento.data) %> <%= l(@evento.horario, format: :time) %></p>
  </div>

  <div class="bg-white rounded-xl border border-stone-200 shadow-sm p-6 max-w-2xl">
    <%= form_with model: @evento, url: admin_evento_escala_path(@evento), method: :patch, local: true, html: { class: "space-y-5" } do |f| %>
      <% if @evento.errors.any? %>
        <div class="rounded-lg bg-red-50 p-4 text-red-800 text-sm">
          <p class="font-medium mb-2"><%= pluralize(@evento.errors.count, "erro") %> impediram a atualização:</p>
          <ul class="list-disc list-inside">
            <% @evento.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <%= render "form_fields", f: f %>

      <div class="flex gap-3 pt-4">
        <%= f.submit "Salvar", class: "px-4 py-2.5 bg-slate-600 hover:bg-slate-700 text-white font-medium rounded-lg transition-colors cursor-pointer" %>
        <%= link_to "Cancelar", admin_competencia_mensal_path(@evento.competencia_mensal), class: "px-4 py-2.5 border border-stone-300 text-stone-700 hover:bg-stone-50 font-medium rounded-lg transition-colors" %>
      </div>
    <% end %>
  </div>
</div>
