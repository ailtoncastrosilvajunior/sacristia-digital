<div class="max-w-4xl mx-auto py-6">
  <div class="mb-6">
    <%= link_to "← #{@evento.competencia_mensal.label}", admin_competencia_mensal_path(@evento.competencia_mensal, aba: "lista"), class: "text-sm text-stone-500 hover:text-stone-700 mb-2 block" %>
    <h1 class="text-2xl font-semibold text-stone-800">Escalar evento</h1>
    <p class="text-stone-500 mt-1"><%= @evento.tipo_servico.nome %> · <%= l(@evento.data) %> às <%= l(@evento.horario, format: :time) %></p>
  </div>

  <%= render "admin/evento_escala/escalar_form", evento: @evento, ministros_disponiveis: @ministros_disponiveis, ministros_escalados: @ministros_escalados, sacerdotes: @sacerdotes %>
</div>
