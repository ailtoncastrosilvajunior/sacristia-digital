<%# Mesmo layout do form de edição, com campos bloqueados (readonly) %>
<% evento = local_assigns[:evento] || @evento %>
<% base_input_class = "w-full px-4 py-2.5 rounded-lg border border-stone-300 bg-stone-50 text-stone-800 cursor-not-allowed" %>

<div>
  <label class="block text-sm font-medium text-stone-700 mb-1">Tipo de serviço</label>
  <div class="<%= base_input_class %>">
    <span class="inline-flex px-2 py-0.5 text-sm font-medium rounded border" style="background-color: <%= evento.tipo_servico.cor_etiqueta %>26; border-color: <%= evento.tipo_servico.cor_etiqueta %>; color: #1f2937;"><%= evento.tipo_servico.nome %></span>
  </div>
</div>

<div class="grid grid-cols-2 gap-4">
  <div>
    <label class="block text-sm font-medium text-stone-700 mb-1">Data</label>
    <input type="text" value="<%= l(evento.data) %>" readonly class="<%= base_input_class %>" />
  </div>
  <div>
    <label class="block text-sm font-medium text-stone-700 mb-1">Horário</label>
    <input type="text" value="<%= l(evento.horario, format: :time) %>" readonly class="<%= base_input_class %>" />
  </div>
</div>

<div>
  <label class="block text-sm font-medium text-stone-700 mb-1">Local</label>
  <input type="text" value="<%= evento.local.presence || "—" %>" readonly class="<%= base_input_class %>" />
</div>

<div>
  <label class="block text-sm font-medium text-stone-700 mb-1">Quantidade de ministros</label>
  <input type="text" value="<%= evento.quantidade_ministros %>" readonly class="<%= base_input_class %>" />
</div>

<div>
  <label class="block text-sm font-medium text-stone-700 mb-1">Ministros escalados</label>
  <div class="<%= base_input_class %> min-h-[42px] flex items-center">
    <%= render "admin/evento_escala/ministros_com_coordenador", evento: evento %>
  </div>
</div>

<div>
  <label class="block text-sm font-medium text-stone-700 mb-1">Sacerdote</label>
  <input type="text" value="<%= evento.sacerdote&.nome || "Nenhum" %>" readonly class="<%= base_input_class %>" />
</div>

<div>
  <label class="block text-sm font-medium text-stone-700 mb-1">Valor espórtula (opcional)</label>
  <input type="text" value="<%= evento.valor_esportula.present? && evento.valor_esportula > 0 ? number_to_currency(evento.valor_esportula, unit: "R$ ", separator: ",", delimiter: ".") : "—" %>" readonly class="<%= base_input_class %>" />
</div>

<div>
  <label class="block text-sm font-medium text-stone-700 mb-1">Status</label>
  <div class="<%= base_input_class %> min-h-[42px] flex items-center">
    <span class="inline-flex px-2 py-0.5 text-xs font-medium rounded-full border
      <%= case evento.status
          when 'confirmado' then 'bg-emerald-100 text-emerald-800 border-emerald-300'
          when 'concluido' then 'bg-sky-100 text-sky-800 border-sky-300'
          when 'cancelado' then 'bg-red-100 text-red-800 border-red-300'
          else 'bg-amber-100 text-amber-800 border-amber-300'
          end %>">
      <%= I18n.t("activerecord.attributes.evento_escala.status_values.#{evento.status}", default: evento.status.humanize) %>
    </span>
  </div>
</div>

<div>
  <label class="block text-sm font-medium text-stone-700 mb-1">Descrição</label>
  <textarea rows="2" readonly class="<%= base_input_class %>"><%= evento.descricao.presence || "—" %></textarea>
</div>

<div>
  <label class="block text-sm font-medium text-stone-700 mb-1">Observações</label>
  <textarea rows="2" readonly class="<%= base_input_class %>"><%= evento.observacoes.presence || "—" %></textarea>
</div>
