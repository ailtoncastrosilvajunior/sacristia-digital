<turbo-frame id="evento_modal">
  <div class="bg-white rounded-xl border border-stone-200 shadow-lg max-w-2xl max-h-[90vh] overflow-y-auto">
    <div class="sticky top-0 bg-white border-b border-stone-200 px-6 py-4 flex items-center justify-between z-10">
      <h2 class="text-lg font-semibold text-stone-800">Novo evento</h2>
      <button type="button" data-action="click->modal#close" class="p-1 rounded-lg text-stone-400 hover:text-stone-600 hover:bg-stone-100 transition-colors" aria-label="Fechar">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </div>
    <div class="p-6">
      <p class="text-stone-500 text-sm mb-4">Adicione um evento à escala de <%= @competencia.label %></p>

      <%= form_with model: @evento, url: admin_evento_escala_index_path, data: { turbo_frame: "_top" }, html: { class: "space-y-5" } do |f| %>
        <%= f.hidden_field :competencia_mensal_id %>
        <%= hidden_field_tag :tipo_servico_id, params[:tipo_servico_id] if params[:tipo_servico_id].present? %>
        <%= hidden_field_tag :sacerdote_id, params[:sacerdote_id] if params[:sacerdote_id].present? %>
        <%= hidden_field_tag :ministro_id, params[:ministro_id] if params[:ministro_id].present? %>
        <% if @evento.errors.any? %>
          <div class="rounded-lg bg-red-50 p-4 text-red-800 text-sm">
            <p class="font-medium mb-2"><%= pluralize(@evento.errors.count, "erro") %> impediram o cadastro:</p>
            <ul class="list-disc list-inside">
              <% @evento.errors.full_messages.each do |msg| %>
                <li><%= msg %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <%= render "form_fields", f: f %>

        <div class="flex gap-3 pt-4">
          <%= f.submit "Criar evento", class: "px-4 py-2.5 bg-slate-600 hover:bg-slate-700 text-white font-medium rounded-lg transition-colors cursor-pointer" %>
          <button type="button" data-action="click->modal#close" class="px-4 py-2.5 border border-stone-300 text-stone-700 hover:bg-stone-50 font-medium rounded-lg transition-colors">Cancelar</button>
        </div>
      <% end %>
    </div>
  </div>
</turbo-frame>
