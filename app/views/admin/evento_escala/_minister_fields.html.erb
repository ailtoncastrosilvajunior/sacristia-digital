<%# Utilizado em new, edit e form_modal %>
<% ministros = Ministro.ativos.ordenados_por_nome %>
<% coord_id = f.object.ministro_coordenador&.id %>
<div data-controller="minister-filter">
  <%= f.label :ministro_ids, "Ministros escalados", class: "block text-sm font-medium text-stone-700 mb-1" %>
  <p class="text-stone-500 text-xs mb-2">Marque os ministros que vão servir neste evento e indique qual é o coordenador</p>
  <% if ministros.any? %>
    <input type="search" data-minister-filter-target="input" data-action="input->minister-filter#filter" placeholder="Buscar ministro..." class="w-full mb-2 px-3 py-2 text-sm rounded-lg border border-stone-200 focus:ring-2 focus:ring-slate-500 focus:border-slate-500" autocomplete="off" />
    <div class="rounded-lg border border-stone-200 p-3 max-h-48 overflow-y-auto bg-white">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-2">
        <% ministros.each do |ministro| %>
          <div data-minister-filter-target="item" data-nome="<%= ministro.nome.downcase %>" class="flex items-center justify-between gap-2 p-2 rounded-lg hover:bg-stone-50 transition-colors">
            <label class="flex items-center gap-2 flex-1 cursor-pointer min-w-0">
              <%= f.check_box :ministro_ids, { multiple: true, checked: (f.object.ministro_ids || []).include?(ministro.id), class: "rounded border-stone-300 text-slate-600 focus:ring-slate-500 shrink-0" }, ministro.id, nil %>
              <span class="text-sm text-stone-800 truncate"><%= ministro.nome %></span>
            </label>
            <label class="flex items-center gap-1 shrink-0 cursor-pointer" title="Coordenador">
              <%= radio_button_tag "evento_escala[ministro_coordenador_id]", ministro.id, coord_id == ministro.id, class: "rounded-full border-stone-300 text-sky-600 focus:ring-sky-500" %>
              <span class="text-[10px] text-stone-500 hidden sm:inline">coord.</span>
            </label>
          </div>
        <% end %>
      </div>
      <p data-minister-filter-target="empty" class="hidden text-stone-500 text-sm py-2">Nenhum ministro encontrado.</p>
    </div>
  <% else %>
    <p class="text-amber-600 text-xs mt-1">Nenhum ministro ativo cadastrado.</p>
  <% end %>
</div>
