<turbo-frame id="evento_modal">
  <div class="bg-white rounded-2xl border border-stone-200/90 shadow-2xl shadow-slate-900/15 w-full max-h-[90vh] overflow-hidden flex flex-col ring-1 ring-stone-100">
    <div class="sticky top-0 z-10 flex items-start sm:items-center justify-between gap-3 px-5 py-4 sm:px-6 border-b border-stone-200/80 bg-gradient-to-r from-slate-900 via-slate-900 to-sky-950 text-white">
      <div class="min-w-0">
        <p class="text-[10px] font-semibold tracking-[0.18em] uppercase text-sky-300/80">Escalar evento</p>
        <h2 class="text-lg font-bold tracking-tight mt-0.5 truncate"><%= @evento.tipo_servico.nome %></h2>
        <p class="text-xs text-slate-400 mt-1 tabular-nums"><%= l(@evento.data, format: :short) %> · <%= l(@evento.horario, format: :time) %></p>
      </div>
      <button type="button" data-action="click->modal#close" class="shrink-0 p-2 rounded-xl text-slate-400 hover:text-white hover:bg-white/10 transition-colors" aria-label="Fechar">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </div>
    <div class="p-5 sm:p-6 overflow-y-auto flex-1 bg-gradient-to-b from-stone-50/80 to-white">
      <%= render "admin/evento_escala/escalar_form",
            evento: @evento,
            ministros_disponiveis: @ministros_disponiveis,
            ministros_escalados: @ministros_escalados,
            sacerdotes: @sacerdotes,
            return_params: @escalar_return_params,
            standalone: false %>
    </div>
  </div>
</turbo-frame>
