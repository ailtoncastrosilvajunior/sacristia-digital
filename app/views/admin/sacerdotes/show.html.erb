<% content_for :title, "#{@sacerdote.nome} — Sacerdotes" %>

<div class="min-h-full">
  <%# Header %>
  <div class="border-b border-stone-200 bg-white">
    <div class="px-6 py-5 sm:px-8">
      <div class="flex items-center justify-between gap-6">
        <div class="min-w-0">
          <p class="text-xs font-medium text-stone-500 uppercase tracking-wide">Sacerdote</p>
          <h1 class="mt-1 text-3xl font-semibold text-stone-900"><%= @sacerdote.nome %></h1>
          <div class="mt-2 flex items-center gap-4">
            <span class="inline-flex px-2.5 py-1 text-xs font-medium rounded <%= @sacerdote.ativo? ? 'bg-emerald-100 text-emerald-700' : 'bg-stone-100 text-stone-600' %>">
              <%= @sacerdote.ativo? ? "Ativo" : "Inativo" %>
            </span>
          </div>
        </div>
        <div class="flex gap-2 shrink-0">
          <%= link_to edit_admin_sacerdote_path(@sacerdote), class: "px-4 py-2 bg-stone-900 text-white text-sm font-medium rounded-lg hover:bg-stone-800 transition-colors" do %>
            Editar
          <% end %>
          <%= button_to admin_sacerdote_path(@sacerdote), method: :delete, data: { turbo_confirm: "Tem certeza?" }, class: "px-4 py-2 border border-red-300 text-red-700 text-sm font-medium rounded-lg hover:bg-red-50 transition-colors" do %>
            Excluir
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <div class="space-y-6 p-6 sm:p-8">
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <%# Coluna esquerda: Informações básicas %>
    <div class="lg:col-span-1">
      <div class="relative overflow-hidden rounded-lg bg-stone-50/60 border border-stone-200/40 shadow-sm p-6 space-y-6">
        <div class="absolute inset-x-0 top-0 h-1 bg-gradient-to-r from-amber-400 to-amber-300"></div>
        <div>
          <p class="text-xs font-medium text-stone-500 uppercase tracking-wide">Email</p>
          <p class="mt-2 text-stone-900"><%= @sacerdote.email || "—" %></p>
        </div>
        <% if @sacerdote.telefone.present? %>
          <div>
            <p class="text-xs font-medium text-stone-500 uppercase tracking-wide">Telefone</p>
            <p class="mt-2 text-stone-900"><%= @sacerdote.telefone %></p>
          </div>
        <% end %>
        <div class="border-t border-stone-200 pt-6">
          <p class="text-xs font-medium text-stone-500 uppercase tracking-wide">Forma de espórtula</p>
          <p class="mt-2">
            <% if @sacerdote.por_missa? %>
              <span class="inline-flex px-2.5 py-1 text-xs font-medium bg-blue-100 text-blue-700 rounded">Por missa</span>
            <% else %>
              <span class="inline-flex px-2.5 py-1 text-xs font-medium bg-purple-100 text-purple-700 rounded">Por período</span>
            <% end %>
          </p>
        </div>
        <div>
          <p class="text-xs font-medium text-stone-500 uppercase tracking-wide">Valor espórtula padrão</p>
          <p class="mt-2 text-lg font-bold text-stone-900"><%= number_to_currency(@sacerdote.valor_esportula_padrao) %></p>
        </div>
      </div>
    </div>

    <%# Coluna direita: Dados %>
    <div class="lg:col-span-2 space-y-6">
      <%# KPIs %>
      <div class="grid grid-cols-3 gap-4">
        <div class="relative overflow-hidden rounded-lg bg-stone-50/60 border border-stone-200/40 shadow-sm p-4 text-center">
          <div class="absolute inset-x-0 top-0 h-0.5 bg-sky-400"></div>
          <p class="text-xs font-medium text-stone-500 uppercase tracking-wide">Celebrações</p>
          <p class="mt-3 text-2xl font-bold text-stone-900"><%= @sacerdote.evento_escalas.count %></p>
        </div>
        <div class="relative overflow-hidden rounded-lg bg-stone-50/60 border border-stone-200/40 shadow-sm p-4 text-center">
          <div class="absolute inset-x-0 top-0 h-0.5 bg-emerald-400"></div>
          <p class="text-xs font-medium text-stone-500 uppercase tracking-wide">Espórtulas</p>
          <p class="mt-3 text-2xl font-bold text-stone-900"><%= @sacerdote.registro_esportulas.count %></p>
        </div>
        <div class="relative overflow-hidden rounded-lg bg-stone-50/60 border border-stone-200/40 shadow-sm p-4 text-center">
          <div class="absolute inset-x-0 top-0 h-0.5 bg-amber-400"></div>
          <p class="text-xs font-medium text-stone-500 uppercase tracking-wide">Total recebido</p>
          <p class="mt-3 text-lg font-bold text-stone-900"><%= number_to_currency(@sacerdote.registro_esportulas.sum(:valor)) %></p>
        </div>
      </div>

      <%# Tabela de espórtulas %>
      <div class="relative overflow-hidden rounded-lg bg-stone-50/60 border border-stone-200/40 shadow-sm">
        <div class="absolute inset-x-0 top-0 h-1 bg-gradient-to-r from-amber-300 to-orange-300"></div>
        <div class="border-b border-stone-200/40 bg-stone-50/80 px-6 py-4">
          <h3 class="font-semibold text-stone-900 text-sm">Últimas espórtulas</h3>
        </div>
        <% if @sacerdote.registro_esportulas.any? %>
          <table class="w-full text-sm">
            <tbody class="divide-y divide-stone-200">
              <% @sacerdote.registro_esportulas.order(data: :desc).limit(10).each do |registro| %>
                <tr class="hover:bg-stone-50">
                  <td class="px-6 py-3 text-stone-900 font-medium tabular-nums"><%= l(registro.data, format: :short) %></td>
                  <td class="px-6 py-3 text-stone-600"><%= number_to_currency(registro.valor) %></td>
                  <td class="px-6 py-3 text-right">
                    <span class="inline-flex px-2 py-0.5 text-xs font-medium <%= registro.status == 'pago' ? 'bg-emerald-100 text-emerald-700' : 'bg-amber-100 text-amber-700' %> rounded">
                      <%= registro.status == 'pago' ? 'Pago' : 'Pendente' %>
                    </span>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        <% else %>
          <div class="px-6 py-8 text-center text-stone-500 text-sm">Nenhuma espórtula registrada</div>
        <% end %>
      </div>
    </div>
  </div>
</div>
