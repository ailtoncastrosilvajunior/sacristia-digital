<% content_for :title, "#{@sacerdote.nome} — Sacerdotes" %>

<div class="space-y-6">
  <div>
    <%= link_to "← Sacerdotes", admin_sacerdotes_path, class: "text-sm text-stone-500 hover:text-stone-700 mb-3 inline-block" %>

    <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
      <div class="min-w-0">
        <p class="text-xs font-medium uppercase tracking-wide text-stone-400">Sacerdote</p>
        <h1 class="mt-1 text-2xl font-semibold text-stone-900 tracking-tight"><%= @sacerdote.nome %></h1>
        <p class="mt-1 text-stone-600 break-all"><%= @sacerdote.email.presence || "—" %></p>
      </div>
      <div class="flex flex-wrap items-center gap-2 shrink-0">
        <%= link_to new_admin_sacerdote_path,
            class: "inline-flex items-center justify-center gap-1.5 px-3 py-2 bg-emerald-600 hover:bg-emerald-700 text-white text-sm font-medium rounded-lg transition-colors shadow-sm shadow-emerald-900/10" do %>
          <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
          Novo sacerdote
        <% end %>
        <%= link_to "Editar", edit_admin_sacerdote_path(@sacerdote),
            class: "inline-flex items-center justify-center px-3 py-2 bg-slate-600 hover:bg-slate-700 text-white text-sm font-medium rounded-lg transition-colors" %>
        <%= button_to "Excluir", admin_sacerdote_path(@sacerdote), method: :delete, data: { turbo_confirm: "Tem certeza que deseja excluir este sacerdote?" },
            class: "inline-flex items-center justify-center px-3 py-2 border border-red-200 text-red-700 hover:bg-red-50 text-sm font-medium rounded-lg transition-colors bg-white cursor-pointer" %>
      </div>
    </div>
  </div>

  <div class="rounded-2xl border border-stone-200/80 bg-gradient-to-br from-slate-50 via-white to-stone-50/80 p-6 sm:p-8 shadow-sm ring-1 ring-stone-100/80">
    <div class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
      <div class="min-w-0">
        <p class="text-xs font-medium uppercase tracking-wide text-stone-500">Valor espórtula padrão</p>
        <p class="mt-1 text-3xl sm:text-4xl font-semibold tabular-nums text-stone-900"><%= number_to_currency(@sacerdote.valor_esportula_padrao) %></p>
      </div>
      <div class="flex flex-col items-start gap-2 sm:flex-row sm:items-center sm:gap-3 shrink-0">
        <span class="inline-flex px-3 py-1.5 text-xs font-semibold rounded-full border <%= @sacerdote.ativo? ? "bg-emerald-100 text-emerald-800 border-emerald-300" : "bg-stone-100 text-stone-600 border-stone-200" %>">
          <%= @sacerdote.ativo? ? "Ativo" : "Inativo" %>
        </span>
        <% if @sacerdote.por_missa? %>
          <span class="inline-flex px-3 py-1.5 text-xs font-semibold rounded-full border bg-sky-100 text-sky-800 border-sky-300">Por missa</span>
        <% else %>
          <span class="inline-flex px-3 py-1.5 text-xs font-semibold rounded-full border bg-violet-100 text-violet-800 border-violet-300">Por período</span>
        <% end %>
      </div>
    </div>
  </div>

  <div class="bg-white rounded-xl border border-stone-200 shadow-sm overflow-hidden divide-y divide-stone-100">
    <section class="p-6 sm:p-8">
      <h2 class="text-sm font-semibold text-stone-900 mb-4">Contato</h2>
      <dl class="grid grid-cols-1 gap-3 sm:grid-cols-2">
        <div class="rounded-xl border border-stone-100 bg-stone-50/50 px-4 py-3">
          <dt class="text-xs font-medium uppercase tracking-wide text-stone-500">E-mail</dt>
          <dd class="mt-1 text-stone-900 font-medium break-all"><%= @sacerdote.email.presence || "—" %></dd>
        </div>
        <div class="rounded-xl border border-stone-100 bg-stone-50/50 px-4 py-3">
          <dt class="text-xs font-medium uppercase tracking-wide text-stone-500">Telefone</dt>
          <dd class="mt-1 text-stone-900 font-medium tabular-nums"><%= @sacerdote.telefone.presence || "—" %></dd>
        </div>
      </dl>
    </section>

    <section class="p-6 sm:p-8">
      <h2 class="text-sm font-semibold text-stone-900 mb-4">Indicadores</h2>
      <% celebracoes_ct = @sacerdote.evento_escalas.count %>
      <% esportulas_ct = @sacerdote.registro_esportulas.count %>
      <% total_recebido = @sacerdote.registro_esportulas.sum(:valor) %>
      <div class="grid grid-cols-3 gap-2 sm:gap-4">
        <div class="group relative min-w-0 overflow-hidden rounded-2xl bg-white p-3 sm:p-5 shadow-sm ring-1 ring-stone-200/80 hover:ring-sky-200/60 transition-all">
          <div class="absolute -right-4 -top-4 h-24 w-24 rounded-full bg-sky-500/10 blur-2xl group-hover:bg-sky-500/15 transition-colors" aria-hidden="true"></div>
          <p class="relative text-[10px] sm:text-xs font-semibold uppercase tracking-wider text-stone-500 truncate">Celebrações</p>
          <p class="relative mt-1.5 sm:mt-2 text-xl sm:text-3xl font-bold tabular-nums text-sky-800"><%= celebracoes_ct %></p>
          <p class="relative mt-1 text-[10px] sm:text-xs text-stone-500 leading-snug line-clamp-2">Na escala como sacerdote</p>
        </div>
        <div class="group relative min-w-0 overflow-hidden rounded-2xl bg-white p-3 sm:p-5 shadow-sm ring-1 ring-stone-200/80 hover:ring-emerald-200/60 transition-all">
          <div class="absolute -right-4 -top-4 h-24 w-24 rounded-full bg-emerald-500/10 blur-2xl group-hover:bg-emerald-500/15 transition-colors" aria-hidden="true"></div>
          <p class="relative text-[10px] sm:text-xs font-semibold uppercase tracking-wider text-stone-500 truncate">Espórtulas</p>
          <p class="relative mt-1.5 sm:mt-2 text-xl sm:text-3xl font-bold tabular-nums text-emerald-700"><%= esportulas_ct %></p>
          <p class="relative mt-1 text-[10px] sm:text-xs text-stone-500 leading-snug line-clamp-2">Registros de espórtula</p>
        </div>
        <div class="group relative min-w-0 overflow-hidden rounded-2xl bg-white p-3 sm:p-5 shadow-sm ring-1 ring-stone-200/80 hover:ring-violet-200/60 transition-all">
          <div class="absolute -right-4 -top-4 h-24 w-24 rounded-full bg-violet-500/10 blur-2xl group-hover:bg-violet-500/15 transition-colors" aria-hidden="true"></div>
          <p class="relative text-[10px] sm:text-xs font-semibold uppercase tracking-wider text-stone-500 truncate">Total recebido</p>
          <p class="relative mt-1.5 sm:mt-2 text-sm sm:text-2xl font-bold tabular-nums text-violet-700 leading-tight break-words"><%= number_to_currency(total_recebido) %></p>
          <p class="relative mt-1 text-[10px] sm:text-xs text-stone-500 leading-snug line-clamp-2">Soma dos valores registrados</p>
        </div>
      </div>
    </section>

    <section class="p-6 sm:p-8">
      <h2 class="text-sm font-semibold text-stone-900 mb-4">Últimas espórtulas</h2>
      <% if @sacerdote.registro_esportulas.any? %>
        <div class="rounded-xl border border-stone-100 overflow-hidden">
          <table class="min-w-full text-sm">
            <tbody class="divide-y divide-stone-100">
              <% @sacerdote.registro_esportulas.order(data: :desc).limit(10).each do |registro| %>
                <tr class="hover:bg-stone-50/80">
                  <td class="px-4 py-3 text-stone-900 font-medium tabular-nums"><%= l(registro.data, format: :short) %></td>
                  <td class="px-4 py-3 text-stone-600 tabular-nums"><%= number_to_currency(registro.valor) %></td>
                  <td class="px-4 py-3 text-right">
                    <span class="inline-flex px-2 py-0.5 text-xs font-semibold rounded-full border <%= registro.status == "pago" ? "bg-emerald-100 text-emerald-800 border-emerald-200" : "bg-amber-100 text-amber-800 border-amber-200" %>">
                      <%= registro.status == "pago" ? "Pago" : "Pendente" %>
                    </span>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <p class="text-sm text-stone-500 text-center py-8 rounded-xl border border-dashed border-stone-200 bg-stone-50/40">Nenhuma espórtula registrada</p>
      <% end %>
    </section>
  </div>
</div>
