<div class="space-y-6">
  <div class="flex items-center justify-between">
    <div>
      <%= link_to "← Sacerdotes", admin_sacerdotes_path, class: "text-sm text-stone-500 hover:text-stone-700 mb-2 block" %>
      <h1 class="text-2xl font-semibold text-stone-800"><%= @sacerdote.nome %></h1>
      <p class="text-stone-500 mt-1">Detalhes do sacerdote</p>
    </div>
    <div class="flex gap-2">
      <%= link_to "Editar", edit_admin_sacerdote_path(@sacerdote),
          class: "px-4 py-2 bg-slate-600 hover:bg-slate-700 text-white font-medium rounded-lg transition-colors" %>
      <%= button_to "Excluir", admin_sacerdote_path(@sacerdote), method: :delete, data: { turbo_confirm: "Tem certeza que deseja excluir este sacerdote?" },
          class: "px-4 py-2 border border-red-300 text-red-600 hover:bg-red-50 font-medium rounded-lg transition-colors" %>
    </div>
  </div>

  <div class="bg-white rounded-xl border border-stone-200 shadow-sm p-6">
    <dl class="grid grid-cols-1 gap-4 sm:grid-cols-2">
      <div>
        <dt class="text-sm font-medium text-stone-500">Nome</dt>
        <dd class="mt-1 text-stone-800"><%= @sacerdote.nome %></dd>
      </div>
      <div>
        <dt class="text-sm font-medium text-stone-500">Email</dt>
        <dd class="mt-1 text-stone-800"><%= @sacerdote.email || "—" %></dd>
      </div>
      <div>
        <dt class="text-sm font-medium text-stone-500">Telefone</dt>
        <dd class="mt-1 text-stone-800"><%= @sacerdote.telefone || "—" %></dd>
      </div>
      <div>
        <dt class="text-sm font-medium text-stone-500">Forma de espórtula</dt>
        <dd class="mt-1 text-stone-800"><%= @sacerdote.por_missa? ? "Por missa" : "Por período" %></dd>
      </div>
      <div>
        <dt class="text-sm font-medium text-stone-500">Valor espórtula padrão</dt>
        <dd class="mt-1 text-stone-800"><%= number_to_currency(@sacerdote.valor_esportula_padrao) %></dd>
      </div>
      <div>
        <dt class="text-sm font-medium text-stone-500">Status</dt>
        <dd class="mt-1">
          <span class="inline-flex px-2 py-1 text-xs font-medium rounded-full <%= @sacerdote.ativo? ? 'bg-emerald-100 text-emerald-800' : 'bg-stone-100 text-stone-600' %>">
            <%= @sacerdote.ativo? ? "Ativo" : "Inativo" %>
          </span>
        </dd>
      </div>
    </dl>
  </div>
</div>
