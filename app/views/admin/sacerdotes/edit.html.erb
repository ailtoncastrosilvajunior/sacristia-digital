<div class="space-y-6">
  <div>
    <%= link_to "← Sacerdotes", admin_sacerdotes_path, class: "text-sm text-stone-500 hover:text-stone-700 mb-2 block" %>
    <h1 class="text-2xl font-semibold text-stone-800">Editar sacerdote</h1>
    <p class="text-stone-500 mt-1"><%= @sacerdote.nome %></p>
  </div>

  <div class="bg-white rounded-xl border border-stone-200 shadow-sm p-6 max-w-2xl">
    <%= form_with model: [:admin, @sacerdote], local: true, html: { class: "space-y-5" } do |f| %>
      <% if @sacerdote.errors.any? %>
        <div class="rounded-lg bg-red-50 p-4 text-red-800 text-sm">
          <p class="font-medium mb-2"><%= pluralize(@sacerdote.errors.count, "erro") %> impediram a atualização:</p>
          <ul class="list-disc list-inside">
            <% @sacerdote.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div>
        <%= f.label :nome, class: "block text-sm font-medium text-stone-700 mb-1" %>
        <%= f.text_field :nome, class: "w-full px-4 py-2.5 rounded-lg border border-stone-300 focus:ring-2 focus:ring-slate-500/20 focus:border-slate-500", placeholder: "Nome completo", autofocus: true %>
      </div>

      <div>
        <%= f.label :email, class: "block text-sm font-medium text-stone-700 mb-1" %>
        <%= f.email_field :email, class: "w-full px-4 py-2.5 rounded-lg border border-stone-300 focus:ring-2 focus:ring-slate-500/20 focus:border-slate-500", placeholder: "email@exemplo.com" %>
      </div>

      <div>
        <%= f.label :telefone, class: "block text-sm font-medium text-stone-700 mb-1" %>
        <%= f.telephone_field :telefone, class: "w-full px-4 py-2.5 rounded-lg border border-stone-300 focus:ring-2 focus:ring-slate-500/20 focus:border-slate-500", placeholder: "(00) 00000-0000" %>
      </div>

      <div>
        <%= f.label :forma_esportula, "Forma de espórtula", class: "block text-sm font-medium text-stone-700 mb-1" %>
        <%= f.select :forma_esportula, Sacerdote::FORMAS_ESPORTULA.map { |f| [f == "por_missa" ? "Por missa" : "Por período", f] },
            {}, class: "w-full px-4 py-2.5 rounded-lg border border-stone-300 focus:ring-2 focus:ring-slate-500/20 focus:border-slate-500" %>
      </div>

      <div>
        <%= f.label :valor_esportula_padrao, "Valor espórtula padrão (R$)", class: "block text-sm font-medium text-stone-700 mb-1" %>
        <%= f.number_field :valor_esportula_padrao, step: 0.01, min: 0, class: "w-full px-4 py-2.5 rounded-lg border border-stone-300 focus:ring-2 focus:ring-slate-500/20 focus:border-slate-500", placeholder: "0,00" %>
      </div>

      <div class="flex items-center">
        <%= f.check_box :ativo, class: "rounded border-stone-300 text-slate-600 focus:ring-slate-500" %>
        <%= f.label :ativo, "Ativo", class: "ml-2 text-sm text-stone-700" %>
      </div>

      <div class="flex gap-3 pt-4">
        <%= f.submit "Salvar", class: "px-4 py-2.5 bg-slate-600 hover:bg-slate-700 text-white font-medium rounded-lg transition-colors cursor-pointer" %>
        <%= link_to "Cancelar", admin_sacerdote_path(@sacerdote), class: "px-4 py-2.5 border border-stone-300 text-stone-700 hover:bg-stone-50 font-medium rounded-lg transition-colors" %>
      </div>
    <% end %>
  </div>
</div>
