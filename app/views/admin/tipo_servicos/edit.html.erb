<div class="space-y-6">
  <div>
    <%= link_to "← Tipos de Serviço", admin_tipo_servicos_path, class: "text-sm text-stone-500 hover:text-stone-700 mb-2 block" %>
    <h1 class="text-2xl font-semibold text-stone-800">Editar tipo de serviço</h1>
    <p class="text-stone-500 mt-1"><%= @tipo_servico.nome %></p>
  </div>

  <div class="bg-white rounded-xl border border-stone-200 shadow-sm p-6 max-w-2xl">
    <%= form_with model: [:admin, @tipo_servico], local: true, html: { class: "space-y-5" } do |f| %>
      <% if @tipo_servico.errors.any? %>
        <div class="rounded-lg bg-red-50 p-4 text-red-800 text-sm">
          <p class="font-medium mb-2"><%= pluralize(@tipo_servico.errors.count, "erro") %> impediram a atualização:</p>
          <ul class="list-disc list-inside">
            <% @tipo_servico.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div>
        <%= f.label :nome, class: "block text-sm font-medium text-stone-700 mb-1" %>
        <%= f.text_field :nome, class: "w-full px-4 py-2.5 rounded-lg border border-stone-300 focus:ring-2 focus:ring-slate-500/20 focus:border-slate-500", placeholder: "Ex: Missa Dominical", autofocus: true %>
      </div>

      <div>
        <%= f.label :tipo_escala, "Tipo de escala", class: "block text-sm font-medium text-stone-700 mb-1" %>
        <%= f.select :tipo_escala, TipoServico::TIPOS_ESCALA.map { |t| [t == "ordinaria" ? "Ordinário" : "Extra", t] },
            {}, class: "w-full px-4 py-2.5 rounded-lg border border-stone-300 focus:ring-2 focus:ring-slate-500/20 focus:border-slate-500" %>
      </div>

      <div>
        <%= f.label :cor_etiqueta, "Cor da etiqueta", class: "block text-sm font-medium text-stone-700 mb-1" %>
        <%= f.color_field :cor_etiqueta, value: @tipo_servico.cor_etiqueta || "#64748b", class: "w-full h-10 rounded-lg border border-stone-300 cursor-pointer" %>
      </div>

      <div class="flex items-center">
        <%= f.check_box :ativo, class: "rounded border-stone-300 text-slate-600 focus:ring-slate-500" %>
        <%= f.label :ativo, "Ativo", class: "ml-2 text-sm text-stone-700" %>
      </div>

      <div class="flex gap-3 pt-4">
        <%= f.submit "Salvar", class: "px-4 py-2.5 bg-slate-600 hover:bg-slate-700 text-white font-medium rounded-lg transition-colors cursor-pointer" %>
        <%= link_to "Cancelar", admin_tipo_servico_path(@tipo_servico), class: "px-4 py-2.5 border border-stone-300 text-stone-700 hover:bg-stone-50 font-medium rounded-lg transition-colors" %>
      </div>
    <% end %>
  </div>
</div>
