<%= paginator.render do %>
  <nav class="inline-flex flex-wrap items-center justify-center gap-1 rounded-2xl border border-stone-200/90 bg-white p-1.5 shadow-md shadow-stone-900/5 ring-1 ring-stone-100" role="navigation" aria-label="Paginação">
    <%= first_page_tag unless current_page.first? %>
    <%= prev_page_tag unless current_page.first? %>
    <% each_page do |page| %>
      <% if page.left_outer? || page.right_outer? || page.inside_window? %>
        <%= page_tag page %>
      <% elsif !page.was_truncated? %>
        <%= gap_tag %>
      <% end %>
    <% end %>
    <%= next_page_tag unless current_page.last? %>
    <%= last_page_tag unless current_page.last? %>
  </nav>
<% end %>
