<% if page.current? %>
  <span class="inline-flex min-w-[2.5rem] h-10 items-center justify-center rounded-xl bg-gradient-to-r from-sky-600 to-indigo-600 text-sm font-bold text-white shadow-md shadow-sky-900/20 ring-1 ring-white/20" aria-current="page"><%= page %></span>
<% else %>
  <%= link_to page, url, remote: remote, rel: page.rel, class: "inline-flex min-w-[2.5rem] h-10 items-center justify-center rounded-xl text-sm font-semibold text-stone-600 hover:bg-sky-50 hover:text-sky-800 transition-colors" %>
<% end %>
