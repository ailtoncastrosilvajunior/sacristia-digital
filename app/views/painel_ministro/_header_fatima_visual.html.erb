<%# Nossa Senhora de Fátima — mobile: retrato (rosto mais completo); lg+: faixa lateral do dashboard. %>
<div class="relative shrink-0 overflow-hidden rounded-xl ring-2 ring-white/15 shadow-lg shadow-violet-950/30
            h-[13.5rem] w-[7.875rem] sm:h-[14.25rem] sm:w-[8.5rem]
            max-lg:mx-0
            lg:h-[11rem] lg:w-[9rem] xl:h-[12rem] xl:w-[9.75rem] lg:mx-0" role="presentation">
  <%= image_tag "nossa-senhora-fatima.png",
        class: "absolute inset-0 h-full w-full object-cover object-[50%_22%] sm:object-[50%_20%] lg:object-[30%_32%]",
        alt: "Nossa Senhora de Fátima",
        loading: "eager",
        decoding: "async" %>
  <div class="absolute inset-0 bg-gradient-to-r from-transparent via-transparent to-violet-950/50 max-lg:to-violet-950/35 lg:bg-gradient-to-r lg:from-transparent lg:via-violet-950/35 lg:to-violet-950/80" aria-hidden="true"></div>
</div>
