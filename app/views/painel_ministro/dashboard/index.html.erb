<% content_for :title, "Minha escala — Sacristia Digital" %>
<div class="min-h-full">
  <% primeiro_nome = (current_user.nome.presence || current_user.email.to_s).split(/\s+/).first %>

  <% if @ministro_record.blank? %>
    <div class="rounded-2xl border border-amber-200 bg-amber-50 p-8 text-center text-amber-900">
      <p class="font-medium">Conta sem vínculo de ministro</p>
      <p class="text-sm mt-2 opacity-90">Peça ao administrador para associar seu usuário ao cadastro de ministro.</p>
    </div>
  <% elsif @competencias.empty? %>
    <div class="relative overflow-hidden rounded-2xl border border-violet-200/80 bg-gradient-to-br from-violet-950 via-indigo-900 to-slate-900 text-white shadow-xl mb-8">
      <div class="absolute inset-0 opacity-[0.06]" style="background-image: url('data:image/svg+xml,%3Csvg width=\'60\' height=\'60\' viewBox=\'0 0 60 60\' xmlns=\'http://www.w3.org/2000/svg\'%3E%3Cg fill=\'none\' fill-rule=\'evenodd\'%3E%3Cg fill=\'%23ffffff\' fill-opacity=\'1\'%3E%3Cpath d=\'M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z\'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>
      <div class="relative grid grid-cols-[minmax(0,1fr)] gap-x-3 gap-y-3 px-5 py-5 sm:px-6 sm:gap-x-4 lg:flex lg:items-center lg:gap-6 lg:py-5 lg:px-8">
        <div class="min-w-0 flex flex-col justify-center text-left lg:flex-1 lg:text-center">
          <div class="lg:max-w-lg lg:mx-auto">
            <p class="text-violet-300/90 text-xs sm:text-sm font-medium tracking-wide uppercase">Olá, <%= primeiro_nome %></p>
            <h1 class="text-xl sm:text-2xl lg:text-3xl font-bold tracking-tight mt-1.5">Ainda não há escala com seu nome</h1>
            <p class="mt-2 text-violet-100/90 text-sm leading-snug lg:leading-relaxed">Quando a coordenação publicar a escala e você estiver designado, seus dias aparecerão aqui por competência.</p>
          </div>
        </div>
      </div>
    </div>
  <% elsif @competencia.nil? %>
    <div class="rounded-2xl border border-amber-200 bg-amber-50 p-8 text-center text-amber-900">
      <p class="font-medium">Competência não encontrada.</p>
      <p class="text-sm mt-1 opacity-90">Escolha outra no menu acima.</p>
    </div>
  <% else %>
    <% comp = @competencia %>
    <% s = @stats %>
    <% mid = @ministro_record.id %>

    <div class="relative overflow-hidden rounded-2xl border border-violet-200/80 bg-gradient-to-br from-violet-950 via-indigo-900 to-slate-900 text-white shadow-xl mb-8">
      <div class="absolute inset-0 opacity-[0.07]" style="background-image: url('data:image/svg+xml,%3Csvg width=\'60\' height=\'60\' viewBox=\'0 0 60 60\' xmlns=\'http://www.w3.org/2000/svg\'%3E%3Cg fill=\'none\' fill-rule=\'evenodd\'%3E%3Cg fill=\'%23ffffff\' fill-opacity=\'1\'%3E%3Cpath d=\'M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z\'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>
      <%# Mobile: 2 colunas — retrato à esquerda | texto + competência à direita. lg+: 3 colunas (inalterado). %>
      <div class="relative grid grid-cols-[minmax(0,1fr)] grid-rows-[auto_auto] gap-x-3 gap-y-3.5 px-5 py-5 sm:px-6 sm:gap-x-4 sm:gap-y-4
                  lg:grid-cols-[auto_minmax(0,1fr)_10.5rem] lg:grid-rows-1 lg:items-center lg:gap-5 lg:py-5 lg:px-8
                  xl:grid-cols-[auto_minmax(0,1fr)_11.25rem] xl:gap-7 xl:pr-8">
        <div class="col-start-1 row-start-1 min-w-0 text-left">
          <p class="text-violet-300/90 text-xs sm:text-sm font-medium tracking-wide uppercase">Minha escala</p>
          <h1 class="text-xl sm:text-2xl lg:text-3xl font-bold tracking-tight mt-1 lg:mt-1.5">Olá, <%= primeiro_nome %></h1>
          <p class="mt-2 text-violet-100/85 text-sm leading-snug lg:leading-relaxed">Acompanhe os dias em que você serve, troque de competência e use o mapa para não perder nenhuma celebração.</p>
          <% if @ministro_record.nome.present? %>
            <p class="mt-2 text-xs text-violet-300/80">Cadastro: <span class="font-medium text-white"><%= @ministro_record.nome %></span></p>
          <% end %>
        </div>
        <div class="col-start-2 row-start-2 min-w-0 w-full lg:col-start-3 lg:row-start-1 flex flex-col justify-center">
          <%= form_with url: ministro_root_path, method: :get, local: true, class: "space-y-1.5" do %>
            <label for="ministro_dash_competencia" class="block text-xs font-medium text-violet-300/90 uppercase tracking-wider">Competência</label>
            <%= select_tag :competencia_mensal_id,
                  options_from_collection_for_select(@competencias, :id, :label, comp.id),
                  { id: "ministro_dash_competencia", class: "w-full rounded-xl border-0 bg-white/10 text-white ring-1 ring-white/20 px-3 py-2.5 text-sm font-medium focus:ring-2 focus:ring-violet-400 focus:outline-none [&>option]:text-slate-900",
                    onchange: "this.form.requestSubmit()" } %>
            <noscript>
              <%= submit_tag "Atualizar", class: "w-full rounded-xl bg-violet-500 hover:bg-violet-400 px-3 py-2 text-sm font-semibold text-white" %>
            </noscript>
          <% end %>
        </div>
      </div>
    </div>

    <div class="flex flex-wrap items-center justify-between gap-4 mb-6">
      <div>
        <h2 class="text-xl font-semibold text-stone-900"><%= comp.label %></h2>
        <p class="text-sm text-stone-500 mt-1"><%= s[:dias_com_servico] %> <%= s[:dias_com_servico] == 1 ? "dia" : "dias" %> com você na escala neste mês</p>
      </div>
      <div class="flex flex-wrap gap-2">
        <%= link_to ministro_meus_servicos_path, class: "inline-flex items-center gap-2 px-4 py-2.5 rounded-xl bg-violet-700 text-white text-sm font-semibold hover:bg-violet-800 transition-colors shadow-sm" do %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
          Lista de serviços
        <% end %>
      </div>
    </div>

    <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 sm:gap-4 mb-8">
      <div class="group relative overflow-hidden rounded-2xl bg-white p-5 shadow-sm ring-1 ring-stone-200/80 hover:ring-violet-200/60 transition-all">
        <div class="absolute -right-4 -top-4 h-24 w-24 rounded-full bg-violet-500/10 blur-2xl"></div>
        <p class="text-xs font-semibold uppercase tracking-wider text-stone-500">Serviços</p>
        <p class="mt-2 text-3xl font-bold tabular-nums text-stone-900"><%= s[:total] %></p>
        <p class="mt-1 text-xs text-stone-500">Nesta competência</p>
      </div>
      <div class="group relative overflow-hidden rounded-2xl bg-white p-5 shadow-sm ring-1 ring-stone-200/80 hover:ring-amber-200/60 transition-all">
        <div class="absolute -right-4 -top-4 h-24 w-24 rounded-full bg-amber-500/10 blur-2xl"></div>
        <p class="text-xs font-semibold uppercase tracking-wider text-stone-500">Coordenação</p>
        <p class="mt-2 text-3xl font-bold tabular-nums text-amber-700"><%= s[:como_coord] %></p>
        <p class="mt-1 text-xs text-stone-500">Como coordenador</p>
      </div>
      <div class="group relative overflow-hidden rounded-2xl bg-white p-5 shadow-sm ring-1 ring-stone-200/80 hover:ring-fuchsia-200/60 transition-all">
        <div class="absolute -right-4 -top-4 h-24 w-24 rounded-full bg-fuchsia-500/10 blur-2xl"></div>
        <p class="text-xs font-semibold uppercase tracking-wider text-stone-500">Adoração</p>
        <p class="mt-2 text-3xl font-bold tabular-nums text-fuchsia-700"><%= s[:como_ador] %></p>
        <p class="mt-1 text-xs text-stone-500">Função marcada</p>
      </div>
      <div class="group relative overflow-hidden rounded-2xl bg-white p-5 shadow-sm ring-1 ring-stone-200/80 hover:ring-emerald-200/60 transition-all">
        <div class="absolute -right-4 -top-4 h-24 w-24 rounded-full bg-emerald-500/10 blur-2xl"></div>
        <p class="text-xs font-semibold uppercase tracking-wider text-stone-500">Confirmação</p>
        <div class="mt-2 flex flex-wrap gap-x-3 gap-y-1 text-sm font-semibold tabular-nums">
          <span class="text-emerald-600"><%= s[:confirmados] %> ok</span>
          <span class="text-amber-600"><%= s[:pendentes_confirmacao] %> pend.</span>
        </div>
        <p class="mt-1 text-xs text-stone-500">Sua presença</p>
      </div>
    </div>

    <div class="grid grid-cols-1 xl:grid-cols-12 gap-6 lg:gap-8">
      <div class="xl:col-span-7 xl:order-2 space-y-4">
        <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-3">
          <div>
            <h3 class="text-lg font-semibold text-stone-900">Próximas celebrações</h3>
            <% if @lista_desde %>
              <p class="text-xs text-violet-700 font-medium mt-1">A partir de <span class="tabular-nums"><%= l(@lista_desde, format: :long) %></span> — clique em outro dia no calendário para mudar.</p>
            <% else %>
              <p class="text-xs text-stone-500 mt-1">A partir de <span class="font-medium text-stone-700">hoje</span> (<span class="tabular-nums"><%= l(Date.current, format: :short) %></span>).</p>
            <% end %>
          </div>
          <% if params[:lista_desde].present? %>
            <%= link_to ministro_root_path(competencia_mensal_id: comp.id), class: "inline-flex shrink-0 items-center gap-1.5 px-3 py-2 rounded-xl text-xs font-semibold bg-stone-100 text-stone-800 hover:bg-stone-200 border border-stone-200 transition-colors" do %>
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
              Voltar a partir de hoje
            <% end %>
          <% end %>
        </div>

        <div class="rounded-2xl border border-stone-200/80 bg-white shadow-sm overflow-hidden">
          <% if @proximos.empty? %>
            <div class="p-10 text-center text-stone-500 text-sm">
              <% if @lista_desde %>
                Nada a partir de <span class="font-medium text-stone-700 tabular-nums"><%= l(@lista_desde) %></span> nesta competência.
              <% else %>
                Não há próximos serviços com você neste mês (ou todos já passaram).
              <% end %>
            </div>
          <% else %>
            <ul class="divide-y divide-stone-100">
              <% @proximos.each do |ev| %>
                <% em = ev.escala_ministros.find { |x| x.ministro_id == mid } %>
                <% cor = ev.tipo_servico.cor_etiqueta.presence || "#64748b" %>
                <li class="flex flex-col sm:flex-row sm:items-stretch gap-0 hover:bg-violet-50/40 transition-colors">
                  <div class="sm:w-28 shrink-0 flex sm:flex-col justify-center sm:justify-start gap-1 sm:gap-0 px-4 py-3 sm:py-4 bg-violet-50/50 sm:bg-violet-50/30 border-b sm:border-b-0 sm:border-r border-stone-100">
                    <span class="text-xs font-bold uppercase text-violet-600/90"><%= I18n.t("date.abbr_day_names")[ev.data.wday] %></span>
                    <span class="text-sm font-semibold text-stone-900 tabular-nums"><%= l(ev.data, format: :short) %></span>
                    <span class="text-xs text-stone-600 tabular-nums"><%= l(ev.horario, format: :time) %></span>
                  </div>
                  <div class="flex-1 min-w-0 px-4 py-3 sm:py-4 flex flex-col sm:flex-row sm:items-center gap-3">
                    <div class="flex-1 min-w-0">
                      <div class="flex items-center gap-2 flex-wrap">
                        <span class="inline-flex px-2 py-0.5 text-xs font-semibold rounded-md border" style="background-color: <%= cor %>22; border-color: <%= cor %>55; color: #1e293b;"><%= ev.tipo_servico.nome %></span>
                        <% if em&.coordenador? %><span class="text-[10px] font-bold uppercase tracking-wide text-amber-700 bg-amber-50 px-1.5 py-0.5 rounded">Coord.</span><% end %>
                        <% if em&.adoracao? %><span class="text-[10px] font-bold uppercase tracking-wide text-fuchsia-700 bg-fuchsia-50 px-1.5 py-0.5 rounded">Ador.</span><% end %>
                        <% if em&.confirmado? %>
                          <span class="text-[10px] font-bold uppercase tracking-wide text-emerald-600">Confirmado</span>
                        <% else %>
                          <span class="text-[10px] font-bold uppercase tracking-wide text-amber-600">Confirme presença</span>
                        <% end %>
                      </div>
                      <p class="mt-1 text-sm text-stone-600 truncate"><%= ev.sacerdote&.nome || tag.span("Sacerdote a definir", class: "text-stone-400 italic") %></p>
                    </div>
                    <div class="flex shrink-0 gap-2">
                      <%= link_to "Detalhes", ministro_servico_path(ev), class: "inline-flex items-center justify-center px-3 py-1.5 rounded-lg text-xs font-semibold bg-violet-600 text-white hover:bg-violet-700 transition-colors" %>
                    </div>
                  </div>
                </li>
              <% end %>
            </ul>
          <% end %>
        </div>

        <% if @recentes_passados.any? %>
          <details class="group rounded-2xl border border-stone-200 bg-white shadow-sm overflow-hidden">
            <summary class="cursor-pointer list-none px-4 py-3 flex items-center justify-between text-sm font-medium text-stone-700 hover:bg-stone-50">
              <span>Últimos serviços realizados</span>
              <svg class="w-4 h-4 text-stone-400 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </summary>
            <ul class="border-t border-stone-100 divide-y divide-stone-50 text-sm text-stone-600 px-4 py-2">
              <% @recentes_passados.each do |ev| %>
                <% em = ev.escala_ministros.find { |x| x.ministro_id == mid } %>
                <li class="py-2 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-1">
                  <span class="tabular-nums text-stone-500"><%= l(ev.data) %> <%= l(ev.horario, format: :time) %></span>
                  <span class="font-medium text-stone-800 truncate"><%= ev.tipo_servico.nome %></span>
                  <span class="text-xs text-stone-500">
                    <%= em&.coordenador? ? "Coord. " : "" %><%= em&.adoracao? ? "Ador. " : "" %>
                  </span>
                </li>
              <% end %>
            </ul>
          </details>
        <% end %>
      </div>

      <div class="xl:col-span-5 xl:order-1 space-y-4">
        <div class="flex flex-col gap-1">
          <div class="flex items-center justify-between gap-2">
            <h3 class="text-lg font-semibold text-stone-900">Seus dias no mês</h3>
            <span class="text-xs text-stone-500 shrink-0">Quanto mais escuro, mais serviços seu</span>
          </div>
          <p class="text-xs text-stone-600 leading-relaxed">Clique em um <strong class="text-stone-800">dia</strong> em que você comparece para ver a lista a partir dessa data.</p>
        </div>
        <div class="rounded-2xl border border-stone-200/80 bg-white p-4 sm:p-5 shadow-sm space-y-4">
          <div class="grid grid-cols-7 gap-1 text-center text-[10px] font-semibold text-stone-400 mb-2">
            <% I18n.t("date.abbr_day_names").each do |nome| %><span class="truncate"><%= nome.first(3) %></span><% end %>
          </div>
          <% lead = comp.periodo.wday %>
          <div class="grid grid-cols-7 gap-1">
            <% lead.times do %>
              <div class="aspect-square rounded-lg bg-transparent min-h-[2rem]" aria-hidden="true"></div>
            <% end %>
            <% @heatmap.each do |cell| %>
              <% c = cell[:count] %>
              <% d = cell[:data] %>
              <% intensity = c.zero? ? 0 : [c, 4].min %>
              <% bg = case intensity
                      when 0 then "bg-stone-100"
                      when 1 then "bg-violet-200"
                      when 2 then "bg-violet-400"
                      when 3 then "bg-violet-600"
                      else "bg-violet-900"
                      end %>
              <% txt = intensity >= 2 ? "text-white" : "text-stone-700" %>
              <% selected = @lista_desde == d %>
              <% sel_ring = selected ? "ring-2 ring-violet-600 ring-offset-2 z-[1] scale-[1.02]" : "" %>
              <% link_cls = "aspect-square rounded-lg #{bg} flex flex-col items-center justify-center text-[10px] font-bold #{txt} shadow-sm ring-1 ring-black/5 min-h-[2rem] transition-transform hover:scale-[1.04] focus:outline-none focus-visible:ring-2 focus-visible:ring-violet-500 focus-visible:ring-offset-2 #{sel_ring}" %>
              <% if c.positive? %>
                <% dia_title = c == 1 ? "#{l(d)}: você em 1 serviço" : "#{l(d)}: você em #{c} serviços" %>
                <%= link_to ministro_root_path(competencia_mensal_id: comp.id, lista_desde: d.strftime("%Y-%m-%d")),
                      class: link_cls,
                      title: dia_title do %>
                  <span class="tabular-nums opacity-90"><%= d.day %></span>
                  <span class="text-[9px] opacity-80 tabular-nums"><%= c %></span>
                <% end %>
              <% else %>
                <div class="<%= link_cls %> cursor-default opacity-80" title="<%= l(d) %>: sem escala">
                  <span class="tabular-nums opacity-60"><%= d.day %></span>
                </div>
              <% end %>
            <% end %>
          </div>
          <div class="flex flex-wrap items-center gap-3 text-xs text-stone-500 pt-1 border-t border-stone-100">
            <span class="inline-flex items-center gap-1.5"><span class="h-3 w-3 rounded bg-stone-100 ring-1 ring-stone-200"></span> Sem você</span>
            <span class="inline-flex items-center gap-1.5"><span class="h-3 w-3 rounded bg-violet-200"></span> 1</span>
            <span class="inline-flex items-center gap-1.5"><span class="h-3 w-3 rounded bg-violet-400"></span> 2</span>
            <span class="inline-flex items-center gap-1.5"><span class="h-3 w-3 rounded bg-violet-600"></span> 3+</span>
          </div>

          <% if @picos_mes.present? %>
            <div class="rounded-xl bg-violet-50/80 border border-violet-100 p-3">
              <p class="text-[10px] font-bold uppercase tracking-wider text-violet-800 mb-2">Dias mais cheios para você</p>
              <ul class="space-y-1.5">
                <% @picos_mes.each do |dia, n| %>
                  <li class="flex items-center justify-between text-sm">
                    <%= link_to ministro_root_path(competencia_mensal_id: comp.id, lista_desde: dia.strftime("%Y-%m-%d")), class: "text-violet-700 font-medium hover:underline tabular-nums" do %>
                      <%= l(dia, format: :short) %>
                    <% end %>
                    <span class="text-stone-600 tabular-nums"><%= n %> <%= n == 1 ? "serviço" : "serviços" %></span>
                  </li>
                <% end %>
              </ul>
            </div>
          <% end %>

          <% if @lista_desde && @eventos_dia_filtro.any? %>
            <div class="rounded-xl bg-violet-50/90 border border-violet-100 p-3">
              <p class="text-[10px] font-bold uppercase tracking-wider text-violet-900 mb-2">No dia <%= l(@lista_desde, format: :short) %></p>
              <ul class="space-y-2 max-h-40 overflow-y-auto">
                <% @eventos_dia_filtro.each do |ev| %>
                  <% cor = ev.tipo_servico.cor_etiqueta.presence || "#64748b" %>
                  <li class="flex items-start gap-2 text-xs">
                    <span class="tabular-nums font-semibold text-stone-600 shrink-0 w-12"><%= l(ev.horario, format: :time) %></span>
                    <span class="inline-flex px-1.5 py-0.5 rounded text-[10px] font-semibold border leading-tight" style="background-color: <%= cor %>22; border-color: <%= cor %>55; color: #1e293b;"><%= ev.tipo_servico.nome %></span>
                  </li>
                <% end %>
              </ul>
            </div>
          <% elsif @lista_desde %>
            <p class="text-xs text-stone-500 italic">Neste dia você não tem serviço na escala.</p>
          <% end %>
        </div>

        <div class="rounded-2xl bg-gradient-to-br from-violet-900 to-indigo-950 text-white p-5 shadow-lg ring-1 ring-violet-500/20">
          <p class="text-sm font-medium text-violet-200">Lembrete</p>
          <p class="mt-2 text-sm leading-relaxed text-violet-100/95">Confirme sua presença em cada celebração quando a coordenação solicitar — assim a equipe organiza melhor o altar e a música.</p>
        </div>
      </div>
    </div>
  <% end %>
</div>
