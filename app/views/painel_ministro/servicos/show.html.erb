<% content_for :title, "Serviço — Sacristia Digital" %>
<% ev = @servico %>
<% mid = current_user.ministro_id %>
<% em = ev.escala_ministros.find { |x| x.ministro_id == mid } %>
<% cor = ev.tipo_servico.cor_etiqueta.presence || "#64748b" %>
<% ministros_escala = ev.escala_ministros.sort_by do |row|
     [
       row.coordenador? ? 0 : 1,
       row.adoracao? ? 0 : 1,
       row.ministro_id == mid ? 0 : 1,
       row.ministro&.nome.to_s.downcase
     ]
   end %>

<div class="space-y-6">
  <%= link_to ministro_meus_servicos_path, class: "inline-flex items-center gap-1 text-sm font-medium text-violet-700 hover:text-violet-900" do %>
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
    Voltar à lista
  <% end %>

  <div class="rounded-2xl border border-stone-200 bg-white shadow-sm overflow-hidden">
    <div class="px-6 py-5 border-b border-stone-100 bg-gradient-to-r from-violet-50/80 to-white">
      <p class="text-xs font-semibold uppercase tracking-wider text-violet-700">Sua função nesta celebração</p>
      <h1 class="text-2xl font-bold text-stone-900 mt-1"><%= ev.tipo_servico.nome %></h1>
      <p class="mt-2 text-stone-600 tabular-nums"><%= l(ev.data, format: :long) %> · <%= l(ev.horario, format: :time) %></p>
      <div class="flex flex-wrap gap-2 mt-3">
        <span class="inline-flex px-2.5 py-1 text-xs font-semibold rounded-lg border" style="background-color: <%= cor %>22; border-color: <%= cor %>55; color: #1e293b;"><%= ev.tipo_servico.nome %></span>
        <% if em&.coordenador? %><span class="inline-flex px-2.5 py-1 text-xs font-bold rounded-lg bg-amber-100 text-amber-900">Coordenador</span><% end %>
        <% if em&.adoracao? %><span class="inline-flex px-2.5 py-1 text-xs font-bold rounded-lg bg-fuchsia-100 text-fuchsia-900">Adoração</span><% end %>
        <% if em&.confirmado? %>
          <span class="inline-flex px-2.5 py-1 text-xs font-bold rounded-lg bg-emerald-100 text-emerald-800">Presença confirmada</span>
        <% else %>
          <span class="inline-flex px-2.5 py-1 text-xs font-bold rounded-lg bg-amber-100 text-amber-800">Confirmação pendente</span>
        <% end %>
      </div>
    </div>
    <div class="px-6 py-5 space-y-4 text-sm text-stone-700">
      <div>
        <p class="text-xs font-semibold uppercase tracking-wider text-stone-500">Sacerdote</p>
        <p class="mt-1 font-medium text-stone-900"><%= ev.sacerdote&.nome || tag.span("A definir", class: "text-stone-400 italic") %></p>
      </div>
      <% if ev.equipe %>
        <div>
          <p class="text-xs font-semibold uppercase tracking-wider text-stone-500">Equipe</p>
          <p class="mt-1"><%= ev.equipe.nome %></p>
        </div>
      <% end %>

      <div class="pt-1 border-t border-stone-100">
        <p class="text-xs font-semibold uppercase tracking-wider text-stone-500">Ministros nesta escala</p>
        <% if ministros_escala.empty? %>
          <p class="mt-2 text-stone-500 italic text-sm">Ainda não há ministros designados para este serviço.</p>
        <% else %>
          <ul class="mt-3 space-y-3">
            <% ministros_escala.each do |row| %>
              <% voce = row.ministro_id == mid %>
              <% nome_m = row.ministro&.nome.to_s %>
              <% iniciais = nome_m.split(/\s+/).reject(&:blank?).take(2).map { |w| w[0] }.join.upcase.presence || "?" %>
              <% papel_label = if row.coordenador? && row.adoracao?
                   "Coordenador e adoração"
                 elsif row.coordenador?
                   "Coordenador da equipe"
                 elsif row.adoracao?
                   "Adoração"
                 else
                   "Ministro na escala"
                 end %>
              <% barra = if row.coordenador? && row.adoracao?
                   "from-amber-400 via-fuchsia-400 to-fuchsia-500"
                 elsif row.coordenador?
                   "from-amber-400 to-amber-600"
                 elsif row.adoracao?
                   "from-fuchsia-400 to-fuchsia-600"
                 else
                   "from-stone-300 to-stone-400"
                 end %>
              <li class="flex gap-0 rounded-2xl border border-stone-200/90 bg-white shadow-sm overflow-hidden <%= voce ? "ring-2 ring-violet-400/70 ring-offset-2 ring-offset-stone-50" : "" %>">
                <div class="w-1 shrink-0 bg-gradient-to-b <%= barra %>" aria-hidden="true"></div>
                <div class="flex flex-1 min-w-0 gap-3 p-3 sm:p-4">
                  <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-gradient-to-br from-violet-100 to-indigo-100 text-sm font-bold text-violet-900 tabular-nums ring-1 ring-violet-200/60">
                    <%= iniciais %>
                  </div>
                  <div class="flex-1 min-w-0">
                    <div class="flex flex-wrap items-baseline gap-x-2 gap-y-1">
                      <span class="font-semibold text-stone-900 <%= voce ? "text-violet-950" : "" %> truncate"><%= row.ministro&.nome || "—" %></span>
                      <% if voce %>
                        <span class="inline-flex px-2 py-0.5 text-[10px] font-bold uppercase tracking-wide rounded-md bg-violet-200 text-violet-900 shrink-0">Você</span>
                      <% end %>
                    </div>
                    <p class="mt-1 text-sm text-stone-600">
                      <span class="text-stone-400 font-medium text-xs uppercase tracking-wider mr-1.5">Função</span>
                      <span class="font-medium text-stone-800"><%= papel_label %></span>
                    </p>
                    <div class="mt-2 flex flex-wrap gap-1.5">
                      <% if row.coordenador? %>
                        <span class="inline-flex items-center gap-1 px-2 py-0.5 text-[10px] font-bold uppercase tracking-wide rounded-md bg-amber-100 text-amber-900 border border-amber-200/80">
                          <svg class="w-3 h-3 shrink-0 opacity-80" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/></svg>
                          Coord.
                        </span>
                      <% end %>
                      <% if row.adoracao? %>
                        <span class="inline-flex items-center gap-1 px-2 py-0.5 text-[10px] font-bold uppercase tracking-wide rounded-md bg-fuchsia-100 text-fuchsia-900 border border-fuchsia-200/80">
                          <svg class="w-3 h-3 shrink-0 opacity-80" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3"/></svg>
                          Ador.
                        </span>
                      <% end %>
                      <% unless row.coordenador? || row.adoracao? %>
                        <span class="inline-flex items-center gap-1 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wide rounded-md bg-stone-100 text-stone-600 border border-stone-200/90">
                          <svg class="w-3 h-3 shrink-0 opacity-70" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                          Equipe
                        </span>
                      <% end %>
                    </div>
                  </div>
                </div>
              </li>
            <% end %>
          </ul>
          <p class="mt-3 text-xs text-stone-500 leading-relaxed">A faixa colorida à esquerda resume a função: âmbar = coordenação, rosa = adoração, cinza = ministro da equipe. Dois papéis no mesmo ministro aparecem com faixa em degradê.</p>
        <% end %>
      </div>

      <% unless em&.confirmado? %>
        <div class="pt-2">
          <%= button_to "Confirmar presença", confirmar_ministro_servico_path(ev), method: :patch, class: "inline-flex items-center justify-center px-5 py-2.5 rounded-xl bg-violet-600 text-white text-sm font-semibold hover:bg-violet-700 transition-colors" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
