<% content_for :title, "Área do sacerdote — Sacristia Digital" %>
<div class="min-h-screen flex flex-col items-center justify-center p-6">
  <div class="max-w-md w-full rounded-2xl border border-stone-200 bg-white shadow-lg p-8 text-center">
    <h1 class="text-xl font-bold text-stone-900">Olá<%= @sacerdote ? ", #{@sacerdote.nome.split.first}" : "" %></h1>
    <p class="text-stone-600 text-sm mt-3 leading-relaxed">
      Esta é a área do sacerdote. Recursos específicos (espórtulas, agenda, etc.) podem ser adicionados aqui no futuro.
    </p>
    <div class="mt-6 flex flex-col gap-2">
      <%= link_to "Minha conta e senha", edit_user_registration_path, class: "text-sm font-semibold text-sky-700 hover:text-sky-900" %>
      <%= link_to "Início", root_path, class: "text-sm font-medium text-stone-600 hover:text-stone-900" %>
      <%= button_to "Sair", destroy_user_session_path, method: :delete, form: { data: { turbo: false } }, class: "text-sm text-stone-500 hover:text-stone-800 mx-auto" %>
    </div>
  </div>
</div>
