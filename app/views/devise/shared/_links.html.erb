<% if controller_name != "sessions" %>
  <%= link_to "Já tem conta? Entrar", new_session_path(resource_name), class: "text-sm font-medium text-violet-700 hover:text-violet-900 transition-colors" %><br />
<% end %>
<% if devise_mapping.recoverable? && controller_name != "passwords" && controller_name != "registrations" %>
  <%= link_to new_password_path(resource_name), class: "inline-flex items-center gap-1.5 text-sm font-medium text-stone-500 hover:text-violet-700 transition-colors group" do %>
    <svg class="w-3.5 h-3.5 opacity-60 group-hover:opacity-100 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"/></svg>
    Esqueceu sua senha?
  <% end %>
<% end %>
