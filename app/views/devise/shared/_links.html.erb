<% if controller_name != 'sessions' %>
  <%= link_to "Já tem conta? Entrar", new_session_path(resource_name), class: "text-sm text-slate-600 hover:text-slate-800" %><br />
<% end %>
<% if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
  <%= link_to "Esqueceu sua senha?", new_password_path(resource_name), class: "text-sm text-slate-600 hover:text-slate-800" %><br />
<% end %>
