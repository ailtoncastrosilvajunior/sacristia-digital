<% if resource.errors.any? %>
  <div class="rounded-xl bg-red-50 border border-red-200 text-red-800 px-4 py-3 text-sm mb-4" role="alert">
    <p class="font-semibold"><%= pluralize(resource.errors.count, "erro") %> impediram salvar:</p>
    <ul class="list-disc list-inside mt-2 space-y-1">
      <% resource.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>
