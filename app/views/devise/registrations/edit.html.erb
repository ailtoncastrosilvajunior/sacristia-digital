<% content_for :title, "Minha conta — Sacristia Digital" %>

<div class="min-h-screen bg-stone-100/80 px-4 py-10 sm:py-14">
  <div class="max-w-md mx-auto">
    <div class="text-center mb-8">
      <%= link_to root_path, class: "inline-flex items-center gap-2 text-sm font-medium text-sky-700 hover:text-sky-900" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        Voltar ao início
      <% end %>
      <h1 class="mt-6 text-2xl font-bold text-stone-900 tracking-tight">Minha conta</h1>
      <p class="mt-2 text-sm text-stone-600">Atualize seu nome e sua senha. Para alterar a senha, preencha os três campos de senha abaixo.</p>
    </div>

    <div class="rounded-2xl border border-stone-200 bg-white shadow-sm p-6 sm:p-8">
      <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put, class: "space-y-5" }) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>

        <div>
          <%= f.label :email, class: "block text-sm font-medium text-stone-700 mb-1" %>
          <%= f.email_field :email, autocomplete: "email", class: "block w-full rounded-xl border-stone-300 shadow-sm focus:border-sky-500 focus:ring-sky-500" %>
        </div>

        <div>
          <%= f.label :nome, class: "block text-sm font-medium text-stone-700 mb-1" %>
          <%= f.text_field :nome, autocomplete: "name", class: "block w-full rounded-xl border-stone-300 shadow-sm focus:border-sky-500 focus:ring-sky-500" %>
        </div>

        <div class="pt-2 border-t border-stone-100">
          <p class="text-xs font-semibold uppercase tracking-wide text-stone-500 mb-3">Alterar senha</p>
          <p class="text-xs text-stone-500 mb-4">Deixe em branco se não quiser mudar a senha.</p>

          <div class="space-y-4">
            <div>
              <%= f.label :password, "Nova senha", class: "block text-sm font-medium text-stone-700 mb-1" %>
              <%= f.password_field :password, autocomplete: "new-password", class: "block w-full rounded-xl border-stone-300 shadow-sm focus:border-sky-500 focus:ring-sky-500" %>
            </div>
            <div>
              <%= f.label :password_confirmation, "Confirmar nova senha", class: "block text-sm font-medium text-stone-700 mb-1" %>
              <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "block w-full rounded-xl border-stone-300 shadow-sm focus:border-sky-500 focus:ring-sky-500" %>
            </div>
            <div>
              <%= f.label :current_password, "Senha atual", class: "block text-sm font-medium text-stone-700 mb-1" %>
              <span class="text-xs text-stone-500 block mb-1">Obrigatória para confirmar as alterações.</span>
              <%= f.password_field :current_password, autocomplete: "current-password", class: "block w-full rounded-xl border-stone-300 shadow-sm focus:border-sky-500 focus:ring-sky-500" %>
            </div>
          </div>
        </div>

        <div class="pt-2">
          <%= f.submit "Salvar alterações", class: "w-full cursor-pointer rounded-xl bg-sky-600 px-4 py-3 text-sm font-semibold text-white shadow-md shadow-sky-900/15 hover:bg-sky-700 transition-colors" %>
        </div>
      <% end %>
    </div>

    <p class="mt-6 text-center text-xs text-stone-500">
      <%= button_to "Sair da conta", destroy_user_session_path, method: :delete, form: { data: { turbo: false }, class: "inline" }, class: "text-stone-600 hover:text-stone-900 underline-offset-2 hover:underline bg-transparent border-0 cursor-pointer p-0 font-medium" %>
    </p>
  </div>
</div>
