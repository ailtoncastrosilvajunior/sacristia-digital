<% content_for :title, "Entrar — Sacristia Digital" %>

<div class="relative min-h-screen flex flex-col items-center justify-center px-4 py-14 sm:py-20 overflow-hidden">
  <%# Fundo — camadas discretas, profundidade suave %>
  <div class="absolute inset-0 bg-slate-950" aria-hidden="true"></div>
  <div class="absolute inset-0 bg-gradient-to-b from-slate-950 via-violet-950/40 to-slate-950" aria-hidden="true"></div>
  <div class="absolute inset-0 bg-gradient-to-tr from-indigo-950/50 via-transparent to-violet-900/25" aria-hidden="true"></div>
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[min(100%,42rem)] h-64 bg-violet-500/15 blur-[100px] rounded-full pointer-events-none" aria-hidden="true"></div>
  <div class="absolute bottom-0 right-0 w-[36rem] h-[36rem] bg-indigo-600/10 blur-[120px] rounded-full translate-x-1/3 translate-y-1/3 pointer-events-none" aria-hidden="true"></div>
  <div class="absolute inset-0 opacity-[0.04]" style="background-image: url('data:image/svg+xml,%3Csvg width=\'60\' height=\'60\' viewBox=\'0 0 60 60\' xmlns=\'http://www.w3.org/2000/svg\'%3E%3Cg fill=\'none\' fill-rule=\'evenodd\'%3E%3Cg fill=\'%23ffffff\' fill-opacity=\'1\'%3E%3Cpath d=\'M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z\'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');" aria-hidden="true"></div>

  <div class="relative z-10 w-full max-w-[420px]">
    <%# Marca %>
    <div class="text-center mb-10">
      <div class="inline-flex h-14 w-14 items-center justify-center rounded-2xl bg-white/5 ring-1 ring-white/10 shadow-lg shadow-black/20 mb-5">
        <svg class="w-7 h-7 text-violet-300/90" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
        </svg>
      </div>
      <p class="text-[11px] font-semibold tracking-[0.22em] uppercase text-violet-300/70">Ministros · MESC</p>
      <h1 class="mt-3 text-3xl sm:text-[2rem] font-bold text-white tracking-tight">Sacristia Digital</h1>
      <p class="mt-2 text-sm text-slate-400 leading-relaxed max-w-xs mx-auto">Entre para acompanhar escalas e serviços com calma e clareza.</p>
    </div>

    <%# Cartão %>
    <div class="rounded-3xl bg-white/[0.97] backdrop-blur-2xl shadow-[0_25px_50px_-12px_rgba(0,0,0,0.45)] ring-1 ring-white/60 border border-white/80 px-6 py-8 sm:px-8 sm:py-9">
      <div class="flex items-center justify-between gap-3 mb-7">
        <h2 class="text-lg font-semibold text-stone-900 tracking-tight">Entrar</h2>
        <span class="text-[10px] font-semibold uppercase tracking-wider text-stone-400 tabular-nums">Área segura</span>
      </div>

      <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-5" }) do |f| %>
        <div class="space-y-1.5">
          <%= f.label :email, class: "block text-xs font-semibold uppercase tracking-wider text-stone-500" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email",
              class: "w-full px-4 py-3 rounded-xl border border-stone-200/90 bg-stone-50/40 text-stone-900 placeholder:text-stone-400 text-[15px] shadow-inner shadow-stone-900/5 focus:outline-none focus:ring-2 focus:ring-violet-500/25 focus:border-violet-400/80 focus:bg-white transition-all",
              placeholder: "nome@exemplo.com" %>
        </div>

        <div class="space-y-1.5">
          <%= f.label :password, "Senha", class: "block text-xs font-semibold uppercase tracking-wider text-stone-500" %>
          <%= f.password_field :password, autocomplete: "current-password",
              class: "w-full px-4 py-3 rounded-xl border border-stone-200/90 bg-stone-50/40 text-stone-900 text-[15px] shadow-inner shadow-stone-900/5 focus:outline-none focus:ring-2 focus:ring-violet-500/25 focus:border-violet-400/80 focus:bg-white transition-all",
              placeholder: "••••••••" %>
        </div>

        <% if devise_mapping.rememberable? %>
          <div class="flex items-center gap-3 pt-0.5">
            <%= f.check_box :remember_me, class: "h-4 w-4 rounded-md border-stone-300 text-violet-600 focus:ring-violet-500/30 focus:ring-offset-0" %>
            <%= f.label :remember_me, "Manter conectado neste aparelho", class: "text-sm text-stone-600 cursor-pointer select-none" %>
          </div>
        <% end %>

        <div class="pt-2">
          <%= f.submit "Entrar",
              class: "w-full cursor-pointer rounded-xl bg-gradient-to-r from-violet-600 via-violet-600 to-indigo-600 px-4 py-3.5 text-[15px] font-semibold text-white shadow-lg shadow-violet-900/25 ring-1 ring-white/10 transition-all hover:from-violet-500 hover:to-indigo-500 hover:shadow-violet-900/35 active:scale-[0.99] focus:outline-none focus-visible:ring-2 focus-visible:ring-violet-400 focus-visible:ring-offset-2 focus-visible:ring-offset-white" %>
        </div>
      <% end %>

      <div class="mt-8 pt-6 border-t border-stone-100">
        <%= render "devise/shared/links" %>
      </div>
    </div>

    <p class="mt-10 text-center text-[11px] leading-relaxed text-slate-500 max-w-sm mx-auto px-2">
      Sistema para gestão das escalas dos Ministros Extraordinários da Sagrada Comunhão
    </p>
  </div>
</div>
