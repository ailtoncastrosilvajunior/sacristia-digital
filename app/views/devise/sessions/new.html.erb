<div class="min-h-screen flex items-center justify-center bg-gradient-to-br from-stone-50 via-slate-50 to-stone-100 px-4">
  <div class="w-full max-w-md">
    <div class="text-center mb-8">
      <h1 class="text-2xl font-semibold text-stone-800 tracking-tight">Sacristia Digital</h1>
      <p class="mt-2 text-sm text-stone-500">Sistema de gestão MESC</p>
    </div>

    <div class="bg-white rounded-2xl shadow-sm border border-stone-200/60 p-8">
      <h2 class="text-lg font-medium text-stone-800 mb-6">Entrar na sua conta</h2>

      <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-5" }) do |f| %>
        <div>
          <%= f.label :email, class: "block text-sm font-medium text-stone-700 mb-1" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email",
              class: "w-full px-4 py-2.5 rounded-lg border border-stone-300 focus:ring-2 focus:ring-slate-500/20 focus:border-slate-500 transition-colors",
              placeholder: "seu@email.com" %>
        </div>

        <div>
          <%= f.label :password, "Senha", class: "block text-sm font-medium text-stone-700 mb-1" %>
          <%= f.password_field :password, autocomplete: "current-password",
              class: "w-full px-4 py-2.5 rounded-lg border border-stone-300 focus:ring-2 focus:ring-slate-500/20 focus:border-slate-500 transition-colors" %>
        </div>

        <% if devise_mapping.rememberable? %>
          <div class="flex items-center">
            <%= f.check_box :remember_me, class: "rounded border-stone-300 text-slate-600 focus:ring-slate-500" %>
            <%= f.label :remember_me, "Lembrar de mim", class: "ml-2 text-sm text-stone-600" %>
          </div>
        <% end %>

        <div class="pt-2">
          <%= f.submit "Entrar", class: "w-full py-2.5 px-4 bg-slate-600 hover:bg-slate-700 text-white font-medium rounded-lg transition-colors cursor-pointer" %>
        </div>
      <% end %>

      <div class="mt-6 pt-6 border-t border-stone-200">
        <%= render "devise/shared/links" %>
      </div>
    </div>

    <p class="mt-6 text-center text-xs text-stone-400">
      Sistema para gestão das escalas dos Ministros Extraordinários da Sagrada Comunhão
    </p>
  </div>
</div>
